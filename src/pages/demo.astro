---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import PhoneFrame from "../components/PhoneFrame.astro";
import KanbanScreen from "../components/screens/KanbanScreen.astro";
import AgendaScreen from "../components/screens/AgendaScreen.astro";
import BibleScreen from "../components/screens/BibleScreen.astro";
import NotificationsScreen from "../components/screens/NotificationsScreen.astro";

const captions = [
  {
    label: "Tâches Kanban",
    description: "Tableau, attribution, deadlines. Du PV à l'action en un glissement.",
  },
  {
    label: "Agenda partagé",
    description: "Tous les évènements visibles, synchronisés avec Google et Apple.",
  },
  {
    label: "La Bible documentaire",
    description: "Statuts, PV, contrats. Recherche instantanée dans 248 docs.",
  },
  {
    label: "Notifications",
    description: "Push mobile seulement quand ça compte. Pas de spam.",
  },
];
---

<Layout
  title="Réserver une démo — Konclav"
  description="Découvrez Konclav en 20 minutes. Une démo personnalisée pour votre association, sans discours commercial."
>
  <Navbar />
  <main>
    <!-- Mini hero -->
    <section class="relative px-6 pt-40 pb-8 sm:pt-44">
      <div class="mx-auto max-w-3xl text-center">
        <div
          data-reveal
          class="mb-8 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-3 py-1 text-xs text-ink-400"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-accent-500"></span>
          Démo personnalisée
        </div>
        <h1
          data-reveal
          class="text-balance text-4xl font-semibold leading-[1.05] tracking-tight text-ink-50 sm:text-5xl md:text-6xl"
        >
          Toute la vie associative, dans une seule app.
        </h1>
        <p
          data-reveal
          class="mx-auto mt-6 max-w-xl text-pretty text-base leading-relaxed text-ink-400 sm:text-lg"
        >
          Découvrez Konclav en 20 minutes. Adapté à votre asso, en direct, sans
          discours commercial.
        </p>
      </div>
    </section>

    <!-- Phone cluster -->
    <section class="relative isolate overflow-hidden px-6 pb-20">
      <div
        aria-hidden="true"
        class="pointer-events-none absolute left-1/2 top-1/2 -z-10 h-[800px] w-[1100px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-40 blur-3xl"
        style="background: radial-gradient(ellipse 60% 50% at center, rgba(94,106,210,0.30), transparent 70%);"
      >
      </div>

      <div class="mx-auto max-w-7xl">
        <div
          class="-mx-6 flex justify-start gap-6 overflow-x-auto px-6 pb-6 snap-x snap-mandatory md:mx-0 md:justify-center md:gap-0 md:overflow-visible md:px-0 md:pb-0 md:snap-none md:[&>*:not(:first-child)]:-ml-8 lg:[&>*:not(:first-child)]:-ml-12"
        >
          <PhoneFrame
            activeTab="taches"
            rotate="md:-rotate-6"
            translateY="md:translate-y-8"
            delay={0}
            zIndex={1}
          >
            <KanbanScreen />
          </PhoneFrame>
          <PhoneFrame
            activeTab="agenda"
            rotate="md:-rotate-2"
            translateY="md:translate-y-0"
            delay={120}
            zIndex={4}
          >
            <AgendaScreen />
          </PhoneFrame>
          <PhoneFrame
            activeTab="plus"
            rotate="md:rotate-2"
            translateY="md:translate-y-4"
            delay={240}
            zIndex={3}
          >
            <BibleScreen />
          </PhoneFrame>
          <PhoneFrame
            activeTab="accueil"
            rotate="md:rotate-6"
            translateY="md:translate-y-12"
            delay={360}
            zIndex={2}
          >
            <NotificationsScreen />
          </PhoneFrame>
        </div>
      </div>
    </section>

    <!-- Captions -->
    <section class="relative px-6 pb-32">
      <div class="mx-auto max-w-6xl">
        <div class="grid gap-x-8 gap-y-6 sm:grid-cols-2 lg:grid-cols-4">
          {
            captions.map((c, i) => (
              <div
                data-reveal
                style={`transition-delay: ${i * 80}ms`}
                class="text-center md:text-left"
              >
                <p class="text-sm font-medium text-ink-50">{c.label}</p>
                <p class="mt-1.5 text-xs leading-relaxed text-ink-400">
                  {c.description}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CTA / contact -->
    <section
      id="reserver"
      class="relative border-t border-white/5 px-6 py-32 sm:py-40"
    >
      <div class="mx-auto max-w-2xl">
        <div data-reveal class="text-center">
          <p class="text-sm font-medium text-accent-500">Réserver ma démo</p>
          <h2
            class="mt-3 text-balance text-3xl font-semibold leading-tight tracking-tight text-ink-50 sm:text-4xl"
          >
            On se cale 20 minutes ?
          </h2>
          <p class="mt-4 text-pretty text-base leading-relaxed text-ink-400">
            Le formulaire de réservation arrive bientôt. En attendant, un mail
            suffit — on répond sous 24h ouvrées.
          </p>
        </div>

        <div
          data-reveal
          class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row"
        >
          <a
            href="mailto:mxrtystream@gmail.com?subject=Demande%20de%20d%C3%A9mo%20Konclav&body=Bonjour%2C%0A%0AJe%20repr%C3%A9sente%20l%27association%20%3A%20%0ANombre%20de%20membres%20%3A%20%0AT%C3%A9l%C3%A9phone%20%3A%20%0AMes%20disponibilit%C3%A9s%20%3A%20%0A%0AMerci%20%21"
            class="inline-flex items-center justify-center gap-1.5 rounded-lg bg-accent-500 px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-accent-400"
          >
            Mail prérempli
            <svg
              viewBox="0 0 16 16"
              fill="none"
              class="h-4 w-4"
              aria-hidden="true"
            >
              <path
                d="M3.5 8h9m0 0L8 3.5M12.5 8 8 12.5"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </a>
          <a
            href="mailto:mxrtystream@gmail.com"
            class="inline-flex items-center justify-center rounded-lg border border-white/10 bg-white/[0.02] px-6 py-3 text-sm font-medium text-ink-50 transition-colors hover:border-white/20 hover:bg-white/[0.04]"
          >
            Mail vide
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
