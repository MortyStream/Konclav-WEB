    const bcError = root.querySelector("[data-bc-error]");
    const bcTitle = document.getElementById("ck-cust-title");

    function editCustomer(id) {
      const fields = bcForm.querySelectorAll("[data-bc-field]");
      fields.forEach((f) => { f.value = f.dataset.bcField === "country" ? "CH" : ""; });
      bcIdInput.value = "";
      bcError.hidden = true;
      bcTitle.textContent = id ? "Modifier le client" : "Nouveau client";
      if (id) {
        const c = customers.find((x) => x.id === id);
        if (c) {
          bcIdInput.value = c.id;
          fields.forEach((f) => { const k = f.dataset.bcField; if (c[k] != null) f.value = c[k]; });
        }
      }
      openModal("customer");
    }
    async function deleteCustomer(id) {
      const c = customers.find((x) => x.id === id);
      if (!confirm("Supprimer « " + (c ? c.asso_name : "ce client") + " » ?\nRefusé s'il reste des factures à son nom — supprimez-les d'abord.")) return;
      try {
        await api("customers?id=eq." + encodeURIComponent(id), { method: "DELETE", headers: { Prefer: "return=minimal" } });
        toast("Client supprimé.");
        loadCustomers();
      } catch (e) {
        if (String(e.message).indexOf("23503") !== -1) toast("Suppression refusée : des factures sont rattachées à ce client.", "error");
        else toast("Échec de la suppression : " + e.message, "error");
      }
    }
    bcForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      const data = {};
      bcForm.querySelectorAll("[data-bc-field]").forEach((f) => { data[f.dataset.bcField] = (f.value || "").trim() || null; });
      if (!data.asso_name) { bcError.textContent = "Nom requis."; bcError.hidden = false; return; }
      const id = bcIdInput.value;
      const btn = root.querySelector("[data-bc-submit]");
      btn.disabled = true; bcError.hidden = true;
      try {
        if (id) {
          await api("customers?id=eq." + encodeURIComponent(id), { method: "PATCH", headers: { Prefer: "return=minimal" }, body: JSON.stringify(data) });
        } else {
          await api("customers", { method: "POST", headers: { Prefer: "return=minimal" }, body: JSON.stringify(data) });
        }
        closeModals();
        toast(id ? "Client mis à jour ✓" : "Client créé ✓");
        await loadCustomers();
      } catch (err) { bcError.textContent = err.message || "Erreur."; bcError.hidden = false; }
      finally { btn.disabled = false; }
    });

    // ----- Abonnements -----
    let subsList = [];
    const bsContent = root.querySelector("[data-bs-content]");
    const INTERVALS = { monthly: "Mensuel", yearly: "Annuel" };
    async function loadSubscriptions() {
      const signal = freshSignal("subs");
      bsContent.innerHTML = '<p class="mt-12 text-center text-sm text-ink-500">Chargement…</p>';
      try {
        const res = await api("subscriptions?select=*,customer:customers(asso_name)&order=created_at.desc", { signal });
        subsList = await res.json();
        renderSubscriptions();
      } catch (e) {
        if (isAbort(e)) return;
        bsContent.innerHTML = '<p class="mt-12 text-center text-sm text-rose-400">Erreur : ' + esc(String(e)) + "</p>";
      }
    }
    function renderSubscriptions() {
      if (!subsList.length) {
        bsContent.innerHTML = '<p class="mt-12 text-center text-sm text-ink-500">Aucun abonnement. Créez-en un : les factures se généreront toutes seules à chaque échéance.</p>';
        return;
      }
      bsContent.innerHTML = '<div class="mt-6 overflow-x-auto rounded-2xl border border-white/10 bg-white/[0.02]">' +
        '<table class="w-full text-sm">' +
        '<thead class="bg-white/[0.03] text-xs uppercase tracking-wide text-ink-500">' +
        '<tr><th scope="col" class="px-4 py-3 text-left">Client</th><th scope="col" class="px-4 py-3 text-left">Libellé</th><th scope="col" class="px-4 py-3 text-right">Montant</th><th scope="col" class="px-4 py-3 text-left">Intervalle</th><th scope="col" class="px-4 py-3 text-left">Prochaine facture</th><th scope="col" class="px-4 py-3 text-left">Statut</th><th scope="col" class="px-4 py-3"><span class="sr-only">Actions</span></th></tr></thead>' +
        '<tbody class="divide-y divide-white/[0.06]">' +
        subsList.map((s) =>
          '<tr data-sub="' + esc(s.id) + '">' +
          '<td class="px-4 py-3 font-semibold text-ink-50">' + esc((s.customer && s.customer.asso_name) || "—") + "</td>" +
          '<td class="px-4 py-3 text-ink-300">' + esc(s.label) + "</td>" +
          '<td class="px-4 py-3 text-right tabular-nums text-ink-50">' + fmtCHF(s.amount, s.currency) + "</td>" +
          '<td class="px-4 py-3 text-ink-300">' + (INTERVALS[s.billing_interval] || esc(s.billing_interval)) + "</td>" +
          '<td class="px-4 py-3 text-ink-300">' + fmtDate(s.next_invoice_date) + "</td>" +
          '<td class="px-4 py-3">' + (s.active
            ? '<span class="rounded-md bg-emerald-400/10 px-2 py-0.5 text-[11px] font-medium text-emerald-400">Actif</span>'
            : '<span class="rounded-md bg-white/[0.06] px-2 py-0.5 text-[11px] font-medium text-ink-400">En pause</span>') + "</td>" +
          '<td class="px-4 py-3 text-right whitespace-nowrap">' +
          '<button type="button" data-sub-edit class="text-xs text-accent-300 hover:text-accent-400">Modifier</button>' +
          ' · <button type="button" data-sub-toggle class="text-xs text-ink-300 hover:text-ink-50">' + (s.active ? "Pause" : "Reprendre") + "</button>" +
          ' · <button type="button" data-sub-del class="text-xs text-rose-400 hover:text-rose-300">×</button>' +
          "</td></tr>"
        ).join("") + "</tbody></table></div>";
    }
    bsContent.addEventListener("click", async (e) => {
      const tr = e.target.closest("[data-sub]"); if (!tr) return;
      const id = tr.dataset.sub;
      const s = subsList.find((x) => x.id === id);
      if (e.target.closest("[data-sub-edit]")) editSubscription(id);
      else if (e.target.closest("[data-sub-toggle]") && s) {
        try {
          await api("subscriptions?id=eq." + encodeURIComponent(id), { method: "PATCH", headers: { Prefer: "return=minimal" }, body: JSON.stringify({ active: !s.active }) });
          toast(s.active ? "Abonnement en pause." : "Abonnement réactivé ✓");
          loadSubscriptions();
        } catch (err) { toast("Échec : " + err.message, "error"); }
      } else if (e.target.closest("[data-sub-del]") && s) {
        if (!confirm("Supprimer cet abonnement ?\nLes factures déjà générées sont conservées.")) return;
        try {
          await api("subscriptions?id=eq." + encodeURIComponent(id), { method: "DELETE", headers: { Prefer: "return=minimal" } });
          toast("Abonnement supprimé.");
          loadSubscriptions();
        } catch (err) { toast("Échec : " + err.message, "error"); }
      }
    });
    root.querySelector("[data-bs-new]").addEventListener("click", () => editSubscription(null));

    const bsForm = root.querySelector("[data-bs-form]");
    const bsIdInput = root.querySelector("[data-bs-id]");
    const bsError = root.querySelector("[data-bs-error]");
    const bsTitle = document.getElementById("ck-sub-title");
    async function editSubscription(id) {
      if (!customers.length) { try { const r = await api("customers?select=id,asso_name&order=asso_name.asc"); customers = await r.json(); } catch {} }
      const sel = bsForm.querySelector('[data-bs-field="customer_id"]');
      sel.innerHTML = '<option value="">— Sélectionner —</option>' + customers.map((c) => '<option value="' + esc(c.id) + '">' + esc(c.asso_name) + "</option>").join("");
      bsForm.querySelector('[data-bs-field="label"]').value = "Abonnement Konclav";
      bsForm.querySelector('[data-bs-field="amount"]').value = "";
      bsForm.querySelector('[data-bs-field="currency"]').value = "CHF";
      bsForm.querySelector('[data-bs-field="vat_rate"]').value = 0;
      bsForm.querySelector('[data-bs-field="billing_interval"]').value = "yearly";
      bsForm.querySelector('[data-bs-field="next_invoice_date"]').value = todayISO();
      bsForm.querySelector('[data-bs-field="issuer_iban"]').value = "";
      bsIdInput.value = "";
      bsError.hidden = true;
      bsTitle.textContent = id ? "Modifier l'abonnement" : "Nouvel abonnement";
      if (id) {
        const s = subsList.find((x) => x.id === id);
        if (s) {
          bsIdInput.value = s.id;
          ["customer_id", "label", "amount", "currency", "vat_rate", "billing_interval", "next_invoice_date", "issuer_iban"].forEach((k) => {
            const f = bsForm.querySelector('[data-bs-field="' + k + '"]'); if (f && s[k] != null) f.value = s[k];
          });
        }
      }
      openModal("subscription");
    }
    bsForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      const data = {
        customer_id: bsForm.querySelector('[data-bs-field="customer_id"]').value || null,
        label: bsForm.querySelector('[data-bs-field="label"]').value.trim() || "Abonnement Konclav",
        amount: +bsForm.querySelector('[data-bs-field="amount"]').value || 0,
        currency: bsForm.querySelector('[data-bs-field="currency"]').value || "CHF",
        vat_rate: +bsForm.querySelector('[data-bs-field="vat_rate"]').value || 0,
        billing_interval: bsForm.querySelector('[data-bs-field="billing_interval"]').value || "yearly",
        next_invoice_date: bsForm.querySelector('[data-bs-field="next_invoice_date"]').value || todayISO(),
        issuer_iban: bsForm.querySelector('[data-bs-field="issuer_iban"]').value.replace(/\s/g, "") || null,
      };
      if (!data.customer_id) { bsError.textContent = "Client requis."; bsError.hidden = false; return; }
      if (data.amount <= 0) { bsError.textContent = "Montant requis."; bsError.hidden = false; return; }
      const id = bsIdInput.value;
      const btn = root.querySelector("[data-bs-submit]");
      btn.disabled = true; bsError.hidden = true;
      try {
        if (id) await api("subscriptions?id=eq." + encodeURIComponent(id), { method: "PATCH", headers: { Prefer: "return=minimal" }, body: JSON.stringify(data) });
        else await api("subscriptions", { method: "POST", headers: { Prefer: "return=minimal" }, body: JSON.stringify(data) });
        closeModals();
        toast(id ? "Abonnement mis à jour ✓" : "Abonnement créé ✓ — facture générée à l'échéance");
        await loadSubscriptions();
      } catch (err) { bsError.textContent = err.message || "Erreur."; bsError.hidden = false; }
      finally { btn.disabled = false; }
    });

    // ----- Factures -----
    async function loadInvoices() {
      const signal = freshSignal("invoices");
      biContent.innerHTML = '<p class="mt-12 text-center text-sm text-ink-500">Chargement…</p>';
      try {
        // Filet opportuniste (en plus du cron 6h) : génère les factures d'abonnement
        // échues et passe les factures dépassées en retard.
        try {
          const bd = await api("rpc/billing_daily", { method: "POST", body: "{}", signal });
          const d = await bd.json();
          if (d && d.generated > 0) toast(d.generated + " facture(s) d'abonnement générée(s) 📄");
        } catch (e) { if (isAbort(e)) throw e; }
        const res = await api("invoices?select=*,customer:customers(asso_name,contact_name)&order=issue_date.desc", { signal });
        invoicesList = await res.json();
        renderInvoices();
      } catch (e) {
        if (isAbort(e)) return;
        biContent.innerHTML = '<p class="mt-12 text-center text-sm text-rose-400">Erreur : ' + esc(String(e)) + '</p>';
      }
    }
    function invoiceStatus(v) {
      const map = { draft: ["Brouillon", "#8b8b94"], sent: ["Envoyée", "#7170ff"], paid: ["Payée", "#4ade80"], overdue: ["En retard", "#f87171"], canceled: ["Annulée", "#52525b"] };
      return map[v] || [v, "#8b8b94"];
    }
    function renderInvoices() {
      if (!invoicesList.length) {
        biContent.innerHTML = '<p class="mt-12 text-center text-sm text-ink-500">Aucune facture. Cliquez sur « Nouvelle facture » pour démarrer.</p>';
        return;
      }
      const today = todayISO();
      const monthKey = today.slice(0, 7);
      const isLate = (inv) => inv.status === "overdue" || (inv.status === "sent" && inv.due_date && inv.due_date < today);
      const sums = invoicesList.reduce((acc, inv) => {
        const sign = inv.doc_type === "credit_note" ? -1 : 1;
        const t = (Number(inv.total) || 0) * sign;
        if (inv.status === "paid") { acc.paidAll += t; if ((inv.paid_at || "").slice(0, 7) === monthKey) acc.paidMonth += t; }
        else if (sign === 1 && isLate(inv)) acc.late += t;
        else if (sign === 1 && inv.status === "sent") acc.due += t;
        return acc;
      }, { paidMonth: 0, due: 0, late: 0, paidAll: 0 });

      const kpi = (label, value, color) =>
        '<div class="rounded-2xl border border-white/10 bg-white/[0.02] p-4">' +
        '<p class="text-2xl font-semibold tabular-nums" style="color:' + color + '">' + esc(value) + '</p>' +
        '<p class="mt-0.5 text-xs text-ink-500">' + esc(label) + '</p></div>';

      biContent.innerHTML =
        '<div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">' +
        kpi("Encaissé ce mois-ci", fmtCHF(sums.paidMonth, "CHF"), "#4ade80") +
        kpi("En attente", fmtCHF(sums.due, "CHF"), "#fbbf24") +
        kpi("En retard", fmtCHF(sums.late, "CHF"), sums.late > 0 ? "#f87171" : "#8b8b94") +
        kpi("Encaissé total", fmtCHF(sums.paidAll, "CHF"), "#f4f4f5") +
        '</div>' +
        '<div class="mt-6 overflow-hidden rounded-2xl border border-white/10 bg-white/[0.02]">' +
        '<table class="w-full text-sm">' +
        '<thead class="bg-white/[0.03] text-xs uppercase tracking-wide text-ink-500">' +
        '<tr><th scope="col" class="px-4 py-3 text-left">Numéro</th><th scope="col" class="px-4 py-3 text-left">Client</th><th scope="col" class="px-4 py-3 text-left">Émise</th><th scope="col" class="px-4 py-3 text-left">Échéance</th><th scope="col" class="px-4 py-3 text-right">Total</th><th scope="col" class="px-4 py-3 text-left">Statut</th><th scope="col" class="px-4 py-3"><span class="sr-only">Actions</span></th></tr>' +
        '</thead><tbody class="divide-y divide-white/[0.06]">' +
        invoicesList.map((inv) => {
          const st = invoiceStatus(inv.status);
          return '<tr data-invoice="' + esc(inv.id) + '">' +
            '<td class="px-4 py-3 font-mono text-xs text-ink-200">' + esc(inv.number) +
            (inv.doc_type === "credit_note" ? ' <span class="rounded bg-rose-400/10 px-1 py-0.5 text-[9px] font-semibold text-rose-400">AVOIR</span>' : "") +
            (inv.subscription_id ? ' <span title="Générée par abonnement">🔄</span>' : "") + '</td>' +
            '<td class="px-4 py-3 text-ink-200">' + esc((inv.customer && inv.customer.asso_name) || "—") + '</td>' +
            '<td class="px-4 py-3 text-ink-300">' + fmtDate(inv.issue_date) + '</td>' +
            '<td class="px-4 py-3 ' + (isLate(inv) ? 'font-medium text-rose-400' : 'text-ink-300') + '">' + fmtDate(inv.due_date) + '</td>' +
            '<td class="px-4 py-3 text-right font-semibold tabular-nums text-ink-50">' + fmtCHF(inv.total, inv.currency) + '</td>' +
            '<td class="px-4 py-3"><select data-inv-status class="rounded-lg border border-white/10 bg-ink-900 px-2 py-1 text-xs text-ink-50 focus:border-accent-500/50 focus:outline-none">' +
            ["draft", "sent", "paid", "overdue", "canceled"].map((v) => '<option value="' + v + '"' + (v === inv.status ? " selected" : "") + '>' + invoiceStatus(v)[0] + '</option>').join("") +
            '</select></td>' +
            '<td class="px-4 py-3 text-right whitespace-nowrap">' +
            '<button type="button" data-inv-pdf class="text-xs text-accent-300 hover:text-accent-400">PDF</button>' +
            ((inv.status === "sent" || inv.status === "overdue") && inv.doc_type !== "credit_note"
              ? ' · <button type="button" data-inv-remind class="text-xs text-amber-400 hover:text-amber-300">Relancer' + (inv.reminder_count > 0 ? " · " + inv.reminder_count : "") + '</button>'
              : "") +
            (inv.doc_type !== "credit_note" && ["sent", "paid", "overdue"].indexOf(inv.status) !== -1
              ? ' · <button type="button" data-inv-credit class="text-xs text-ink-300 hover:text-ink-50">Avoir</button>'
              : "") +
            ' · <button type="button" data-inv-edit class="text-xs text-ink-300 hover:text-ink-50">Modifier</button>' +
            ' · <button type="button" data-inv-del class="text-xs text-rose-400 hover:text-rose-300">×</button>' +
            '</td></tr>';
        }).join("") +
        '</tbody></table></div>';
    }

    biContent.addEventListener("click", async (e) => {
      const tr = e.target.closest("[data-invoice]"); if (!tr) return;
      const id = tr.dataset.invoice;
      if (e.target.closest("[data-inv-pdf]")) downloadInvoicePdf(id);
      else if (e.target.closest("[data-inv-remind]")) remindInvoice(id);
      else if (e.target.closest("[data-inv-credit]")) createCreditNote(id);
      else if (e.target.closest("[data-inv-edit]")) editInvoice(id);
      else if (e.target.closest("[data-inv-del]")) deleteInvoice(id);
    });
    biContent.addEventListener("change", async (e) => {
      const sel = e.target.closest("[data-inv-status]"); if (!sel) return;
      const tr = sel.closest("[data-invoice]"); const id = tr.dataset.invoice;
      const inv = invoicesList.find((x) => x.id === id);
      const prev = inv ? inv.status : null;
      const patch = { status: sel.value };
      if (sel.value === "paid") patch.paid_at = new Date().toISOString();
      try { await api("invoices?id=eq." + encodeURIComponent(id), { method: "PATCH", headers: { Prefer: "return=minimal" }, body: JSON.stringify(patch) });
        if (inv) Object.assign(inv, patch); renderInvoices(); toast("Statut mis à jour ✓");
      } catch (err) { sel.value = prev || "draft"; toast("Échec du changement de statut : " + err.message, "error"); }
    });

    root.querySelector("[data-bi-new]").addEventListener("click", () => editInvoice(null));
    root.querySelector("[data-bi-csv]").addEventListener("click", exportInvoicesCsv);

    async function remindInvoice(id) {
      const inv = invoicesList.find((x) => x.id === id);
      if (!inv) return;
      if (!confirm("Envoyer un rappel de paiement pour " + inv.number + " à « " + ((inv.customer && inv.customer.asso_name) || "ce client") + " » ?")) return;
      try {
        const res = await fn("cockpit-invoice-reminder", { method: "POST", json: { invoice_id: id } });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || "HTTP " + res.status);
        toast("Rappel envoyé ✓ (relance n°" + data.reminder_count + ")");
        loadInvoices();
      } catch (e) { toast("Échec du rappel : " + e.message, "error"); }
    }

    async function createCreditNote(id) {
      const inv = invoicesList.find((x) => x.id === id);
      if (!inv) return;
      if (!confirm("Créer un avoir (note de crédit) pour " + inv.number + " ?\nIl reprendra les mêmes lignes, en brouillon — modifiable avant envoi.")) return;
      try {
        const res = await api("invoice_lines?invoice_id=eq." + encodeURIComponent(id) + "&order=position.asc");
        const lines = await res.json();
        await api("rpc/save_invoice", { method: "POST", body: JSON.stringify({
          p_invoice: {
            id: null, customer_id: inv.customer_id, issue_date: todayISO(), due_date: todayISO(),
            currency: inv.currency, vat_rate: inv.vat_rate, issuer_iban: inv.issuer_iban,
            notes: "Avoir sur la facture " + inv.number, doc_type: "credit_note", credit_for_invoice_id: id,
          },
          p_lines: lines.map((l) => ({ description: l.description, qty: l.qty, unit_price: l.unit_price })),
        })});
        toast("Avoir créé (brouillon) ✓");
        loadInvoices();
      } catch (e) { toast("Échec de la création de l'avoir : " + e.message, "error"); }
    }

    // ----- Rapprochement bancaire (texte libre → factures payées) -----
    let rcMatches = [];
    root.querySelector("[data-bi-reconcile]").addEventListener("click", () => {
      root.querySelector("[data-rc-text]").value = "";
      root.querySelector("[data-rc-results]").innerHTML = '<p class="text-xs text-ink-500">Collez votre relevé puis cliquez « Analyser » : les factures ouvertes dont le numéro ou le montant exact apparaît seront proposées.</p>';
      root.querySelector("[data-rc-apply]").hidden = true;
      openModal("reconcile");
    });
    root.querySelector("[data-rc-analyze]").addEventListener("click", () => {
      const text = root.querySelector("[data-rc-text]").value.toLowerCase();
      if (!text.trim()) return;
      const open = invoicesList.filter((i) => (i.status === "sent" || i.status === "overdue") && i.doc_type !== "credit_note");
      rcMatches = open.map((i) => {
        const numHit = text.indexOf(String(i.number).toLowerCase()) !== -1;
        const amt = (Number(i.total) || 0).toFixed(2);
        const amtHit = text.indexOf(amt) !== -1 || text.indexOf(amt.replace(".", ",")) !== -1;
        return { inv: i, strong: numHit, weak: !numHit && amtHit };
      }).filter((m) => m.strong || m.weak);
      const el = root.querySelector("[data-rc-results]");
      if (!rcMatches.length) {
        el.innerHTML = '<p class="text-xs text-rose-400">Aucune facture ouverte ne correspond (ni numéro, ni montant exact).</p>';
        root.querySelector("[data-rc-apply]").hidden = true;
        return;
      }
      el.innerHTML = rcMatches.map((m, idx) =>
        '<label class="flex items-center gap-2 rounded-lg border border-white/[0.06] bg-white/[0.01] px-3 py-2 text-xs">' +
        '<input type="checkbox" data-rc-check="' + idx + '"' + (m.strong ? " checked" : "") + ' />' +
        '<span class="font-mono text-ink-200">' + esc(m.inv.number) + "</span>" +
        '<span class="text-ink-500">' + esc((m.inv.customer && m.inv.customer.asso_name) || "") + "</span>" +
        '<span class="ml-auto tabular-nums text-ink-50">' + fmtCHF(m.inv.total, m.inv.currency) + "</span>" +
        '<span class="' + (m.strong ? "text-emerald-400" : "text-amber-400") + '">' + (m.strong ? "n° trouvé" : "montant seul") + "</span>" +
        "</label>").join("");
      root.querySelector("[data-rc-apply]").hidden = false;
    });
    root.querySelector("[data-rc-apply]").addEventListener("click", async (e) => {
      const checked = Array.from(root.querySelectorAll("[data-rc-check]:checked")).map((c) => rcMatches[+c.dataset.rcCheck]).filter(Boolean);
      if (!checked.length) { toast("Aucune facture cochée.", "error"); return; }
      e.target.disabled = true;
      let ok = 0;
      for (const m of checked) {
        try {
          await api("invoices?id=eq." + encodeURIComponent(m.inv.id), { method: "PATCH", headers: { Prefer: "return=minimal" }, body: JSON.stringify({ status: "paid", paid_at: new Date().toISOString() }) });
          ok++;
        } catch {}
      }
      e.target.disabled = false;
      closeModals();
      toast(ok + " facture(s) marquée(s) payée(s) ✓" + (ok < checked.length ? " — " + (checked.length - ok) + " échec(s)" : ""));
      loadInvoices();
    });

    function exportInvoicesCsv() {
      if (!invoicesList.length) { toast("Aucune facture à exporter.", "error"); return; }
      const head = "Numéro;Client;Émise;Échéance;Statut;Devise;Sous-total;TVA %;TVA;Total;Payée le";
      const rows = invoicesList.map((i) => [
        i.number, (i.customer && i.customer.asso_name) || "", i.issue_date || "", i.due_date || "", i.status,
        i.currency, i.subtotal, i.vat_rate, i.vat_amount, i.total, i.paid_at ? i.paid_at.slice(0, 10) : "",
      ].map((v) => '"' + String(v ?? "").replace(/"/g, '""') + '"').join(";"));
      const blob = new Blob(["﻿" + head + "\n" + rows.join("\n")], { type: "text/csv;charset=utf-8" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url; a.download = "konclav-factures-" + todayISO() + ".csv";
      document.body.appendChild(a); a.click(); a.remove();
      setTimeout(() => URL.revokeObjectURL(url), 5000);
      toast("Export CSV téléchargé ✓");
    }

    async function downloadInvoicePdf(id) {
      try {
        const res = await fn("cockpit-invoice-pdf", { qs: "id=" + encodeURIComponent(id) });
        if (!res.ok) { const t = await res.text(); toast("PDF échoué : " + t.slice(0, 160), "error"); return; }
        const blob = await res.blob();
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url; a.target = "_blank"; a.rel = "noopener";
        document.body.appendChild(a); a.click(); a.remove();
        setTimeout(() => URL.revokeObjectURL(url), 60_000);
      } catch (e) { toast("Erreur PDF : " + e.message, "error"); }
    }

    async function deleteInvoice(id) {
      const inv = invoicesList.find((x) => x.id === id);
      if (!confirm("Supprimer la facture " + (inv ? inv.number : id) + " ?")) return;
      try { await api("invoices?id=eq." + encodeURIComponent(id), { method: "DELETE", headers: { Prefer: "return=minimal" } }); toast("Facture supprimée."); loadInvoices(); }
      catch (e) { toast("Échec de la suppression : " + e.message, "error"); }
    }

    // ----- Modal facture -----
    const biForm = root.querySelector("[data-bi-form]");
    const biIdInput = root.querySelector("[data-bi-id]");
    const biError = root.querySelector("[data-bi-error]");
    const biTitle = document.getElementById("ck-inv-title");
    const biLinesEl = root.querySelector("[data-bi-lines]");
    let editingInvoiceLines = []; // {description, qty, unit_price}

    function lineRow(line, idx) {
      return '<div class="ck-line" data-line-idx="' + idx + '">' +
        '<input data-l-desc placeholder="Description" value="' + esc(line.description || "") + '" class="ck-input" />' +
        '<input data-l-qty type="number" step="0.01" min="0" value="' + (line.qty != null ? line.qty : 1) + '" class="ck-input" />' +
        '<input data-l-price type="number" step="0.01" min="0" value="' + (line.unit_price != null ? line.unit_price : 0) + '" class="ck-input" />' +
        '<span class="text-right text-xs tabular-nums text-ink-300" data-l-total>0.00</span>' +
        '<button type="button" data-l-rm aria-label="Supprimer la ligne" class="ck-line-rm text-rose-400 hover:text-rose-300">×</button>' +
        '</div>';
    }
    function renderLines() {
      biLinesEl.innerHTML = editingInvoiceLines.map(lineRow).join("");
      recomputeTotals();
    }
    function recomputeTotals() {
      let subtotal = 0;
      biLinesEl.querySelectorAll("[data-line-idx]").forEach((row) => {
        const i = +row.dataset.lineIdx;
        const qty = +row.querySelector("[data-l-qty]").value || 0;
        const price = +row.querySelector("[data-l-price]").value || 0;
        const lt = Math.round(qty * price * 100) / 100;
        editingInvoiceLines[i].qty = qty;
        editingInvoiceLines[i].unit_price = price;
        editingInvoiceLines[i].line_total = lt;
        row.querySelector("[data-l-total]").textContent = lt.toFixed(2);
        subtotal += lt;
      });
      const vatRate = +biForm.querySelector('[data-bi-field="vat_rate"]').value || 0;
      const vat = Math.round(subtotal * vatRate) / 100;
      const total = Math.round((subtotal + vat) * 100) / 100;
      const cur = biForm.querySelector('[data-bi-field="currency"]').value || "CHF";
      root.querySelector("[data-bi-subtotal]").textContent = fmtCHF(subtotal, cur);
      root.querySelector("[data-bi-vat-label]").textContent = "TVA " + vatRate + "%";
      root.querySelector("[data-bi-vat]").textContent = fmtCHF(vat, cur);
      root.querySelector("[data-bi-total]").textContent = fmtCHF(total, cur);
    }
    biLinesEl.addEventListener("input", recomputeTotals);
    biLinesEl.addEventListener("click", (e) => {
      const rm = e.target.closest("[data-l-rm]"); if (!rm) return;
      const idx = +rm.closest("[data-line-idx]").dataset.lineIdx;
      editingInvoiceLines.splice(idx, 1); renderLines();
    });
    biForm.addEventListener("input", (e) => {
      if (e.target.dataset.biField === "vat_rate" || e.target.dataset.biField === "currency") recomputeTotals();
    });
    root.querySelector("[data-bi-add-line]").addEventListener("click", () => {
      editingInvoiceLines.push({ description: "", qty: 1, unit_price: 0 });
      renderLines();
    });

    async function editInvoice(id) {
      // Reset
      biIdInput.value = "";
      biError.hidden = true;
      biTitle.textContent = id ? "Modifier la facture" : "Nouvelle facture";
      // Populate clients dropdown
      if (!customers.length) { try { const r = await api("customers?select=id,asso_name&order=asso_name.asc"); customers = await r.json(); } catch {} }
      const sel = biForm.querySelector('[data-bi-field="customer_id"]');
      sel.innerHTML = '<option value="">— Sélectionner —</option>' + customers.map((c) => '<option value="' + esc(c.id) + '">' + esc(c.asso_name) + '</option>').join("");
      // Defaults
      biForm.querySelector('[data-bi-field="issue_date"]').value = todayISO();
      biForm.querySelector('[data-bi-field="due_date"]').value = addDaysISO(todayISO(), 30);
      biForm.querySelector('[data-bi-field="vat_rate"]').value = 0;
      biForm.querySelector('[data-bi-field="currency"]').value = "CHF";
      biForm.querySelector('[data-bi-field="notes"]').value = "";
      biForm.querySelector('[data-bi-field="issuer_iban"]').value = "";
      editingInvoiceLines = [{ description: "Abonnement Konclav", qty: 1, unit_price: 0 }];
      if (id) {
        biIdInput.value = id;
        try {
          const [iRes, lRes] = await Promise.all([
            api("invoices?id=eq." + encodeURIComponent(id) + "&select=*"),
            api("invoice_lines?invoice_id=eq." + encodeURIComponent(id) + "&order=position.asc"),
          ]);
          const inv = (await iRes.json())[0];
          const lines = await lRes.json();
          sel.value = inv.customer_id || "";
          ["issue_date", "due_date", "vat_rate", "currency", "notes", "issuer_iban"].forEach((k) => {
            const el = biForm.querySelector('[data-bi-field="' + k + '"]'); if (el && inv[k] != null) el.value = inv[k];
          });
          editingInvoiceLines = lines.length ? lines.map((l) => ({ description: l.description, qty: l.qty, unit_price: l.unit_price })) : editingInvoiceLines;
        } catch (e) { biError.textContent = e.message; biError.hidden = false; }
      }
      renderLines();
      openModal("invoice");
    }

    biForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      biError.hidden = true;
      const submit = root.querySelector("[data-bi-submit]");
      const data = {
        customer_id: biForm.querySelector('[data-bi-field="customer_id"]').value || null,
        issue_date: biForm.querySelector('[data-bi-field="issue_date"]').value || todayISO(),
        due_date: biForm.querySelector('[data-bi-field="due_date"]').value || addDaysISO(todayISO(), 30),
        currency: biForm.querySelector('[data-bi-field="currency"]').value || "CHF",
        vat_rate: +biForm.querySelector('[data-bi-field="vat_rate"]').value || 0,
        notes: biForm.querySelector('[data-bi-field="notes"]').value.trim() || null,
        issuer_iban: biForm.querySelector('[data-bi-field="issuer_iban"]').value.replace(/\s/g, "") || null,
      };
      if (!data.customer_id) { biError.textContent = "Client requis."; biError.hidden = false; return; }
      const cleanLines = editingInvoiceLines.filter((l) => l.description && +l.qty > 0);
      if (!cleanLines.length) { biError.textContent = "Ajoutez au moins une ligne."; biError.hidden = false; return; }
      if (cleanLines.some((l) => +l.unit_price < 0)) { biError.textContent = "Les prix ne peuvent pas être négatifs."; biError.hidden = false; return; }

      submit.disabled = true;
      try {
        const id = biIdInput.value;
        // RPC transactionnelle : upsert facture + remplacement des lignes en un seul aller-retour
        await api("rpc/save_invoice", {
          method: "POST",
          body: JSON.stringify({
            p_invoice: Object.assign({ id: id || null }, data),
            p_lines: cleanLines.map((l) => ({ description: l.description, qty: l.qty, unit_price: l.unit_price })),
          }),
        });
        closeModals();
        toast(id ? "Facture mise à jour ✓" : "Facture créée ✓");
        await loadInvoices();
      } catch (err) { biError.textContent = err.message || "Erreur."; biError.hidden = false; }
      finally { submit.disabled = false; }
    });

    // =========================================================
    // ============ RECHERCHE GLOBALE (Cmd+K) ===================
    // =========================================================
    const qInput = root.querySelector("[data-ck-q]");
    const qResults = root.querySelector("[data-ck-results]");
    let qItems = [];
    let qActive = 0;
    const qBtnClass = (on) => "flex w-full items-center gap-3 rounded-lg px-3 py-2.5 text-left text-sm " + (on ? "bg-accent-500/15 text-ink-50" : "text-ink-300 hover:bg-white/[0.04]");
    async function openSearch() {
      if (appView.hidden) return;
      openModal("cmdk");
      qInput.value = "";
      renderSearch("");
      qInput.focus();
      const jobs = [];
      if (!leads.length) jobs.push(api("leads?select=*&order=created_at.desc").then((r) => r.json()).then((d) => { leads = d; }).catch(() => {}));
      if (!customers.length) jobs.push(api("customers?select=*&order=asso_name.asc").then((r) => r.json()).then((d) => { customers = d; }).catch(() => {}));
      if (!invoicesList.length) jobs.push(api("invoices?select=*,customer:customers(asso_name,contact_name)&order=issue_date.desc").then((r) => r.json()).then((d) => { invoicesList = d; }).catch(() => {}));
      if (jobs.length) { await Promise.all(jobs); renderSearch(qInput.value); }
    }
    function searchPool() {
      const pool = [];
      leads.forEach((l) => pool.push({
        kind: "Lead", label: l.asso_name, sub: (l.first_name || "") + " " + (l.last_name || "") + " · " + l.email,
        hay: (l.asso_name + " " + l.first_name + " " + l.last_name + " " + l.email + " " + (l.canton || "")).toLowerCase(),
        go: () => { closeModals(); focusLeadId = l.id; switchTab("leads"); },
      }));
      customers.forEach((c) => pool.push({
        kind: "Client", label: c.asso_name, sub: (c.contact_name || "") + " · " + (c.contact_email || ""),
        hay: (c.asso_name + " " + (c.contact_name || "") + " " + (c.contact_email || "")).toLowerCase(),
        go: () => { closeModals(); switchTab("billing"); switchSubtab("customers"); },
      }));
      invoicesList.forEach((i) => pool.push({
        kind: "Facture", label: i.number, sub: ((i.customer && i.customer.asso_name) || "—") + " · " + fmtCHF(i.total, i.currency),
        hay: (i.number + " " + ((i.customer && i.customer.asso_name) || "")).toLowerCase(),
        go: () => { closeModals(); switchTab("billing"); switchSubtab("invoices"); editInvoice(i.id); },
      }));
      return pool;
    }
    function renderSearch(q) {
      const needle = q.trim().toLowerCase();
      qItems = needle ? searchPool().filter((it) => it.hay.indexOf(needle) !== -1).slice(0, 8) : [];
      qActive = 0;
      qResults.innerHTML = qItems.length
        ? qItems.map((it, i) =>
            '<li><button type="button" data-q-i="' + i + '" class="' + qBtnClass(i === qActive) + '">' +
            '<span class="shrink-0 rounded-md border border-white/10 bg-white/[0.03] px-1.5 py-0.5 text-[10px] uppercase tracking-wide text-ink-500">' + it.kind + "</span>" +
            '<span class="min-w-0 flex-1"><span class="block truncate font-medium">' + esc(it.label) + '</span><span class="block truncate text-xs text-ink-500">' + esc(it.sub) + "</span></span>" +
            "</button></li>").join("")
        : '<li class="px-3 py-6 text-center text-sm text-ink-500">' + (needle ? "Aucun résultat." : "Tapez pour chercher dans les leads, clients et factures.") + "</li>";
    }
    qInput.addEventListener("input", () => renderSearch(qInput.value));
    qInput.addEventListener("keydown", (e) => {
      if (e.key === "ArrowDown") { e.preventDefault(); qActive = Math.min(qActive + 1, qItems.length - 1); qHighlight(); }
      else if (e.key === "ArrowUp") { e.preventDefault(); qActive = Math.max(qActive - 1, 0); qHighlight(); }
      else if (e.key === "Enter") { e.preventDefault(); if (qItems[qActive]) qItems[qActive].go(); }
    });
    function qHighlight() {
      qResults.querySelectorAll("[data-q-i]").forEach((b, i) => { b.className = qBtnClass(i === qActive); });
    }
    qResults.addEventListener("click", (e) => {
      const b = e.target.closest("[data-q-i]");
      if (b && qItems[+b.dataset.qI]) qItems[+b.dataset.qI].go();
    });
    searchBtn.addEventListener("click", openSearch);
    document.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") { e.preventDefault(); openSearch(); }
    });

    // =========================================================
    // ============ AUTH FORMS ==================================
    // =========================================================
    loginForm.addEventListener("submit", async (e) => {
      e.preventDefault(); loginBtn.disabled = true; loginError.hidden = true;
      try {
        const email = document.getElementById("ck-email").value.trim();
        const password = document.getElementById("ck-password").value;
        const data = await authRequest("password", { email, password });
        if (jwtEmail(data.access_token) !== ADMIN) throw new Error("Ce compte n'a pas accès au cockpit.");
        store.set(data.access_token, data.refresh_token);
        await enter();
      } catch (err) { loginError.textContent = err.message || "Échec de connexion."; loginError.hidden = false; }
      finally { loginBtn.disabled = false; }
    });

    changeForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      const pw = document.getElementById("ck-newpw").value;
      const pw2 = document.getElementById("ck-newpw2").value;
      changeError.hidden = true;
      if (pw.length < 12) { changeError.textContent = "12 caractères minimum."; changeError.hidden = false; return; }
      if (pw !== pw2) { changeError.textContent = "Les deux mots de passe ne correspondent pas."; changeError.hidden = false; return; }
      changeBtn.disabled = true;
      try {
        const res = await fetch(U + "/auth/v1/user", {
          method: "PUT", headers: { apikey: K, Authorization: "Bearer " + store.at, "Content-Type": "application/json" },
          body: JSON.stringify({ password: pw, data: { temp_password: false } }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error_description || data.msg || "Échec du changement.");
        await showApp();
      } catch (err) { changeError.textContent = err.message || "Échec du changement."; changeError.hidden = false; }
      finally { changeBtn.disabled = false; }
    });

    mfaForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      const btn = root.querySelector("[data-ck-mfa-btn]");
      const code = document.getElementById("ck-mfa-code").value.trim();
      btn.disabled = true; mfaError.hidden = true;
      try {
        await mfaVerify(mfaFactorId, code);
        mfaView.hidden = true;
        await enter();
      } catch (err) { mfaError.textContent = err.message || "Code invalide."; mfaError.hidden = false; }
      finally { btn.disabled = false; }
    });

    // Modal de gestion 2FA : enrôlement (QR + activation) ou désactivation
    btn2fa.addEventListener("click", openMfaSettings);
    async function openMfaSettings() {
      openModal("mfa");
      mfaBody.innerHTML = '<p class="text-ink-500">Chargement…</p>';
      try {
        const user = await fetchUser();
        const factors = (user && user.factors) || [];
        const verified = factors.filter((f) => f.status === "verified");
        if (verified.length) { renderMfaActive(verified[0]); return; }
        for (const f of factors) { try { await mfaRequest("/" + f.id, { method: "DELETE" }); } catch {} }
        const enr = await mfaRequest("", { body: { factor_type: "totp", friendly_name: "Cockpit Konclav" } });
        renderMfaEnroll(enr);
      } catch (err) {
        mfaBody.innerHTML = '<p class="text-rose-400">' + esc(err.message || "Erreur 2FA.") + '</p>';
      }
    }
    function renderMfaActive(factor) {
      mfaBody.innerHTML =
        '<p class="flex items-center gap-2 text-emerald-400"><span class="h-2 w-2 rounded-full bg-emerald-400"></span>2FA actif sur ce compte.</p>' +
        '<p class="mt-3 text-xs text-ink-500">Chaque connexion exige un code de votre app d\'authentification. La base refuse toute session non vérifiée, même avec le bon mot de passe.</p>' +
        '<div class="mt-5 flex justify-end">' +
        '<button type="button" data-mfa-disable="' + esc(factor.id) + '" class="rounded-lg border border-rose-400/30 px-4 py-2 text-xs font-medium text-rose-400 hover:border-rose-400/60">Désactiver le 2FA</button>' +
        '</div>';
    }
    function renderMfaEnroll(enr) {
      const qr = (enr.totp && enr.totp.qr_code) || "";
      const qrHtml = qr.indexOf("data:") === 0
        ? '<img src="' + qr + '" alt="QR code 2FA" class="h-44 w-44" />'
        : '<div class="h-44 w-44 [&>svg]:h-full [&>svg]:w-full" role="img" aria-label="QR code 2FA">' + qr + '</div>';
      mfaBody.innerHTML =
        '<p>Scannez ce QR avec une app d\'authentification (Google Authenticator, Aegis, 1Password…), puis entrez le code à 6 chiffres pour activer.</p>' +
        '<div class="mt-4 flex justify-center"><div class="rounded-xl bg-white p-3">' + qrHtml + '</div></div>' +
        '<p class="mt-3 break-all text-center font-mono text-[11px] text-ink-500">' + esc((enr.totp && enr.totp.secret) || "") + '</p>' +
        '<form data-mfa-activate-form class="mt-4 flex gap-2">' +
        '<input data-mfa-code inputmode="numeric" pattern="\\d{6}" maxlength="6" required placeholder="000000" autocomplete="one-time-code" class="ck-input text-center tracking-[0.3em] tabular-nums" />' +
        '<button type="submit" class="shrink-0 rounded-lg bg-accent-500 px-4 py-2 text-sm font-semibold text-white hover:bg-accent-400 disabled:opacity-60">Activer</button>' +
        '</form>' +
        '<p data-mfa-enroll-error role="alert" hidden class="mt-2 text-xs text-rose-400"></p>' +
        '<p class="mt-4 text-xs text-ink-500">⚠ Conservez l\'accès à votre app : sans elle, le déblocage passe par le dashboard Supabase (Authentication → Users → supprimer le facteur).</p>';
      mfaBody.dataset.enrollId = enr.id;
    }
    mfaBody.addEventListener("click", async (e) => {
      const dis = e.target.closest("[data-mfa-disable]");
      if (!dis) return;
      if (!confirm("Désactiver le 2FA ? Le mot de passe seul suffira à nouveau.")) return;
      dis.disabled = true;
      try { await mfaRequest("/" + dis.dataset.mfaDisable, { method: "DELETE" }); toast("2FA désactivé."); closeModals(); }
      catch (err) { toast("Échec : " + err.message, "error"); dis.disabled = false; }
    });
    mfaBody.addEventListener("submit", async (e) => {
      const form = e.target.closest("[data-mfa-activate-form]");
      if (!form) return;
      e.preventDefault();
      const errEl = mfaBody.querySelector("[data-mfa-enroll-error]");
      const btn = form.querySelector("button");
      btn.disabled = true; errEl.hidden = true;
      try {
        await mfaVerify(mfaBody.dataset.enrollId, mfaBody.querySelector("[data-mfa-code]").value.trim());
        toast("2FA activé ✓ — il sera demandé à chaque connexion.");
        closeModals();
      } catch (err) { errEl.textContent = err.message || "Code invalide."; errEl.hidden = false; }
      finally { btn.disabled = false; }
    });

    logoutBtn.addEventListener("click", showLogin);

    // ---- Boot ----
    (async () => {
      if (store.at && jwtEmail(store.at) === ADMIN) { await enter(); return; }
      if (await refreshSession()) { if (jwtEmail(store.at) === ADMIN) { await enter(); return; } }
      showLogin();
