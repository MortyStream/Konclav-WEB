---
import Layout from "../layouts/Layout.astro";
import Logo from "../components/Logo.astro";
// Cockpit admin — page cachée (noindex, hors sitemap, aucun lien public).
// Auth Supabase + RLS : la base ne répond qu'au compte contact@konclav.ch.
// Trois modules : Inscriptions, Audience (analytics interne), Facturation (clients + QR-bills).
const SUPABASE_URL = "https://ehbdngidjrkhfrprfgqg.supabase.co";
const PUBLISHABLE_KEY = "sb_publishable_VALB2_pMZ2GjMNP3mmyChg_y-vuitny";
const ADMIN_EMAIL = "contact@konclav.ch";
---

<Layout title="Cockpit — Konclav" description="Espace d'administration Konclav." noindex={true}>
  <main
    id="main"
    class="mx-auto min-h-dvh w-full max-w-6xl px-6 pb-24 pt-10"
    data-cockpit
    data-url={SUPABASE_URL}
    data-key={PUBLISHABLE_KEY}
    data-admin={ADMIN_EMAIL}
  >
    <!-- Header -->
    <header class="flex items-center justify-between border-b border-white/[0.06] pb-6">
      <a href="/" class="flex items-center gap-2 text-base font-semibold tracking-tight text-ink-50">
        <Logo class="h-7 w-7" />
        Konclav <span class="rounded-md border border-accent-500/40 bg-accent-500/10 px-2 py-0.5 text-[11px] font-medium text-accent-300">Cockpit</span>
      </a>
      <div class="flex items-center gap-2">
        <button
          type="button"
          data-ck-search
          hidden
          class="rounded-lg border border-white/10 bg-white/[0.02] px-4 py-2 text-xs font-medium text-ink-400 transition-colors hover:border-white/20 hover:text-ink-50"
        >
          Rechercher <kbd class="ml-1 rounded border border-white/10 bg-white/[0.04] px-1 text-[10px]">⌘K</kbd>
        </button>
        <button
          type="button"
          data-ck-2fa
          hidden
          class="rounded-lg border border-white/10 bg-white/[0.02] px-4 py-2 text-xs font-medium text-ink-400 transition-colors hover:border-white/20 hover:text-ink-50"
        >
          2FA
        </button>
        <button
          type="button"
          data-ck-logout
          hidden
          class="rounded-lg border border-white/10 bg-white/[0.02] px-4 py-2 text-xs font-medium text-ink-400 transition-colors hover:border-white/20 hover:text-ink-50"
        >
          Se déconnecter
        </button>
      </div>
    </header>

    <!-- ===== LOGIN ===== -->
    <section data-ck-login class="mx-auto mt-20 max-w-sm">
      <h1 class="text-center text-2xl font-semibold tracking-tight text-ink-50">Espace admin</h1>
      <p class="mt-2 text-center text-sm text-ink-400">Réservé à l'exploitant de Konclav.</p>
      <form data-ck-login-form class="mt-8 space-y-4">
        <div>
          <label for="ck-email" class="mb-2 block text-sm font-medium text-ink-50">Email</label>
          <input
            id="ck-email"
            type="email"
            autocomplete="username"
            value={ADMIN_EMAIL}
            required
            class="w-full rounded-xl border border-white/10 bg-white/[0.03] px-4 py-3 text-sm text-ink-50 placeholder:text-ink-500 focus:border-accent-500/50 focus:outline-none focus:ring-2 focus:ring-accent-500/20"
          />
        </div>
        <div>
          <label for="ck-password" class="mb-2 block text-sm font-medium text-ink-50">Mot de passe</label>
          <input
            id="ck-password"
            type="password"
            autocomplete="current-password"
            required
            class="w-full rounded-xl border border-white/10 bg-white/[0.03] px-4 py-3 text-sm text-ink-50 focus:border-accent-500/50 focus:outline-none focus:ring-2 focus:ring-accent-500/20"
          />
        </div>
        <button
          type="submit"
          data-ck-login-btn
          class="cta-shimmer w-full rounded-xl bg-accent-500 px-5 py-3 text-sm font-semibold text-white shadow-[var(--shadow-cta)] transition-colors hover:bg-accent-400 disabled:cursor-not-allowed disabled:opacity-60"
        >
          Se connecter
        </button>
        <p data-ck-login-error role="alert" hidden class="text-center text-sm text-rose-400"></p>
      </form>
    </section>

    <!-- ===== CHANGEMENT DE MOT DE PASSE FORCÉ (compte créé avec mdp temporaire) ===== -->
    <section data-ck-change hidden class="mx-auto mt-20 max-w-sm">
      <h1 class="text-center text-2xl font-semibold tracking-tight text-ink-50">Nouveau mot de passe</h1>
      <p class="mt-2 text-center text-sm text-ink-400">
        Votre mot de passe actuel est temporaire. Choisissez-en un définitif —
        il n'est connu que de vous.
      </p>
      <form data-ck-change-form class="mt-8 space-y-4">
        <div>
          <label for="ck-newpw" class="mb-2 block text-sm font-medium text-ink-50">Nouveau mot de passe</label>
          <input
            id="ck-newpw"
            type="password"
            autocomplete="new-password"
            minlength="12"
            required
            class="w-full rounded-xl border border-white/10 bg-white/[0.03] px-4 py-3 text-sm text-ink-50 focus:border-accent-500/50 focus:outline-none focus:ring-2 focus:ring-accent-500/20"
          />
          <p class="mt-1.5 text-xs text-ink-500">12 caractères minimum.</p>
        </div>
        <div>
          <label for="ck-newpw2" class="mb-2 block text-sm font-medium text-ink-50">Confirmez-le</label>
          <input
            id="ck-newpw2"
            type="password"
            autocomplete="new-password"
            minlength="12"
            required
            class="w-full rounded-xl border border-white/10 bg-white/[0.03] px-4 py-3 text-sm text-ink-50 focus:border-accent-500/50 focus:outline-none focus:ring-2 focus:ring-accent-500/20"
          />
        </div>
        <button
          type="submit"
          data-ck-change-btn
          class="cta-shimmer w-full rounded-xl bg-accent-500 px-5 py-3 text-sm font-semibold text-white shadow-[var(--shadow-cta)] transition-colors hover:bg-accent-400 disabled:cursor-not-allowed disabled:opacity-60"
        >
          Enregistrer et entrer
        </button>
        <p data-ck-change-error role="alert" hidden class="text-center text-sm text-rose-400"></p>
      </form>
    </section>

    <!-- ===== VÉRIFICATION 2FA (connexion) ===== -->
    <section data-ck-mfa hidden class="mx-auto mt-20 max-w-sm">
      <h1 class="text-center text-2xl font-semibold tracking-tight text-ink-50">Vérification 2FA</h1>
      <p class="mt-2 text-center text-sm text-ink-400">Entrez le code à 6 chiffres de votre app d'authentification.</p>
      <form data-ck-mfa-form class="mt-8 space-y-4">
        <label for="ck-mfa-code" class="sr-only">Code 2FA</label>
        <input
          id="ck-mfa-code"
          inputmode="numeric"
          autocomplete="one-time-code"
          pattern="\d{6}"
          maxlength="6"
          required
          placeholder="••••••"
          class="w-full rounded-xl border border-white/10 bg-white/[0.03] px-4 py-3 text-center text-2xl tracking-[0.4em] tabular-nums text-ink-50 placeholder:text-ink-500 focus:border-accent-500/50 focus:outline-none focus:ring-2 focus:ring-accent-500/20"
        />
        <button
          type="submit"
          data-ck-mfa-btn
          class="cta-shimmer w-full rounded-xl bg-accent-500 px-5 py-3 text-sm font-semibold text-white shadow-[var(--shadow-cta)] transition-colors hover:bg-accent-400 disabled:cursor-not-allowed disabled:opacity-60"
        >
          Vérifier
        </button>
        <p data-ck-mfa-error role="alert" hidden class="text-center text-sm text-rose-400"></p>
      </form>
    </section>

    <!-- ===== APP ===== -->
    <section data-ck-app hidden>
      <!-- Tabs principaux -->
      <nav class="mt-8 flex flex-wrap gap-1 border-b border-white/[0.06]" role="tablist" aria-label="Sections du cockpit">
        <button type="button" data-tab="overview" role="tab" aria-selected="true"
          class="ck-tab relative -mb-px border-b-2 border-accent-500 px-4 py-3 text-sm font-medium text-ink-50">
          Aperçu
        </button>
        <button type="button" data-tab="leads" role="tab" aria-selected="false"
          class="ck-tab relative -mb-px border-b-2 border-transparent px-4 py-3 text-sm font-medium text-ink-400 hover:text-ink-50">
          Inscriptions
        </button>
        <button type="button" data-tab="orgs" role="tab" aria-selected="false"
          class="ck-tab relative -mb-px border-b-2 border-transparent px-4 py-3 text-sm font-medium text-ink-400 hover:text-ink-50">
          Assos
        </button>
        <button type="button" data-tab="audience" role="tab" aria-selected="false"
          class="ck-tab relative -mb-px border-b-2 border-transparent px-4 py-3 text-sm font-medium text-ink-400 hover:text-ink-50">
          Audience
        </button>
        <button type="button" data-tab="billing" role="tab" aria-selected="false"
          class="ck-tab relative -mb-px border-b-2 border-transparent px-4 py-3 text-sm font-medium text-ink-400 hover:text-ink-50">
          Facturation
        </button>
      </nav>

      <!-- ===== PANEL : APERÇU ===== -->
      <div data-panel="overview" role="tabpanel">
        <div data-ov-content aria-live="polite">
          <p class="mt-12 text-center text-sm text-ink-500">Chargement…</p>
        </div>
      </div>

      <!-- ===== PANEL : LEADS ===== -->
      <div data-panel="leads" role="tabpanel" hidden>
        <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-4" data-ck-stats></div>
        <div class="mt-8 flex flex-wrap items-center justify-between gap-3">
          <div class="flex flex-wrap items-center gap-2" data-ck-filters role="group" aria-label="Filtrer par statut"></div>
          <div class="flex items-center gap-1" role="group" aria-label="Vue">
            <button type="button" data-view="list" class="ck-pill ck-pill-on">Liste</button>
            <button type="button" data-view="kanban" class="ck-pill">Kanban</button>
            <button type="button" data-ck-broadcast class="ck-pill ml-2">📣 Email groupé</button>
          </div>
        </div>
        <div class="mt-6 space-y-3" data-ck-list aria-live="polite"></div>
        <p data-ck-empty hidden class="mt-12 text-center text-sm text-ink-500">Aucune demande pour ce filtre.</p>
      </div>

      <!-- ===== PANEL : ASSOS ===== -->
      <div data-panel="orgs" role="tabpanel" hidden>
        <div class="mt-8 flex flex-wrap items-center justify-between gap-3">
          <h2 class="text-xl font-semibold tracking-tight text-ink-50">Associations provisionnées</h2>
          <button type="button" data-og-refresh class="ck-pill">Rafraîchir</button>
        </div>
        <div data-og-content aria-live="polite">
          <p class="mt-12 text-center text-sm text-ink-500">Chargement…</p>
        </div>
      </div>

      <!-- ===== PANEL : AUDIENCE ===== -->
      <div data-panel="audience" role="tabpanel" hidden>
        <div class="mt-8 flex flex-wrap items-center justify-between gap-3">
          <h2 class="text-xl font-semibold tracking-tight text-ink-50">Audience du site</h2>
          <div class="flex gap-1" data-au-periods role="group" aria-label="Période">
            <button type="button" data-period="24h" class="ck-pill">24h</button>
            <button type="button" data-period="7d"  class="ck-pill ck-pill-on">7 j</button>
            <button type="button" data-period="30d" class="ck-pill">30 j</button>
            <button type="button" data-period="90d" class="ck-pill">90 j</button>
          </div>
        </div>
        <div data-au-content aria-live="polite">
          <p class="mt-12 text-center text-sm text-ink-500">Chargement…</p>
        </div>
      </div>

      <!-- ===== PANEL : BILLING ===== -->
      <div data-panel="billing" role="tabpanel" hidden>
        <!-- Sous-tabs -->
        <nav class="mt-6 flex flex-wrap gap-1" role="tablist" aria-label="Sous-sections facturation">
          <button type="button" data-subtab="invoices" role="tab" aria-selected="true"
            class="ck-subtab ck-subtab-on">Factures</button>
          <button type="button" data-subtab="subscriptions" role="tab" aria-selected="false"
            class="ck-subtab">Abonnements</button>
          <button type="button" data-subtab="customers" role="tab" aria-selected="false"
            class="ck-subtab">Clients</button>
        </nav>

        <!-- Sous-panel factures -->
        <div data-subpanel="invoices">
          <div class="mt-6 flex flex-wrap items-center justify-between gap-3">
            <h2 class="text-xl font-semibold tracking-tight text-ink-50">Factures</h2>
            <div class="flex gap-2">
              <button type="button" data-bi-reconcile
                class="rounded-xl border border-white/10 bg-white/[0.02] px-4 py-2 text-sm font-medium text-ink-300 transition-colors hover:border-white/20 hover:text-ink-50">
                Rapprocher
              </button>
              <button type="button" data-bi-csv
                class="rounded-xl border border-white/10 bg-white/[0.02] px-4 py-2 text-sm font-medium text-ink-300 transition-colors hover:border-white/20 hover:text-ink-50">
                Exporter CSV
              </button>
              <button type="button" data-bi-new
                class="rounded-xl bg-accent-500 px-4 py-2 text-sm font-semibold text-white shadow-[var(--shadow-cta)] transition-colors hover:bg-accent-400">
                + Nouvelle facture
              </button>
            </div>
          </div>
          <div data-bi-content aria-live="polite">
            <p class="mt-12 text-center text-sm text-ink-500">Chargement…</p>
          </div>
        </div>

        <!-- Sous-panel clients -->
        <div data-subpanel="customers" hidden>
          <div class="mt-6 flex flex-wrap items-center justify-between gap-3">
            <h2 class="text-xl font-semibold tracking-tight text-ink-50">Clients</h2>
            <button type="button" data-bc-new
              class="rounded-xl bg-accent-500 px-4 py-2 text-sm font-semibold text-white shadow-[var(--shadow-cta)] transition-colors hover:bg-accent-400">
              + Nouveau client
            </button>
          </div>
          <div data-bc-content aria-live="polite">
            <p class="mt-12 text-center text-sm text-ink-500">Chargement…</p>
          </div>
        </div>

        <!-- Sous-panel abonnements -->
        <div data-subpanel="subscriptions" hidden>
          <div class="mt-6 flex flex-wrap items-center justify-between gap-3">
            <h2 class="text-xl font-semibold tracking-tight text-ink-50">Abonnements</h2>
            <button type="button" data-bs-new
              class="rounded-xl bg-accent-500 px-4 py-2 text-sm font-semibold text-white shadow-[var(--shadow-cta)] transition-colors hover:bg-accent-400">
              + Nouvel abonnement
            </button>
          </div>
          <p class="mt-2 text-xs text-ink-500">Les factures d'abonnement se génèrent automatiquement en brouillon à chaque échéance — chaque nuit (6h) et à l'ouverture de l'onglet Factures.</p>
          <div data-bs-content aria-live="polite">
            <p class="mt-12 text-center text-sm text-ink-500">Chargement…</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== MODAL : édition client ===== -->
    <div data-modal="customer" hidden class="ck-modal" role="dialog" aria-modal="true" aria-labelledby="ck-cust-title">
      <div class="ck-modal-back"></div>
      <div class="ck-modal-card">
        <div class="flex items-center justify-between border-b border-white/[0.06] px-5 py-4">
          <h3 id="ck-cust-title" class="text-base font-semibold text-ink-50">Nouveau client</h3>
          <button type="button" data-modal-close class="text-ink-400 hover:text-ink-50" aria-label="Fermer">✕</button>
        </div>
        <form data-bc-form class="space-y-3 px-5 py-5">
          <input type="hidden" data-bc-id />
          <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
            <label class="block text-xs">
              <span class="mb-1 block font-medium text-ink-400">Nom de l'association *</span>
              <input data-bc-field="asso_name" required class="ck-input" />
            </label>
            <label class="block text-xs">
              <span class="mb-1 block font-medium text-ink-400">Forme juridique</span>
              <input data-bc-field="vat_number" class="ck-input" placeholder="N° TVA (si applicable)" />
            </label>
          </div>
          <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
            <label class="block text-xs">
              <span class="mb-1 block font-medium text-ink-400">Contact (nom complet) *</span>
              <input data-bc-field="contact_name" required class="ck-input" />
            </label>
            <label class="block text-xs">
              <span class="mb-1 block font-medium text-ink-400">Email *</span>
              <input data-bc-field="contact_email" type="email" required class="ck-input" />
            </label>
          </div>
          <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
            <label class="block text-xs sm:col-span-3">
              <span class="mb-1 block font-medium text-ink-400">Adresse (rue + n°)</span>
              <input data-bc-field="address_line" class="ck-input" />
            </label>
            <label class="block text-xs">
              <span class="mb-1 block font-medium text-ink-400">NPA</span>
              <input data-bc-field="postal_code" class="ck-input" />
            </label>
            <label class="block text-xs sm:col-span-2">
              <span class="mb-1 block font-medium text-ink-400">Localité</span>
              <input data-bc-field="city" class="ck-input" />
            </label>
          </div>
          <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
            <label class="block text-xs">
              <span class="mb-1 block font-medium text-ink-400">Pays</span>
              <input data-bc-field="country" value="CH" maxlength="2" class="ck-input" />
            </label>
            <label class="block text-xs">
              <span class="mb-1 block font-medium text-ink-400">Téléphone</span>
              <input data-bc-field="phone" class="ck-input" />
            </label>
          </div>
          <label class="block text-xs">
            <span class="mb-1 block font-medium text-ink-400">Notes internes</span>
            <textarea data-bc-field="notes" rows="2" class="ck-input"></textarea>
          </label>
          <p data-bc-error role="alert" hidden class="text-sm text-rose-400"></p>
          <div class="flex justify-end gap-2 pt-2">
            <button type="button" data-modal-close class="rounded-lg border border-white/10 px-4 py-2 text-sm text-ink-300 hover:border-white/20 hover:text-ink-50">Annuler</button>
            <button type="submit" data-bc-submit class="rounded-lg bg-accent-500 px-4 py-2 text-sm font-semibold text-white hover:bg-accent-400 disabled:cursor-not-allowed disabled:opacity-60">Enregistrer</button>
          </div>
        </form>
      </div>
    </div>

    <!-- ===== MODAL : édition facture ===== -->
    <div data-modal="invoice" hidden class="ck-modal" role="dialog" aria-modal="true" aria-labelledby="ck-inv-title">
      <div class="ck-modal-back"></div>
      <div class="ck-modal-card ck-modal-wide">
        <div class="flex items-center justify-between border-b border-white/[0.06] px-5 py-4">
          <h3 id="ck-inv-title" class="text-base font-semibold text-ink-50">Nouvelle facture</h3>
          <button type="button" data-modal-close class="text-ink-400 hover:text-ink-50" aria-label="Fermer">✕</button>
        </div>
        <form data-bi-form class="space-y-4 px-5 py-5">
          <input type="hidden" data-bi-id />
          <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
            <label class="block text-xs">
              <span class="mb-1 block font-medium text-ink-400">Client *</span>
              <select data-bi-field="customer_id" required class="ck-input"></select>
            </label>
            <label class="block text-xs">
              <span class="mb-1 block font-medium text-ink-400">Devise</span>
              <select data-bi-field="currency" class="ck-input">
                <option value="CHF">CHF</option>
                <option value="EUR">EUR</option>
              </select>
            </label>
          </div>
          <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
            <label class="block text-xs">
              <span class="mb-1 block font-medium text-ink-400">Date d'émission</span>
              <input data-bi-field="issue_date" type="date" class="ck-input" />
            </label>
            <label class="block text-xs">
              <span class="mb-1 block font-medium text-ink-400">Échéance</span>
              <input data-bi-field="due_date" type="date" class="ck-input" />
            </label>
            <label class="block text-xs">
              <span class="mb-1 block font-medium text-ink-400">TVA (%) — 0 si non assujetti</span>
              <input data-bi-field="vat_rate" type="number" min="0" max="100" step="0.01" value="0" class="ck-input" />
            </label>
          </div>
          <label class="block text-xs">
            <span class="mb-1 block font-medium text-ink-400">IBAN émetteur (pour le QR de paiement)</span>
            <input data-bi-field="issuer_iban" class="ck-input" placeholder="CH00 0000 0000 0000 0000 0" />
          </label>

          <!-- Lignes -->
          <div>
            <div class="mb-2 flex items-center justify-between">
              <span class="text-xs font-medium text-ink-400">Lignes</span>
              <button type="button" data-bi-add-line class="rounded-lg border border-white/10 bg-white/[0.02] px-3 py-1 text-xs font-medium text-ink-200 hover:border-white/20">+ Ligne</button>
            </div>
            <div data-bi-lines class="space-y-2"></div>
          </div>

          <!-- Totaux live -->
          <div class="rounded-xl border border-white/[0.06] bg-white/[0.02] p-4 text-sm">
            <div class="flex justify-between text-ink-400"><span>Sous-total</span><span data-bi-subtotal class="tabular-nums text-ink-50">0.00</span></div>
            <div class="flex justify-between text-ink-400"><span data-bi-vat-label>TVA</span><span data-bi-vat class="tabular-nums text-ink-50">0.00</span></div>
            <div class="mt-2 flex justify-between border-t border-white/[0.06] pt-2 text-base font-semibold text-ink-50"><span>Total</span><span data-bi-total class="tabular-nums">0.00</span></div>
          </div>

          <label class="block text-xs">
            <span class="mb-1 block font-medium text-ink-400">Notes</span>
            <textarea data-bi-field="notes" rows="2" class="ck-input"></textarea>
          </label>

          <p data-bi-error role="alert" hidden class="text-sm text-rose-400"></p>
          <div class="flex justify-end gap-2 pt-2">
            <button type="button" data-modal-close class="rounded-lg border border-white/10 px-4 py-2 text-sm text-ink-300 hover:border-white/20 hover:text-ink-50">Annuler</button>
            <button type="submit" data-bi-submit class="rounded-lg bg-accent-500 px-4 py-2 text-sm font-semibold text-white hover:bg-accent-400 disabled:cursor-not-allowed disabled:opacity-60">Enregistrer</button>
          </div>
        </form>
      </div>
    </div>

    <!-- ===== MODAL : abonnement ===== -->
    <div data-modal="subscription" hidden class="ck-modal" role="dialog" aria-modal="true" aria-labelledby="ck-sub-title">
      <div class="ck-modal-back"></div>
      <div class="ck-modal-card">
        <div class="flex items-center justify-between border-b border-white/[0.06] px-5 py-4">
