<style is:global>
  .ck-tab[aria-selected="true"] { border-color: var(--color-accent-500); color: var(--color-ink-50); }
  .ck-pill { border: 1px solid rgba(255,255,255,.10); background: rgba(255,255,255,.02); color: var(--color-ink-400); padding: .35rem .85rem; border-radius: 999px; font-size: .75rem; font-weight: 500; transition: all .15s; }
  .ck-pill:hover { border-color: rgba(255,255,255,.20); color: var(--color-ink-50); }
  .ck-pill-on { border-color: rgba(94,106,210,.60); background: rgba(94,106,210,.15); color: var(--color-ink-50); }
  .ck-subtab { padding: .5rem 1rem; border-radius: .5rem; font-size: .8rem; color: var(--color-ink-400); font-weight: 500; transition: all .15s; }
  .ck-subtab:hover { color: var(--color-ink-50); background: rgba(255,255,255,.03); }
  .ck-subtab-on { background: rgba(94,106,210,.12); color: var(--color-ink-50); }
  .ck-input { width: 100%; border-radius: .75rem; border: 1px solid rgba(255,255,255,.10); background: rgba(255,255,255,.03); padding: .65rem .85rem; font-size: .875rem; color: var(--color-ink-50); }
  .ck-input:focus { outline: none; border-color: rgba(94,106,210,.50); box-shadow: 0 0 0 3px rgba(94,106,210,.20); }
  .ck-modal { position: fixed; inset: 0; z-index: 60; display: flex; align-items: center; justify-content: center; padding: 1rem; }
  .ck-modal-back { position: absolute; inset: 0; background: rgba(0,0,0,.75); backdrop-filter: blur(4px); }
  .ck-modal-card { position: relative; width: 100%; max-width: 32rem; max-height: 90vh; overflow-y: auto; border-radius: 1rem; border: 1px solid rgba(255,255,255,.10); background: var(--color-ink-900); }
  .ck-modal-wide { max-width: 48rem; }
  .ck-line { display: grid; grid-template-columns: 1fr 4rem 6rem 6rem 2rem; gap: .5rem; align-items: center; }
  @media (max-width: 640px) { .ck-line { grid-template-columns: 1fr 1fr 1fr; } .ck-line .ck-line-rm { grid-column: span 3; } }
  .ck-sparkline { stroke: var(--color-accent-400); stroke-width: 1.5; fill: none; }
  .ck-sparkfill { fill: rgba(113,112,255,.10); }
  .ck-toasts { position: fixed; bottom: 1.25rem; left: 50%; transform: translateX(-50%); z-index: 80; display: flex; flex-direction: column; align-items: center; gap: .5rem; width: min(92vw, 28rem); pointer-events: none; }
  .ck-toast { pointer-events: auto; max-width: 100%; border-radius: .75rem; border: 1px solid rgba(255,255,255,.10); background: var(--color-ink-900); padding: .6rem 1rem; font-size: .8rem; color: var(--color-ink-50); box-shadow: 0 8px 24px rgba(0,0,0,.5); transition: opacity .3s; animation: ck-toast-in .25s cubic-bezier(0.16, 1, 0.3, 1); }
  .ck-toast-ok { border-color: rgba(74,222,128,.35); }
  .ck-toast-err { border-color: rgba(248,113,113,.45); }
  @keyframes ck-toast-in { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
  @media (prefers-reduced-motion: reduce) { .ck-toast { animation: none; } }
</style>

<script is:inline>
  (function () {
    const root = document.querySelector("[data-cockpit]");
    if (!root) return;
    const U = root.dataset.url;
    const K = root.dataset.key;
    const ADMIN = root.dataset.admin;

    // ===== DOM refs =====
    const loginView = root.querySelector("[data-ck-login]");
    const changeView = root.querySelector("[data-ck-change]");
    const changeForm = root.querySelector("[data-ck-change-form]");
    const changeBtn = root.querySelector("[data-ck-change-btn]");
    const changeError = root.querySelector("[data-ck-change-error]");
    const appView = root.querySelector("[data-ck-app]");
    const loginForm = root.querySelector("[data-ck-login-form]");
    const loginBtn = root.querySelector("[data-ck-login-btn]");
    const loginError = root.querySelector("[data-ck-login-error]");
    const logoutBtn = root.querySelector("[data-ck-logout]");
    const mfaView = root.querySelector("[data-ck-mfa]");
    const mfaForm = root.querySelector("[data-ck-mfa-form]");
    const mfaError = root.querySelector("[data-ck-mfa-error]");
    const btn2fa = root.querySelector("[data-ck-2fa]");
    const mfaBody = root.querySelector("[data-mfa-body]");
    const searchBtn = root.querySelector("[data-ck-search]");

    const tabs = root.querySelectorAll("[data-tab]");
    const panels = { overview: root.querySelector('[data-panel="overview"]'), leads: root.querySelector('[data-panel="leads"]'), orgs: root.querySelector('[data-panel="orgs"]'), audience: root.querySelector('[data-panel="audience"]'), billing: root.querySelector('[data-panel="billing"]') };
    const subtabs = root.querySelectorAll("[data-subtab]");
    const subpanels = { invoices: root.querySelector('[data-subpanel="invoices"]'), customers: root.querySelector('[data-subpanel="customers"]'), subscriptions: root.querySelector('[data-subpanel="subscriptions"]') };

    const esc = (s) => String(s ?? "").replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
    const fmtCHF = (n, c) => (c || "CHF") + " " + (Number(n) || 0).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, "'");
    const fmtDate = (s) => s ? new Date(s).toLocaleDateString("fr-CH", { day: "2-digit", month: "short", year: "numeric" }) : "—";
    const todayISO = () => new Date().toISOString().slice(0, 10);
    const addDaysISO = (d, n) => { const x = new Date(d); x.setDate(x.getDate() + n); return x.toISOString().slice(0, 10); };

    const toastsEl = root.querySelector("[data-ck-toasts]");
    function toast(msg, type) {
      const el = document.createElement("div");
      el.className = "ck-toast " + (type === "error" ? "ck-toast-err" : "ck-toast-ok");
      el.textContent = msg;
      toastsEl.appendChild(el);
      setTimeout(() => { el.style.opacity = "0"; setTimeout(() => el.remove(), 320); }, type === "error" ? 5200 : 2600);
    }

    // Un AbortController par module : changer d'onglet/période annule la requête précédente
    const aborters = {};
    function freshSignal(key) {
      if (aborters[key]) aborters[key].abort();
      aborters[key] = new AbortController();
      return aborters[key].signal;
    }
    const isAbort = (e) => !!e && (e.name === "AbortError" || e.code === 20);

    // ===== Auth (REST) =====
    const store = {
      get at() { return sessionStorage.getItem("ck_at"); },
      get rt() { return sessionStorage.getItem("ck_rt"); },
      set(at, rt) { sessionStorage.setItem("ck_at", at); sessionStorage.setItem("ck_rt", rt); },
      clear() { sessionStorage.removeItem("ck_at"); sessionStorage.removeItem("ck_rt"); },
    };
    function jwtEmail(token) { try { return JSON.parse(atob(token.split(".")[1])).email || ""; } catch { return ""; } }

    async function authRequest(grant, body) {
      const res = await fetch(U + "/auth/v1/token?grant_type=" + grant, {
        method: "POST", headers: { apikey: K, "Content-Type": "application/json" }, body: JSON.stringify(body),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error_description || data.msg || "Échec de connexion");
      return data;
    }
    async function refreshSession() {
      if (!store.rt) return false;
      try { const d = await authRequest("refresh_token", { refresh_token: store.rt }); store.set(d.access_token, d.refresh_token); return true; }
      catch { store.clear(); return false; }
    }
    async function api(path, opts = {}, retried = false) {
      const res = await fetch(U + "/rest/v1/" + path, {
        ...opts,
        headers: { apikey: K, Authorization: "Bearer " + store.at, "Content-Type": "application/json", ...(opts.headers || {}) },
      });
      if (res.status === 401 && !retried && (await refreshSession())) return api(path, opts, true);
      if (res.status === 401) { showLogin(); throw new Error("Session expirée"); }
      if (!res.ok) { const t = await res.text().catch(() => ""); throw new Error("HTTP " + res.status + " — " + t.slice(0, 200)); }
      return res;
    }
    async function fn(name, opts = {}) {
      const res = await fetch(U + "/functions/v1/" + name + (opts.qs ? "?" + opts.qs : ""), {
        method: opts.method || "GET",
        headers: { apikey: K, Authorization: "Bearer " + store.at, ...(opts.json ? { "Content-Type": "application/json" } : {}), ...(opts.headers || {}) },
        body: opts.json ? JSON.stringify(opts.json) : opts.body,
      });
      return res;
    }

    // ===== Vues principales =====
    function showLogin() { store.clear(); appView.hidden = true; changeView.hidden = true; mfaView.hidden = true; logoutBtn.hidden = true; btn2fa.hidden = true; searchBtn.hidden = true; loginView.hidden = false; }
    function showChange() { loginView.hidden = true; appView.hidden = true; mfaView.hidden = true; changeView.hidden = false; logoutBtn.hidden = false; document.getElementById("ck-newpw").focus(); }
    let mfaFactorId = null;
    function showMfa(factorId) {
      mfaFactorId = factorId;
      loginView.hidden = true; changeView.hidden = true; appView.hidden = true;
      logoutBtn.hidden = false; btn2fa.hidden = true; mfaView.hidden = false;
      const inp = document.getElementById("ck-mfa-code"); inp.value = ""; inp.focus();
    }
    async function showApp() {
      loginView.hidden = true; changeView.hidden = true; mfaView.hidden = true; appView.hidden = false; logoutBtn.hidden = false; btn2fa.hidden = false; searchBtn.hidden = false;
      let saved = null;
      try { saved = sessionStorage.getItem("ck_tab"); } catch {}
      switchTab(saved && panels[saved] ? saved : "overview");
    }
    async function fetchUser() {
      const res = await fetch(U + "/auth/v1/user", { headers: { apikey: K, Authorization: "Bearer " + store.at } });
      return res.ok ? res.json() : null;
    }

    // ===== MFA TOTP (GoTrue REST : /factors, /factors/:id/challenge, /factors/:id/verify) =====
    function jwtAal(token) { try { return JSON.parse(atob(token.split(".")[1])).aal || "aal1"; } catch { return "aal1"; } }
    async function mfaRequest(path, opts = {}) {
      const res = await fetch(U + "/auth/v1/factors" + path, {
        method: opts.method || "POST",
        headers: { apikey: K, Authorization: "Bearer " + store.at, "Content-Type": "application/json" },
        body: opts.body ? JSON.stringify(opts.body) : undefined,
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error_description || data.msg || "Erreur 2FA (" + res.status + ")");
      return data;
    }
    async function mfaVerify(factorId, code) {
      const ch = await mfaRequest("/" + factorId + "/challenge");
      const d = await mfaRequest("/" + factorId + "/verify", { body: { challenge_id: ch.id, code } });
      if (d.access_token) store.set(d.access_token, d.refresh_token);
      return d;
    }

    async function enter() {
      const user = await fetchUser();
      if (!user) { showLogin(); return; }
      const verified = (user.factors || []).filter((f) => f.status === "verified");
      if (verified.length && jwtAal(store.at) !== "aal2") { showMfa(verified[0].id); return; }
      if (user.user_metadata && user.user_metadata.temp_password === true) showChange();
      else await showApp();
    }

    // ===== Tab navigation =====
    function switchTab(name) {
      tabs.forEach((t) => {
        const on = t.dataset.tab === name;
        t.setAttribute("aria-selected", on ? "true" : "false");
        t.className = "ck-tab relative -mb-px border-b-2 px-4 py-3 text-sm font-medium transition-colors " + (on ? "border-accent-500 text-ink-50" : "border-transparent text-ink-400 hover:text-ink-50");
      });
      Object.entries(panels).forEach(([k, el]) => { if (el) el.hidden = k !== name; });
      try { sessionStorage.setItem("ck_tab", name); } catch {}
      if (name === "overview") loadOverview();
      if (name === "leads") loadLeads();
      if (name === "orgs") loadOrgs();
      if (name === "audience") loadAudience();
      if (name === "billing") { switchSubtab("invoices"); }
    }
    function switchSubtab(name) {
      subtabs.forEach((t) => {
        const on = t.dataset.subtab === name;
        t.setAttribute("aria-selected", on ? "true" : "false");
        t.className = "ck-subtab " + (on ? "ck-subtab-on" : "");
      });
      Object.entries(subpanels).forEach(([k, el]) => { if (el) el.hidden = k !== name; });
      if (name === "invoices") loadInvoices();
      if (name === "customers") loadCustomers();
      if (name === "subscriptions") loadSubscriptions();
    }
    tabs.forEach((t) => t.addEventListener("click", () => switchTab(t.dataset.tab)));
    subtabs.forEach((t) => t.addEventListener("click", () => switchSubtab(t.dataset.subtab)));

    // ===== Modal helpers =====
    const modals = root.querySelectorAll("[data-modal]");
    function openModal(name) {
      modals.forEach((m) => { m.hidden = m.dataset.modal !== name; });
      const m = root.querySelector('[data-modal="' + name + '"]');
      if (m) { const inp = m.querySelector("input, select, textarea"); if (inp) inp.focus(); }
    }
    function closeModals() { modals.forEach((m) => (m.hidden = true)); }
    root.addEventListener("click", (e) => {
      if (e.target.closest("[data-modal-close]") || e.target.classList.contains("ck-modal-back")) closeModals();
    });
    document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeModals(); });

    // =========================================================
    // ============ MODULE 1 : INSCRIPTIONS (LEADS) ============
    // =========================================================
    const STATUSES = [
      { value: "new", label: "Nouveau", color: "#7170ff" },
      { value: "contacted", label: "Contacté", color: "#fbbf24" },
      { value: "converted", label: "Converti", color: "#4ade80" },
      { value: "declined", label: "Refusé", color: "#8b8b94" },
    ];
    const statusOf = (v) => STATUSES.find((s) => s.value === v) || { value: v, label: v, color: "#8b8b94" };
    let leads = [];
    let leadFilter = "all";
    let leadView = "list";
    const statsEl = root.querySelector("[data-ck-stats]");
    const filtersEl = root.querySelector("[data-ck-filters]");
    const listEl = root.querySelector("[data-ck-list]");
    const emptyEl = root.querySelector("[data-ck-empty]");

    async function loadLeads() {
      const signal = freshSignal("leads");
      listEl.innerHTML = '<p class="py-10 text-center text-sm text-ink-500">Chargement…</p>';
      try {
        const res = await api("leads?select=*&order=created_at.desc", { signal });
        leads = await res.json();
        renderLeads();
      } catch (e) {
        if (isAbort(e)) return;
        listEl.innerHTML = '<p class="py-10 text-center text-sm text-rose-400">Erreur de chargement. Rechargez la page.</p>';
      }
    }
    async function patchLead(id, body) {
      await api("leads?id=eq." + encodeURIComponent(id), { method: "PATCH", headers: { Prefer: "return=minimal" }, body: JSON.stringify(body) });
    }
    function renderLeads() {
      const counts = { all: leads.length };
      STATUSES.forEach((s) => { counts[s.value] = leads.filter((l) => l.status === s.value).length; });
      statsEl.innerHTML = [["Total", counts.all, "#f4f4f5"]].concat(STATUSES.map((s) => [s.label + "s", counts[s.value], s.color])).slice(0, 4)
        .map(([label, n, color]) =>
          '<div class="rounded-2xl border border-white/10 bg-white/[0.02] p-4">' +
          '<p class="text-2xl font-semibold tabular-nums" style="color:' + color + '">' + n + "</p>" +
          '<p class="mt-0.5 text-xs text-ink-500">' + esc(label) + "</p></div>"
        ).join("");
      filtersEl.innerHTML = [{ value: "all", label: "Tous" }].concat(STATUSES).map((s) => {
        const on = leadFilter === s.value;
        return '<button type="button" data-filter="' + s.value + '" class="rounded-full border px-3.5 py-1.5 text-xs font-medium transition-colors ' +
          (on ? "border-accent-500/60 bg-accent-500/15 text-ink-50" : "border-white/10 bg-white/[0.02] text-ink-400 hover:border-white/20 hover:text-ink-50") +
          '">' + esc(s.label) + (s.value === "all" ? "" : " · " + (counts[s.value] || 0)) + "</button>";
      }).join("");
      if (focusLeadId) leadView = "list";
      syncViewPills();
      if (leadView === "kanban") { renderKanban(); return; }
      const shown = leadFilter === "all" ? leads : leads.filter((l) => l.status === leadFilter);
      emptyEl.hidden = shown.length > 0;
      listEl.innerHTML = shown.map(leadCard).join("");
      if (focusLeadId) {
        const card = listEl.querySelector('[data-lead="' + focusLeadId + '"]');
        if (card) { card.open = true; card.scrollIntoView({ block: "center" }); }
        focusLeadId = null;
      }
    }
    let focusLeadId = null;
    function leadCard(l) {
      const st = statusOf(l.status);
      const date = new Date(l.created_at).toLocaleDateString("fr-CH", { day: "2-digit", month: "short", year: "numeric" });
      const options = STATUSES.map((s) => '<option value="' + s.value + '"' + (s.value === l.status ? " selected" : "") + ">" + s.label + "</option>").join("");
      const modules = Array.isArray(l.modules) && l.modules.length
        ? l.modules.map((m) => '<span class="rounded-md border border-white/10 bg-white/[0.03] px-2 py-0.5 text-[11px] text-ink-300">' + esc(m) + "</span>").join(" ")
        : '<span class="text-ink-500">—</span>';
      return '<details class="group rounded-2xl border border-white/10 bg-white/[0.02] transition-colors hover:border-white/15" data-lead="' + esc(l.id) + '">' +
        '<summary class="flex cursor-pointer flex-wrap items-center gap-x-4 gap-y-2 px-5 py-4 [&::-webkit-details-marker]:hidden">' +
        '<span class="h-2 w-2 shrink-0 rounded-full" style="background:' + st.color + '"></span>' +
        '<span class="min-w-0 flex-1"><span class="block truncate text-sm font-semibold text-ink-50">' + esc(l.asso_name) + "</span>" +
        '<span class="block text-xs text-ink-500">' + esc(l.canton) + " · " + esc(l.member_count) + " membres · " + date + "</span></span>" +
        (l.next_action_at ? '<span class="text-[11px] font-medium ' + (l.next_action_at <= todayISO() ? "text-rose-400" : "text-ink-500") + '">🔔 ' + fmtDate(l.next_action_at) + "</span>" : "") +
        (l.provisioned_org_id ? '<span class="rounded-md bg-emerald-400/10 px-1.5 py-0.5 text-[10px] font-medium text-emerald-400">App ✓</span>' : "") +
        '<span class="text-xs text-ink-400">' + esc(l.first_name + " " + l.last_name) + "</span>" +
        '<select data-status class="rounded-lg border border-white/10 bg-ink-900 px-2.5 py-1.5 text-xs text-ink-50 focus:border-accent-500/50 focus:outline-none">' + options + "</select>" +
        "</summary>" +
        '<div class="space-y-4 border-t border-white/[0.06] px-5 py-4 text-sm">' +
        '<p><span class="text-ink-500">Contact :</span> <a class="text-accent-300 underline decoration-accent-500/40 underline-offset-2" href="mailto:' + esc(l.email) + '">' + esc(l.email) + "</a>" +
        (l.phone ? ' · <span class="text-ink-200">' + esc(l.phone) + "</span>" : "") +
        ' · <span class="text-ink-400">' + esc(l.role) + "</span></p>" +
        '<p><span class="text-ink-500">Activité :</span> <span class="text-ink-200">' + esc(l.activity) + "</span></p>" +
        (l.needs ? '<p><span class="text-ink-500">Besoins :</span> <span class="text-ink-200">' + esc(l.needs) + "</span></p>" : "") +
        '<p class="flex flex-wrap items-center gap-1.5"><span class="text-ink-500">Modules :</span> ' + modules + "</p>" +
        (l.legal_form || l.source
          ? '<p class="text-xs text-ink-500">' + esc([l.legal_form, l.source && "via " + l.source].filter(Boolean).join(" · ")) + "</p>"
          : "") +
        '<div><label class="mb-1.5 block text-xs font-medium text-ink-400">Notes internes</label>' +
        '<textarea data-notes rows="2" class="w-full rounded-xl border border-white/10 bg-white/[0.03] px-3 py-2 text-sm text-ink-50 focus:border-accent-500/50 focus:outline-none">' + esc(l.notes || "") + "</textarea>" +
        '<button type="button" data-save-notes class="mt-2 rounded-lg border border-white/10 bg-white/[0.02] px-3.5 py-1.5 text-xs font-medium text-ink-50 transition-colors hover:border-white/20">Enregistrer la note</button>' +
        '<span data-saved hidden class="ml-2 text-xs text-emerald-400">Enregistré ✓</span></div>' +
        '<div class="flex flex-wrap items-end gap-2 border-t border-white/[0.06] pt-3">' +
        '<label class="block text-xs"><span class="mb-1 block font-medium text-ink-400">Prochaine action</span>' +
        '<input type="date" data-next-action value="' + esc(l.next_action_at || "") + '" class="rounded-lg border border-white/10 bg-ink-900 px-2.5 py-1.5 text-xs text-ink-50 focus:border-accent-500/50 focus:outline-none" /></label>' +
        '<button type="button" data-save-reminder class="rounded-lg border border-white/10 bg-white/[0.02] px-3 py-1.5 text-xs font-medium text-ink-200 transition-colors hover:border-white/20">Planifier</button>' +
        '<span class="flex-1"></span>' +
        '<button type="button" data-lead-email class="rounded-lg border border-accent-500/40 bg-accent-500/10 px-3 py-1.5 text-xs font-medium text-accent-300 transition-colors hover:bg-accent-500/20">✉️ Email</button>' +
        (l.provisioned_org_id
          ? '<span class="rounded-lg border border-emerald-400/30 bg-emerald-400/10 px-3 py-1.5 text-xs font-medium text-emerald-400">Provisionnée ✓</span>'
          : '<button type="button" data-lead-provision class="rounded-lg bg-accent-500 px-3 py-1.5 text-xs font-semibold text-white transition-colors hover:bg-accent-400">🚀 Provisionner</button>') +
        "</div>" +
        '<div data-lead-events class="border-t border-white/[0.06] pt-3 text-xs text-ink-500"></div>' +
        "</div></details>";
    }
    filtersEl.addEventListener("click", (e) => {
      const btn = e.target.closest("[data-filter]"); if (!btn) return;
      leadFilter = btn.dataset.filter; renderLeads();
    });
    listEl.addEventListener("click", (e) => {
      if (e.target.closest("[data-status]")) { e.preventDefault(); e.stopPropagation(); }
      const card = e.target.closest("[data-lead]");
      if (!card) return;
      const id = card.dataset.lead;
      const saveBtn = e.target.closest("[data-save-notes]");
      if (saveBtn) {
        const notes = card.querySelector("[data-notes]").value;
        saveBtn.disabled = true;
        patchLead(id, { notes }).then(() => {
          const lead = leads.find((l) => l.id === id); if (lead) lead.notes = notes;
          const ok = card.querySelector("[data-saved]"); ok.hidden = false; setTimeout(() => (ok.hidden = true), 2000);
        }).catch(() => toast("Échec de l'enregistrement de la note.", "error")).finally(() => (saveBtn.disabled = false));
      }
      const remBtn = e.target.closest("[data-save-reminder]");
      if (remBtn) {
        const val = card.querySelector("[data-next-action]").value || null;
        remBtn.disabled = true;
        patchLead(id, { next_action_at: val }).then(() => {
          const lead = leads.find((l) => l.id === id); if (lead) lead.next_action_at = val;
          toast(val ? "Rappel planifié pour le " + fmtDate(val) + " ✓" : "Rappel retiré.");
          if (val) logLeadEvent(id, "reminder_set", "Relance planifiée le " + fmtDate(val));
        }).catch(() => toast("Échec de l'enregistrement du rappel.", "error")).finally(() => (remBtn.disabled = false));
      }
      if (e.target.closest("[data-lead-email]")) {
        const lead = leads.find((l) => l.id === id); if (lead) openEmailModal(lead);
      }
      if (e.target.closest("[data-lead-provision]")) {
        const lead = leads.find((l) => l.id === id); if (lead) provisionLead(lead);
      }
    });
    listEl.addEventListener("change", (e) => {
      const sel = e.target.closest("[data-status]"); if (!sel) return;
      const card = sel.closest("[data-lead]"); const id = card.dataset.lead;
      const prev = (leads.find((l) => l.id === id) || {}).status;
      patchLead(id, { status: sel.value }).then(() => {
        const lead = leads.find((l) => l.id === id); if (lead) lead.status = sel.value; renderLeads();
        logLeadEvent(id, "status_change", "Statut → " + statusOf(sel.value).label);
      }).catch(() => { sel.value = prev; toast("Échec du changement de statut.", "error"); });
    });

    // Timeline d'activité : chargée à l'ouverture du card (toggle ne bulle pas → capture)
    listEl.addEventListener("toggle", (e) => {
      const card = e.target.closest ? e.target.closest("[data-lead]") : null;
      if (!card || !card.open) return;
      loadLeadEvents(card.dataset.lead, card.querySelector("[data-lead-events]"));
    }, true);
    const EVENT_ICONS = { status_change: "↻", note: "📝", email_sent: "✉️", reminder_set: "🔔", provisioned: "🚀" };
    async function loadLeadEvents(id, el) {
      if (!el || el.dataset.loaded) return;
      try {
        const res = await api("lead_events?lead_id=eq." + encodeURIComponent(id) + "&order=created_at.desc&limit=20");
        const evs = await res.json();
        el.dataset.loaded = "1";
        el.innerHTML = evs.length
          ? '<p class="mb-1.5 font-medium text-ink-400">Historique</p>' + evs.map((ev) =>
              '<p class="py-0.5">' + (EVENT_ICONS[ev.type] || "·") + ' <span class="text-ink-300">' + esc(ev.detail || ev.type) + '</span> <span class="text-ink-500">— ' + fmtDate(ev.created_at) + "</span></p>"
            ).join("")
          : "<p>Aucune activité enregistrée pour ce lead.</p>";
      } catch { el.innerHTML = ""; }
    }
    function logLeadEvent(id, type, detail) {
      api("lead_events", { method: "POST", headers: { Prefer: "return=minimal" }, body: JSON.stringify({ lead_id: id, type, detail }) })
        .then(() => {
          const el = listEl.querySelector('[data-lead="' + id + '"] [data-lead-events]');
          if (el) { delete el.dataset.loaded; const card = el.closest("[data-lead]"); if (card && card.open) loadLeadEvents(id, el); }
        })
        .catch(() => {});
    }

    // ----- Vue Kanban -----
    function syncViewPills() {
      root.querySelectorAll("[data-view]").forEach((x) => { x.className = "ck-pill" + (x.dataset.view === leadView ? " ck-pill-on" : ""); });
    }
    root.querySelectorAll("[data-view]").forEach((b) => b.addEventListener("click", () => {
      leadView = b.dataset.view;
      renderLeads();
    }));
    function renderKanban() {
      emptyEl.hidden = true;
      listEl.innerHTML = '<div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">' +
        STATUSES.map((s) => {
          const items = leads.filter((l) => l.status === s.value);
          return '<div class="rounded-2xl border border-white/10 bg-white/[0.02] p-3">' +
            '<p class="mb-2 flex items-center gap-2 px-1 text-xs font-semibold" style="color:' + s.color + '">' +
            '<span class="h-2 w-2 rounded-full" style="background:' + s.color + '"></span>' + esc(s.label) + " · " + items.length + "</p>" +
            '<div class="min-h-16 space-y-2" data-kb-drop="' + s.value + '">' +
            items.map((l) =>
              '<div draggable="true" data-kb-card="' + esc(l.id) + '" class="cursor-grab rounded-xl border border-white/10 bg-ink-900 p-3 transition-colors hover:border-white/20 active:cursor-grabbing">' +
              '<p class="truncate text-sm font-semibold text-ink-50">' + esc(l.asso_name) + "</p>" +
              '<p class="mt-0.5 truncate text-[11px] text-ink-500">' + esc((l.first_name || "") + " " + (l.last_name || "")) + (l.canton ? " · " + esc(l.canton) : "") + "</p>" +
              (l.next_action_at ? '<p class="mt-1 text-[11px] ' + (l.next_action_at <= todayISO() ? "text-rose-400" : "text-ink-500") + '">🔔 ' + fmtDate(l.next_action_at) + "</p>" : "") +
              (l.provisioned_org_id ? '<p class="mt-1 text-[11px] text-emerald-400">App ✓</p>' : "") +
              "</div>"
            ).join("") + "</div></div>";
        }).join("") + "</div>";
    }
    let dragLeadId = null;
    listEl.addEventListener("dragstart", (e) => {
      const card = e.target.closest && e.target.closest("[data-kb-card]");
      if (card) { dragLeadId = card.dataset.kbCard; e.dataTransfer.effectAllowed = "move"; }
    });
    listEl.addEventListener("dragover", (e) => {
      if (dragLeadId && e.target.closest && e.target.closest("[data-kb-drop]")) e.preventDefault();
    });
    listEl.addEventListener("drop", (e) => {
      const zone = e.target.closest && e.target.closest("[data-kb-drop]");
      if (!zone || !dragLeadId) return;
      e.preventDefault();
      const id = dragLeadId; dragLeadId = null;
      const status = zone.dataset.kbDrop;
      const lead = leads.find((l) => l.id === id);
      if (!lead || lead.status === status) return;
      const prev = lead.status;
      lead.status = status;
      renderLeads();
      patchLead(id, { status }).then(() => {
        logLeadEvent(id, "status_change", "Statut → " + statusOf(status).label);
        toast("Statut mis à jour ✓");
      }).catch(() => { lead.status = prev; renderLeads(); toast("Échec du changement de statut.", "error"); });
    });

    // =========================================================
    // ============ MODULE 1B : APERÇU (dashboard) ==============
    // =========================================================
    const ovContent = root.querySelector("[data-ov-content]");
    async function loadOverview() {
      const signal = freshSignal("overview");
      ovContent.innerHTML = '<p class="mt-12 text-center text-sm text-ink-500">Chargement…</p>';
      // Tick d'onboarding opportuniste (filet en plus du cron) — fire-and-forget
      fn("cockpit-onboarding-tick", { method: "POST", json: {} })
        .then((r) => r.ok ? r.json() : null)
        .then((d) => { if (d && d.sent > 0) toast(d.sent + " email(s) d'onboarding envoyé(s) ✉️"); })
        .catch(() => {});
      try {
        const [leadsRes, invRes, anaRes, evRes, monRes, sysRes, onbRes] = await Promise.all([
          api("leads?select=id,asso_name,status,created_at,next_action_at,first_name,last_name,source,provisioned_org_id&order=created_at.desc", { signal }),
          api("invoices?select=id,number,total,currency,status,due_date,paid_at,doc_type&order=due_date.asc", { signal }),
          api("rpc/cockpit_analytics", { method: "POST", body: JSON.stringify({ p_period: "7d" }), signal }).catch(() => null),
          api("lead_events?select=lead_id,type,detail,created_at&or=(type.eq.provisioned,type.eq.status_change)&limit=1000", { signal }).catch(() => null),
          api("rpc/cockpit_monitoring", { method: "POST", body: "{}", signal }).catch(() => null),
          fn("cockpit-monitoring").catch(() => null),
          api("scheduled_emails?select=template_key,recipient_email,org_name,status,scheduled_for,sent_at&order=scheduled_for.desc&limit=20", { signal }).catch(() => null),
        ]);
        const allLeads = await leadsRes.json();
        const invs = await invRes.json();
        const ana = anaRes ? await anaRes.json().catch(() => null) : null;
        const events = evRes ? await evRes.json().catch(() => []) : [];
        const mon = monRes ? await monRes.json().catch(() => null) : null;
        const sys = sysRes && sysRes.ok ? await sysRes.json().catch(() => null) : null;
        const onb = onbRes ? await onbRes.json().catch(() => []) : [];
        renderOverview(allLeads, invs, ana, events, mon, sys, onb);
      } catch (e) {
        if (isAbort(e)) return;
        ovContent.innerHTML = '<p class="mt-12 text-center text-sm text-rose-400">Erreur : ' + esc(String(e)) + "</p>";
      }
    }
    function conversionStats(allLeads, events) {
      const total = allLeads.length;
      const converted = allLeads.filter((l) => l.status === "converted" || l.provisioned_org_id).length;
      const rate = total ? Math.round((converted / total) * 100) : 0;
      const convDates = {};
      (events || []).forEach((ev) => {
        if ((ev.type === "status_change" && /Converti$/.test(ev.detail || "")) || ev.type === "provisioned") {
          if (!convDates[ev.lead_id] || ev.created_at < convDates[ev.lead_id]) convDates[ev.lead_id] = ev.created_at;
        }
      });
      const durations = [];
      allLeads.forEach((l) => { if (convDates[l.id]) durations.push((new Date(convDates[l.id]) - new Date(l.created_at)) / 86400000); });
      const avgDays = durations.length ? Math.round(durations.reduce((a, b) => a + b, 0) / durations.length) : null;
      const srcCount = {};
      allLeads.forEach((l) => { const s = (l.source || "").trim(); if (s) srcCount[s] = (srcCount[s] || 0) + 1; });
      const topSource = Object.entries(srcCount).sort((a, b) => b[1] - a[1])[0] || null;
      return { total, converted, rate, avgDays, topSource };
    }

    function renderOverview(allLeads, invs, ana, events, mon, sys, onb) {
      const today = todayISO();
      const weekAgo = addDaysISO(today, -7);
      const due = allLeads
        .filter((l) => l.next_action_at && l.next_action_at <= today && l.status !== "declined" && l.status !== "converted")
        .sort((a, b) => (a.next_action_at < b.next_action_at ? -1 : 1));
      const newLeads = allLeads.filter((l) => l.created_at >= weekAgo);
      const lateInvs = invs.filter((i) => i.status === "overdue" || (i.status === "sent" && i.due_date && i.due_date < today));
      const lateSum = lateInvs.reduce((s, i) => s + (Number(i.total) || 0), 0);
      const monthKey = today.slice(0, 7);
      const paidMonth = invs.filter((i) => i.status === "paid" && (i.paid_at || "").slice(0, 7) === monthKey)
        .reduce((s, i) => s + (Number(i.total) || 0), 0);
      const visitors = ana && ana.stats ? Number(ana.stats.visitors) || 0 : null;

      const kpiCard = (label, value, color, tab) =>
        '<button type="button" data-goto="' + tab + '" class="rounded-2xl border border-white/10 bg-white/[0.02] p-5 text-left transition-colors hover:border-white/20">' +
        '<p class="text-3xl font-semibold tracking-tight tabular-nums" style="color:' + color + '">' + value + "</p>" +
        '<p class="mt-1 text-xs text-ink-500">' + esc(label) + "</p></button>";
      const miniList = (items, mapper, emptyMsg) =>
        items.length
          ? '<ul class="space-y-1.5">' + items.slice(0, 6).map(mapper).join("") + "</ul>"
          : '<p class="text-sm text-ink-500">' + emptyMsg + "</p>";

      ovContent.innerHTML =
        '<div class="mt-8 grid grid-cols-2 gap-3 lg:grid-cols-4">' +
        kpiCard("Leads à relancer", String(due.length), due.length ? "#f87171" : "#4ade80", "leads") +
        kpiCard("Nouvelles demandes (7 j)", String(newLeads.length), "#7170ff", "leads") +
        kpiCard("Factures en retard", lateInvs.length ? lateInvs.length + " · " + fmtCHF(lateSum, "CHF") : "0", lateInvs.length ? "#f87171" : "#4ade80", "billing") +
        kpiCard("Encaissé ce mois-ci", fmtCHF(paidMonth, "CHF"), "#4ade80", "billing") +
        "</div>" +
        '<div class="mt-6 grid grid-cols-1 gap-4 lg:grid-cols-2">' +
        '<div class="rounded-2xl border border-white/10 bg-white/[0.02] p-5">' +
        '<h3 class="mb-3 text-sm font-semibold text-ink-50">🔔 À relancer</h3>' +
        miniList(due, (l) =>
          '<li><button type="button" data-goto-lead="' + esc(l.id) + '" class="flex w-full items-center justify-between rounded-lg border border-white/[0.06] bg-white/[0.01] px-3 py-2 text-left text-xs transition-colors hover:border-white/15">' +
          '<span class="truncate text-ink-200">' + esc(l.asso_name) + ' <span class="text-ink-500">· ' + esc((l.first_name || "") + " " + (l.last_name || "")) + "</span></span>" +
          '<span class="ml-3 shrink-0 tabular-nums text-rose-400">' + fmtDate(l.next_action_at) + "</span></button></li>",
          "Rien en attente — tout est à jour ✓") +
        "</div>" +
        '<div class="rounded-2xl border border-white/10 bg-white/[0.02] p-5">' +
        '<h3 class="mb-3 text-sm font-semibold text-ink-50">Dernières demandes</h3>' +
        miniList(newLeads, (l) =>
          '<li><button type="button" data-goto-lead="' + esc(l.id) + '" class="flex w-full items-center justify-between rounded-lg border border-white/[0.06] bg-white/[0.01] px-3 py-2 text-left text-xs transition-colors hover:border-white/15">' +
          '<span class="truncate text-ink-200">' + esc(l.asso_name) + "</span>" +
          '<span class="ml-3 shrink-0 text-ink-500">' + fmtDate(l.created_at) + "</span></button></li>",
          "Aucune demande cette semaine.") +
        "</div></div>" +
        renderOverviewExtras(allLeads, events, mon, sys, onb) +
        (visitors !== null
          ? '<p class="mt-6 text-center text-xs text-ink-500">' + fmtNum(visitors) + ' visiteurs sur konclav.ch ces 7 derniers jours · <button type="button" data-goto="audience" class="text-accent-300 hover:text-accent-400">voir l\'audience</button></p>'
          : "");
    }
    function renderOverviewExtras(allLeads, events, mon, sys, onb) {
      const cv = conversionStats(allLeads, events);
      const statLine = (label, value) =>
        '<div class="flex items-center justify-between py-1 text-xs"><span class="text-ink-500">' + label + '</span><span class="font-medium text-ink-200">' + value + "</span></div>";

      const convCard =
        '<div class="rounded-2xl border border-white/10 bg-white/[0.02] p-5">' +
        '<h3 class="mb-2 text-sm font-semibold text-ink-50">📈 Conversion</h3>' +
        statLine("Taux de conversion", cv.rate + " % <span class=\"text-ink-500\">(" + cv.converted + "/" + cv.total + ")</span>") +
        statLine("Temps moyen avant conversion", cv.avgDays !== null ? cv.avgDays + " j" : "—") +
        statLine("Top source", cv.topSource ? esc(cv.topSource[0]) + " <span class=\"text-ink-500\">(" + cv.topSource[1] + ")</span>" : "—") +
        "</div>";

      let sysCard = '<div class="rounded-2xl border border-white/10 bg-white/[0.02] p-5">' +
        '<h3 class="mb-2 text-sm font-semibold text-ink-50">🩺 Santé système</h3>';
      if (mon) {
        const runs = Array.isArray(mon.cron_runs) ? mon.cron_runs : [];
        const last = runs[0];
        sysCard += statLine("Facturation nocturne",
          last
            ? (last.status === "succeeded" ? '<span class="text-emerald-400">✓ ' + fmtDate(last.start_time) + "</span>" : '<span class="text-rose-400">✗ ' + esc(last.status) + "</span>")
            : "pas encore exécutée");
        sysCard += statLine("Brouillons d'abonnement à valider", mon.draft_auto_invoices > 0 ? '<span class="text-amber-400">' + mon.draft_auto_invoices + "</span>" : "0");
        sysCard += statLine("Leads dormants (14 j sans action)", mon.stuck_leads > 0 ? '<span class="text-rose-400">' + mon.stuck_leads + "</span>" : "0");
      } else {
        sysCard += '<p class="text-xs text-ink-500">Monitoring indisponible.</p>';
      }
      if (sys && Array.isArray(sys.resend)) {
        const bad = sys.resend.filter((r) => ["bounced", "complained", "failed", "delivery_delayed"].indexOf(String(r.status)) !== -1);
        sysCard += statLine("Emails récents (Resend)",
          sys.resend.length
            ? (bad.length ? '<span class="text-rose-400">' + bad.length + " en échec / " + sys.resend.length + "</span>" : '<span class="text-emerald-400">' + sys.resend.length + " OK</span>")
            : "—");
        if (bad.length) {
          sysCard += bad.slice(0, 3).map((r) => '<p class="truncate py-0.5 text-[11px] text-rose-400">✗ ' + esc(r.to || "?") + " — " + esc(r.subject || "") + "</p>").join("");
        }
      }
      sysCard += "</div>";

      let bugsCard = '<div class="rounded-2xl border border-white/10 bg-white/[0.02] p-5">' +
        '<h3 class="mb-2 text-sm font-semibold text-ink-50">🐛 Bugs signalés (app)</h3>';
      if (sys && Array.isArray(sys.bugs) && sys.bugs.length) {
        bugsCard += sys.bugs.slice(0, 4).map((b) =>
          '<div class="border-b border-white/[0.04] py-1.5 last:border-0">' +
          '<p class="text-xs text-ink-200">' + esc(String(b.description).slice(0, 90)) + (String(b.description).length > 90 ? "…" : "") + "</p>" +
          '<p class="mt-0.5 text-[11px] text-ink-500">' + esc(b.who) + " · " + esc(b.org) + " · " + fmtDate(b.created_at) + "</p>" +
          "</div>").join("");
      } else {
        bugsCard += '<p class="text-xs text-ink-500">Aucun bug signalé 🎉</p>';
      }
      bugsCard += "</div>";

      const onbRows = Array.isArray(onb) ? onb : [];
      const pending = onbRows.filter((r) => r.status === "pending").length;
      const failedOnb = onbRows.filter((r) => r.status === "failed").length;
      const ONB_LABEL = { onboarding_d1: "J+1", onboarding_d7: "J+7", onboarding_d14: "J+14" };
      const ONB_ICON = { sent: "✓", pending: "⏳", failed: "✗", sending: "⏳", canceled: "⊘" };
      const ONB_COLOR = { sent: "text-emerald-400", pending: "text-amber-400", failed: "text-rose-400", sending: "text-amber-400", canceled: "text-ink-500" };
      let onbCard = '<div class="rounded-2xl border border-white/10 bg-white/[0.02] p-5">' +
        '<div class="mb-2 flex items-center justify-between"><h3 class="text-sm font-semibold text-ink-50">📬 Onboarding (envois auto)</h3>' +
        '<button type="button" data-onb-open class="text-xs text-accent-300 hover:text-accent-400">Modifier</button></div>' +
        '<p class="mb-3 text-xs text-ink-500">' + pending + " en attente · " + onbRows.filter((r) => r.status === "sent").length + " envoyé(s)" +
          (failedOnb ? ' · <span class="text-rose-400">' + failedOnb + " échec(s)</span>" : "") + "</p>";
      if (!onbRows.length) {
        onbCard += '<p class="text-xs text-ink-500">Rien à envoyer pour l\'instant — les emails se programment au provisionnement.</p>';
      } else {
        onbCard += onbRows.slice(0, 5).map((r) =>
          '<div class="flex items-center gap-2 border-b border-white/[0.04] py-1.5 text-xs last:border-0">' +
          '<span class="' + (ONB_COLOR[r.status] || "text-ink-400") + '">' + (ONB_ICON[r.status] || "·") + "</span>" +
          '<span class="rounded bg-white/[0.04] px-1.5 py-0.5 text-[10px] text-ink-400">' + esc(ONB_LABEL[r.template_key] || r.template_key) + "</span>" +
          '<span class="min-w-0 flex-1 truncate text-ink-200">' + esc(r.org_name || r.recipient_email) + "</span>" +
          '<span class="shrink-0 text-ink-500">' + fmtDate(r.sent_at || r.scheduled_for) + "</span></div>").join("");
      }
      onbCard += "</div>";
      // Card contenu du site
      const scCard = '<div class="rounded-2xl border border-white/10 bg-white/[0.02] p-5">' +
        '<div class="mb-2 flex items-center justify-between"><h3 class="text-sm font-semibold text-ink-50">✏️ Contenu du site</h3>' +
        '<button type="button" data-sc-open class="text-xs text-accent-300 hover:text-accent-400">Éditer</button></div>' +
        '<p class="text-xs text-ink-500">Hero, sous-titre, CTA final — modifiables sans toucher au code, appliqués en direct sur konclav.ch.</p></div>';
      return '<div class="mt-6 grid grid-cols-1 gap-4 lg:grid-cols-2">' + convCard + onbCard + "</div>" +
             '<div class="mt-4 grid grid-cols-1 gap-4 lg:grid-cols-3">' + sysCard + bugsCard + scCard + "</div>";
    }

    // ----- Édition du contenu du site -----
    const SITE_CONTENT_FIELDS = [
      { key: "hero.title", label: "Hero — titre principal (H1)", placeholder: "Gérez votre association dans une seule app !", multiline: false, max: 120 },
      { key: "hero.subtitle", label: "Hero — sous-titre", placeholder: "Konclav, c'est l'intranet privé pensé pour les associations suisses. Tâches, agenda, documents, cotisations, AG, votations — toute la vie associative dans une seule app mobile.", multiline: true, max: 500, hint: "Le formatting italique du défaut est perdu si tu modifies (sécurité)." },
      { key: "hero.cta_primary", label: "Hero — bouton principal", placeholder: "S'inscrire", multiline: false, max: 40 },
      { key: "cta_final.eyebrow", label: "Bas de page — eyebrow", placeholder: "On se cale ?", multiline: false, max: 40 },
      { key: "cta_final.title", label: "Bas de page — titre", placeholder: "Prêt à inscrire votre asso ?", multiline: false, max: 120 },
      { key: "cta_final.subtitle", label: "Bas de page — sous-titre", placeholder: "Un court formulaire pour nous présenter votre asso. On étudie chaque demande et on revient vers vous sous 48h ouvrées.", multiline: true, max: 500 },
    ];
    let scCache = null;
    async function loadSiteContent() {
      if (scCache) return scCache;
      try {
        const res = await api("cockpit_settings?key=eq.site_content&select=value");
        const rows = await res.json();
        scCache = rows[0] && rows[0].value && typeof rows[0].value === "object" ? rows[0].value : {};
      } catch { scCache = {}; }
      return scCache;
    }
    ovContent.addEventListener("click", async (e) => {
      if (!e.target.closest("[data-sc-open]")) return;
      const current = await loadSiteContent();
      root.querySelector("[data-sc-list]").innerHTML = SITE_CONTENT_FIELDS.map((f) => {
        const value = typeof current[f.key] === "string" ? current[f.key] : "";
        const input = f.multiline
          ? '<textarea data-sc-field="' + esc(f.key) + '" rows="3" maxlength="' + f.max + '" class="ck-input" placeholder="' + esc(f.placeholder) + '">' + esc(value) + '</textarea>'
          : '<input data-sc-field="' + esc(f.key) + '" maxlength="' + f.max + '" class="ck-input" placeholder="' + esc(f.placeholder) + '" value="' + esc(value) + '" />';
        return '<div class="rounded-xl border border-white/[0.06] bg-white/[0.01] p-3">' +
          '<p class="mb-1.5 text-xs font-semibold text-ink-50">' + esc(f.label) + '</p>' +
          '<p class="mb-2 text-[11px] text-ink-500">Défaut : <span class="italic">' + esc(f.placeholder.slice(0, 120)) + (f.placeholder.length > 120 ? "…" : "") + '</span>' + (f.hint ? ' · ' + esc(f.hint) : "") + '</p>' +
          input + "</div>";
      }).join("");
      root.querySelector("[data-sc-error]").hidden = true;
      openModal("sitecontent");
    });
    root.querySelector("[data-sc-save]").addEventListener("click", async () => {
      const errEl = root.querySelector("[data-sc-error]");
      const value = {};
      SITE_CONTENT_FIELDS.forEach((f) => {
        const v = (root.querySelector('[data-sc-field="' + f.key + '"]').value || "").trim();
        if (v) value[f.key] = v.slice(0, f.max);
      });
      try {
        await api("cockpit_settings", { method: "POST", headers: { Prefer: "resolution=merge-duplicates,return=minimal" }, body: JSON.stringify({ key: "site_content", value }) });
        scCache = value;
        toast("Contenu du site mis à jour ✓ — visible immédiatement sur konclav.ch");
        closeModals();
      } catch (e) { errEl.textContent = e.message || "Erreur."; errEl.hidden = false; }
    });

    // ----- Édition des templates onboarding -----
    let onbCache = null;
    async function loadOnbTemplates() {
      if (onbCache) return onbCache;
      try {
        const res = await api("cockpit_settings?key=eq.onboarding_emails&select=value");
        const rows = await res.json();
        onbCache = rows[0] && Array.isArray(rows[0].value) ? rows[0].value : [];
      } catch { onbCache = []; }
      return onbCache;
    }
    ovContent.addEventListener("click", async (e) => {
      if (!e.target.closest("[data-onb-open]")) return;
      const tpls = await loadOnbTemplates();
      root.querySelector("[data-onb-list]").innerHTML = tpls.map((t, i) =>
        '<div class="rounded-xl border border-white/[0.06] bg-white/[0.01] p-3">' +
        '<div class="mb-2 flex items-center justify-between"><p class="text-xs font-semibold text-ink-50">' + esc(t.label || t.key) + "</p>" +
        '<label class="text-xs text-ink-500">Délai (jours) <input data-onb-delay="' + i + '" type="number" min="0" max="365" value="' + (t.delay_days != null ? t.delay_days : 0) + '" class="ml-1 w-16 rounded border border-white/10 bg-white/[0.03] px-2 py-1 text-xs text-ink-50 tabular-nums" /></label></div>' +
        '<input data-onb-subject="' + i + '" value="' + esc(t.subject || "") + '" class="ck-input mb-2" aria-label="Sujet" />' +
        '<textarea data-onb-body="' + i + '" rows="6" class="ck-input" aria-label="Corps">' + esc(t.body || "") + "</textarea>" +
        "</div>").join("");
      root.querySelector("[data-onb-error]").hidden = true;
      openModal("onboarding");
    });
    root.querySelector("[data-onb-save]").addEventListener("click", async () => {
      const tpls = await loadOnbTemplates();
      const errEl = root.querySelector("[data-onb-error]");
      const value = tpls.map((t, i) => ({
        key: t.key,
        label: t.label,
        delay_days: Math.max(0, Math.min(365, +root.querySelector('[data-onb-delay="' + i + '"]').value || 0)),
        subject: root.querySelector('[data-onb-subject="' + i + '"]').value,
        body: root.querySelector('[data-onb-body="' + i + '"]').value,
      }));
      if (value.some((v) => !v.subject || !v.body)) { errEl.textContent = "Sujet et corps obligatoires."; errEl.hidden = false; return; }
      try {
        await api("cockpit_settings", { method: "POST", headers: { Prefer: "resolution=merge-duplicates,return=minimal" }, body: JSON.stringify({ key: "onboarding_emails", value }) });
        onbCache = value;
        toast("Templates onboarding enregistrés ✓");
        closeModals();
      } catch (e) { errEl.textContent = e.message || "Erreur."; errEl.hidden = false; }
    });
    ovContent.addEventListener("click", (e) => {
      const lb = e.target.closest("[data-goto-lead]");
      if (lb) { focusLeadId = lb.dataset.gotoLead; switchTab("leads"); return; }
      const b = e.target.closest("[data-goto]");
      if (b) switchTab(b.dataset.goto);
    });

    // =========================================================
    // ============ MODULE 2 : AUDIENCE (analytics interne) =====
    // =========================================================
    const auContent = root.querySelector("[data-au-content]");
    const auPeriods = root.querySelector("[data-au-periods]");
    let auPeriod = "7d";

    auPeriods.addEventListener("click", (e) => {
      const b = e.target.closest("[data-period]"); if (!b) return;
      auPeriod = b.dataset.period;
      auPeriods.querySelectorAll("[data-period]").forEach((x) => x.className = "ck-pill" + (x.dataset.period === auPeriod ? " ck-pill-on" : ""));
      loadAudience();
    });

    function fmtNum(n) { return (Number(n) || 0).toLocaleString("fr-CH"); }
    function fmtDuration(secs) {
      const s = Math.round(secs || 0); if (s < 60) return s + " s";
      const m = Math.floor(s / 60); const r = s % 60; return m + " min " + (r ? r + " s" : "");
    }

    async function loadAudience() {
      const signal = freshSignal("audience");
      auContent.innerHTML = '<p class="mt-12 text-center text-sm text-ink-500">Chargement…</p>';
      try {
        const res = await api("rpc/cockpit_analytics", { method: "POST", body: JSON.stringify({ p_period: auPeriod }), signal });
        const data = await res.json();
        renderAudience(data);
      } catch (e) {
        if (isAbort(e)) return;
        auContent.innerHTML = '<p class="mt-12 text-center text-sm text-rose-400">Erreur : ' + esc(String(e)) + '</p>';
      }
    }

    function sparkline(points, w = 600, h = 80) {
      if (!points || !points.length) return '';
      const max = Math.max(1, ...points.map((p) => p.y));
      const dx = w / Math.max(1, points.length - 1);
      const ys = points.map((p, i) => [i * dx, h - (p.y / max) * (h - 6) - 3]);
      const path = ys.map(([x, y], i) => (i === 0 ? "M" : "L") + x.toFixed(1) + " " + y.toFixed(1)).join(" ");
      const fill = "M0 " + h + " L" + ys.map(([x, y]) => x.toFixed(1) + " " + y.toFixed(1)).join(" L") + " L" + w + " " + h + " Z";
      return '<svg viewBox="0 0 ' + w + ' ' + h + '" preserveAspectRatio="none" class="w-full" aria-hidden="true">' +
        '<path d="' + fill + '" class="ck-sparkfill" />' +
        '<path d="' + path + '" class="ck-sparkline" />' +
        '</svg>';
    }

    function renderAudience(data) {
      const s = data.stats || {};
      const kpiCard = (label, value, sub) =>
        '<div class="rounded-2xl border border-white/10 bg-white/[0.02] p-5">' +
        '<p class="text-xs uppercase tracking-wide text-ink-500">' + esc(label) + '</p>' +
        '<p class="mt-1 text-3xl font-semibold tracking-tight text-ink-50 tabular-nums">' + esc(value) + '</p>' +
        (sub ? '<p class="mt-1 text-xs text-ink-400">' + esc(sub) + '</p>' : '') +
        '</div>';

      const visitors = Number(s.visitors) || 0;
      const pageviews = Number(s.pageviews) || 0;
      const visits = Number(s.visits) || 0;
      const totaltime = Number(s.totaltime) || 0;
      const bounces = Number(s.bounces) || 0;
      const avgTime = visits > 0 ? Math.round(totaltime / visits) : 0;
      const bounceRate = visits > 0 ? Math.round((bounces / visits) * 100) : 0;

      const pvSeries = Array.isArray(data.series) ? data.series.map((p) => ({ x: p.x, y: Number(p.y) || 0 })) : [];

      const listSection = (items, mapper) => {
        if (!items || !items.length) return '<p class="text-sm text-ink-500">—</p>';
        const max = Math.max(...items.map((i) => Number(i.y) || 0));
        return '<ul class="space-y-1.5">' + items.slice(0, 8).map((it) => {
          const w = max > 0 ? Math.round((Number(it.y) / max) * 100) : 0;
          const label = mapper(it);
          return '<li class="relative overflow-hidden rounded-lg border border-white/[0.06] bg-white/[0.01] px-3 py-2">' +
            '<div class="absolute inset-y-0 left-0 bg-accent-500/15" style="width:' + w + '%"></div>' +
            '<div class="relative flex items-center justify-between text-xs">' +
            '<span class="truncate text-ink-200">' + label + '</span>' +
            '<span class="ml-3 shrink-0 tabular-nums text-ink-400">' + fmtNum(it.y) + '</span>' +
            '</div></li>';
        }).join("") + '</ul>';
      };

      const refLabel = (r) => r.x ? esc(r.x) : '<span class="text-ink-500">Direct</span>';
      const flag = (cc) => {
        if (!cc || cc.length !== 2) return "";
        return String.fromCodePoint(...cc.toUpperCase().split("").map((c) => 0x1F1E6 + c.charCodeAt(0) - 65));
      };

      const hasEvents = Array.isArray(data.events) && data.events.length > 0;

      auContent.innerHTML =
        '<div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">' +
        kpiCard("Visiteurs", fmtNum(visitors), "uniques / jour (anonymisation 24 h)") +
        kpiCard("Sessions", fmtNum(visits), null) +
        kpiCard("Pages vues", fmtNum(pageviews), null) +
        kpiCard("Temps moy.", fmtDuration(avgTime), bounceRate + "% rebond") +
        '</div>' +

        '<div class="mt-6 rounded-2xl border border-white/10 bg-white/[0.02] p-5">' +
        '<div class="flex items-center justify-between"><h3 class="text-sm font-semibold text-ink-50">Trafic</h3>' +
        '<p class="text-xs text-ink-500">Pages vues sur ' + esc(auPeriod) + '</p></div>' +
        '<div class="mt-3">' + sparkline(pvSeries) + '</div>' +
        '</div>' +

        '<div class="mt-6 grid grid-cols-1 gap-4 lg:grid-cols-2">' +
        '<div class="rounded-2xl border border-white/10 bg-white/[0.02] p-5">' +
        '<h3 class="mb-3 text-sm font-semibold text-ink-50">Pages les plus vues</h3>' +
        listSection(data.urls, (it) => esc(it.x || "/")) +
        '</div>' +
        '<div class="rounded-2xl border border-white/10 bg-white/[0.02] p-5">' +
        '<h3 class="mb-3 text-sm font-semibold text-ink-50">Sources</h3>' +
        listSection(data.referrers, refLabel) +
        '</div>' +
        '<div class="rounded-2xl border border-white/10 bg-white/[0.02] p-5">' +
        '<h3 class="mb-3 text-sm font-semibold text-ink-50">Pays</h3>' +
        listSection(data.countries, (it) => (flag(it.x) ? flag(it.x) + ' ' : '') + esc(it.x || "—")) +
        '</div>' +
        '<div class="rounded-2xl border border-white/10 bg-white/[0.02] p-5">' +
        '<h3 class="mb-3 text-sm font-semibold text-ink-50">Appareils & navigateurs</h3>' +
        '<div class="grid grid-cols-2 gap-3">' +
        '<div>' + listSection(data.devices, (it) => esc(it.x || "—")) + '</div>' +
        '<div>' + listSection(data.browsers, (it) => esc(it.x || "—")) + '</div>' +
        '</div></div>' +
        (hasEvents
          ? '<div class="rounded-2xl border border-white/10 bg-white/[0.02] p-5">' +
            '<h3 class="mb-3 text-sm font-semibold text-ink-50">Événements (conversions)</h3>' +
            listSection(data.events, (it) => esc(it.x || "—")) +
            '</div>'
          : '') +
        '</div>' +

        '<p class="mt-4 text-center text-xs text-ink-500">Mesure d\'audience interne · hébergée à Zurich (Supabase) · sans cookie, anonyme by design</p>';
    }

    // =========================================================
    // ============ MODULE 2B : ASSOS (provisionnement) =========
    // =========================================================
    const ogContent = root.querySelector("[data-og-content]");
    async function loadOrgs() {
      ogContent.innerHTML = '<p class="mt-12 text-center text-sm text-ink-500">Chargement…</p>';
      try {
        const res = await fn("cockpit-orgs");
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || "HTTP " + res.status);
        renderOrgs(data.orgs || []);
      } catch (e) {
        ogContent.innerHTML = '<p class="mt-12 text-center text-sm text-rose-400">Erreur : ' + esc(e.message || String(e)) + "</p>";
      }
    }
    function renderOrgs(orgs) {
      if (!orgs.length) {
        ogContent.innerHTML = '<p class="mt-12 text-center text-sm text-ink-500">Aucune asso provisionnée pour l\'instant.<br>Ouvrez un lead dans « Inscriptions » et cliquez « 🚀 Provisionner ».</p>';
        return;
      }
      ogContent.innerHTML = '<div class="mt-6 overflow-x-auto rounded-2xl border border-white/10 bg-white/[0.02]">' +
        '<table class="w-full text-sm">' +
        '<thead class="bg-white/[0.03] text-xs uppercase tracking-wide text-ink-500">' +
        '<tr><th scope="col" class="px-4 py-3 text-left">Association</th><th scope="col" class="px-4 py-3 text-left">Président</th><th scope="col" class="px-4 py-3 text-right">Membres</th><th scope="col" class="px-4 py-3 text-left">Dernière connexion</th><th scope="col" class="px-4 py-3 text-left">Statut</th><th scope="col" class="px-4 py-3"><span class="sr-only">Actions</span></th></tr></thead>' +
        '<tbody class="divide-y divide-white/[0.06]">' +
        orgs.map((o) =>
          '<tr data-org="' + esc(o.id) + '" data-org-active="' + (o.is_active ? "1" : "") + '" data-org-name="' + esc(o.name) + '" data-org-customer="' + esc(o.customer_id || "") + '">' +
          '<td class="px-4 py-3"><p class="font-semibold text-ink-50">' + esc(o.name) + '</p><p class="font-mono text-[11px] text-ink-500">' + esc(o.slug) + "</p></td>" +
          '<td class="px-4 py-3">' + (o.president
            ? '<p class="text-ink-200">' + esc(o.president.name) + '</p><p class="text-xs text-ink-500">' + esc(o.president.email) + "</p>"
            : '<span class="text-ink-500">—</span>') + "</td>" +
          '<td class="px-4 py-3 text-right tabular-nums text-ink-200">' + (o.member_count || 0) + "</td>" +
          (function () {
            const days = o.last_login ? (Date.now() - new Date(o.last_login)) / 86400000 : null;
            const c = days === null ? "#8b8b94" : days <= 7 ? "#4ade80" : days <= 30 ? "#fbbf24" : "#f87171";
            return '<td class="px-4 py-3 text-xs text-ink-400"><span class="mr-1.5 inline-block h-2 w-2 rounded-full align-middle" style="background:' + c + '"></span>' + (o.last_login ? fmtDate(o.last_login) : "jamais") + "</td>";
          })() +
          '<td class="px-4 py-3">' + (o.is_active
            ? '<span class="rounded-md bg-emerald-400/10 px-2 py-0.5 text-[11px] font-medium text-emerald-400">Active</span>'
            : '<span class="rounded-md bg-rose-400/10 px-2 py-0.5 text-[11px] font-medium text-rose-400">Suspendue</span>') + "</td>" +
          '<td class="px-4 py-3 text-right whitespace-nowrap">' +
          '<button type="button" data-org-detail class="text-xs text-accent-300 hover:text-accent-400">Détails</button>' +
          ' · <button type="button" data-org-toggle class="text-xs ' +
          (o.is_active ? "text-rose-400 hover:text-rose-300" : "text-emerald-400 hover:text-emerald-300") + '">' +
          (o.is_active ? "Suspendre" : "Réactiver") + "</button></td></tr>"
        ).join("") + "</tbody></table></div>";
    }
    async function toggleOrgDetail(tr) {
      const next = tr.nextElementSibling;
      if (next && next.dataset.orgDetail) { next.remove(); return; }
      const custId = tr.dataset.orgCustomer;
      const detail = document.createElement("tr");
      detail.dataset.orgDetail = "1";
      detail.innerHTML = '<td colspan="6" class="bg-white/[0.01] px-4 py-3 text-xs text-ink-500">Chargement…</td>';
      tr.after(detail);
      const cell = detail.firstElementChild;
      if (!custId) { cell.textContent = "Aucune fiche client liée — créez-la dans Facturation → Clients."; return; }
      try {
        const res = await api("invoices?customer_id=eq." + encodeURIComponent(custId) + "&select=total,status&limit=200");
        const invs = await res.json();
        const paid = invs.filter((i) => i.status === "paid").reduce((s, i) => s + (+i.total || 0), 0);
        const open = invs.filter((i) => i.status === "sent" || i.status === "overdue").reduce((s, i) => s + (+i.total || 0), 0);
        cell.innerHTML =
          '<span class="text-ink-300">' + invs.length + " facture(s)</span> · " +
          '<span class="text-emerald-400">' + fmtCHF(paid, "CHF") + " encaissé</span> · " +
          '<span class="text-amber-400">' + fmtCHF(open, "CHF") + " en cours</span> · " +
          '<button type="button" data-goto-billing class="text-accent-300 hover:text-accent-400">Ouvrir la facturation</button>';
      } catch { cell.textContent = "Erreur de chargement."; }
    }
    ogContent.addEventListener("click", async (e) => {
      if (e.target.closest("[data-goto-billing]")) { switchTab("billing"); return; }
      const det = e.target.closest("[data-org-detail]");
      if (det) { toggleOrgDetail(det.closest("[data-org]")); return; }
      const btn = e.target.closest("[data-org-toggle]"); if (!btn) return;
      const tr = btn.closest("[data-org]");
      const active = !!tr.dataset.orgActive;
      if (!confirm(active
        ? "Suspendre « " + tr.dataset.orgName + " » ?\nSes membres ne pourront plus utiliser l'app jusqu'à réactivation."
        : "Réactiver « " + tr.dataset.orgName + " » ?")) return;
      btn.disabled = true;
      try {
        const res = await fn("cockpit-orgs", { method: "PATCH", json: { org_id: tr.dataset.org, is_active: !active } });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || "HTTP " + res.status);
        toast(active ? "Asso suspendue." : "Asso réactivée ✓");
        loadOrgs();
      } catch (err) { toast("Échec : " + err.message, "error"); btn.disabled = false; }
    });
    root.querySelector("[data-og-refresh]").addEventListener("click", loadOrgs);

    // ----- Provisionnement depuis un lead -----
    async function provisionLead(lead) {
      if (!confirm("Provisionner « " + lead.asso_name + " » ?\n\nCela va créer :\n• l'association dans l'app Konclav\n• le compte président pour " + lead.email + " (mot de passe temporaire, à changer au 1er login)\n• la fiche client en facturation\n\nUn email avec les accès sera envoyé au président.")) return;
      try {
        const res = await fn("cockpit-orgs", { method: "POST", json: { lead_id: lead.id } });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || "HTTP " + res.status);
        lead.provisioned_org_id = data.org.id;
        lead.status = "converted";
        renderLeads();
        showProvisionResult(lead, data);
      } catch (err) { toast("Provisionnement échoué : " + err.message, "error"); }
    }
    function showProvisionResult(lead, data) {
      const mb = root.querySelector("[data-pv-body]");
      mb.innerHTML =
        '<p class="flex items-center gap-2 text-emerald-400"><span class="h-2 w-2 rounded-full bg-emerald-400"></span>« ' + esc(data.org.name) + " » est provisionnée.</p>" +
        '<table class="mt-4 w-full text-xs"><tbody>' +
        '<tr><td class="py-1.5 pr-3 text-ink-500">Identifiant</td><td class="py-1.5 font-mono text-ink-50">' + esc(lead.email) + "</td></tr>" +
        '<tr><td class="py-1.5 pr-3 text-ink-500">Mot de passe temporaire</td><td class="py-1.5 font-mono text-base text-ink-50">' + esc(data.temp_password) + "</td></tr>" +
        "</tbody></table>" +
        (data.email_sent
          ? '<p class="mt-3 text-xs text-emerald-400">Email d\'accès envoyé au président ✓</p>'
          : '<p class="mt-3 text-xs text-rose-400">⚠ L\'email n\'est pas parti — transmettez ces accès manuellement.</p>') +
        '<p class="mt-2 text-xs text-ink-500">Ce mot de passe ne sera plus jamais affiché. Le président devra le changer à sa première connexion.</p>';
      openModal("provision");
    }

    // =========================================================
    // ============ MODULE 2C : EMAILS CRM ======================
    // =========================================================
    const EMAIL_TEMPLATES = [
      { label: "Premier contact", subject: "Votre demande pour {asso} — Konclav",
        body: "Bonjour {prenom},\n\nMerci pour votre demande concernant {asso} !\n\nJe suis Kévin, je développe Konclav — l'espace privé pour les associations suisses. J'aimerais comprendre votre fonctionnement actuel pour vous montrer ce que l'app peut vous apporter concrètement.\n\nAuriez-vous 20 minutes cette semaine pour un appel ?\n\nBonne journée,\nKévin — Konclav" },
      { label: "Relance douce", subject: "Re : votre demande pour {asso}",
        body: "Bonjour {prenom},\n\nJe me permets de revenir vers vous concernant votre demande pour {asso}.\n\nSi vous avez des questions sur Konclav (fonctionnement, prix, sécurité des données), j'y réponds volontiers — par email ou par téléphone, comme vous préférez.\n\nBonne journée,\nKévin — Konclav" },
      { label: "Infos pratiques", subject: "Konclav pour {asso} — les infos essentielles",
        body: "Bonjour {prenom},\n\nVoici l'essentiel sur Konclav en quelques lignes :\n\n• Un espace 100% privé pour {asso} : tâches, agenda, documents, membres\n• Hébergé en Suisse (Zurich), conforme nLPD\n• Essai 14 jours sans engagement\n\nJe vous accompagne personnellement pour la mise en route (environ 30 minutes).\n\nDes questions ? Répondez simplement à cet email.\n\nBonne journée,\nKévin — Konclav" },
      { label: "Refus poli", subject: "Votre demande pour {asso}",
        body: "Bonjour {prenom},\n\nMerci pour l'intérêt que vous portez à Konclav.\n\nAprès examen, je ne pense pas que l'app soit le bon outil pour {asso} aujourd'hui — je préfère vous le dire honnêtement plutôt que de vous faire perdre du temps.\n\nJe garde vos coordonnées : si l'offre évolue dans une direction qui vous correspond, je reviendrai vers vous.\n\nBonne continuation,\nKévin — Konclav" },
    ];
    let emailLeadId = null;
    const fillTemplate = (str, lead) => str.replace(/\{prenom\}/g, lead.first_name || "").replace(/\{asso\}/g, lead.asso_name || "");

    // Modèles éditables : surcharges stockées dans cockpit_settings (clé email_templates)
    let tplCache = null;
    async function getTemplates() {
      if (tplCache) return tplCache;
      try {
        const res = await api("cockpit_settings?key=eq.email_templates&select=value");
        const rows = await res.json();
        const saved = rows[0] && Array.isArray(rows[0].value) ? rows[0].value : null;
        tplCache = saved && saved.length === EMAIL_TEMPLATES.length
          ? EMAIL_TEMPLATES.map((t, i) => ({ label: t.label, subject: saved[i].subject || t.subject, body: saved[i].body || t.body }))
          : EMAIL_TEMPLATES.slice();
      } catch { tplCache = EMAIL_TEMPLATES.slice(); }
      return tplCache;
    }
    async function openEmailModal(lead) {
      emailLeadId = lead.id;
      root.querySelector("[data-em-to]").textContent = lead.email;
      const tpls = await getTemplates();
      const sel = root.querySelector("[data-em-template]");
      sel.innerHTML = tpls.map((t, i) => '<option value="' + i + '">' + esc(t.label) + "</option>").join("");
      const apply = () => {
        const t = tpls[+sel.value || 0];
        root.querySelector("[data-em-subject]").value = fillTemplate(t.subject, lead);
        root.querySelector("[data-em-body]").value = fillTemplate(t.body, lead);
      };
      sel.onchange = apply;
      apply();
      root.querySelector("[data-em-error]").hidden = true;
      openModal("email");
    }
    root.querySelector("[data-em-edit-tpl]").addEventListener("click", openTemplatesEditor);
    async function openTemplatesEditor() {
      const tpls = await getTemplates();
      root.querySelector("[data-tpl-list]").innerHTML = tpls.map((t, i) =>
        '<div class="rounded-xl border border-white/[0.06] bg-white/[0.01] p-3">' +
        '<p class="mb-2 text-xs font-semibold text-ink-50">' + esc(t.label) + "</p>" +
        '<input data-tpl-subject="' + i + '" value="' + esc(t.subject) + '" class="ck-input mb-2" aria-label="Sujet" />' +
        '<textarea data-tpl-body="' + i + '" rows="6" class="ck-input" aria-label="Corps">' + esc(t.body) + "</textarea>" +
        "</div>").join("");
      openModal("templates");
    }
    root.querySelector("[data-tpl-save]").addEventListener("click", async () => {
      const tpls = await getTemplates();
      const value = tpls.map((t, i) => ({
        label: t.label,
        subject: root.querySelector('[data-tpl-subject="' + i + '"]').value,
        body: root.querySelector('[data-tpl-body="' + i + '"]').value,
      }));
      try {
        await api("cockpit_settings", { method: "POST", headers: { Prefer: "resolution=merge-duplicates,return=minimal" }, body: JSON.stringify({ key: "email_templates", value }) });
        tplCache = value;
        toast("Modèles enregistrés ✓");
        closeModals();
      } catch (e) { toast("Échec : " + e.message, "error"); }
    });

    // ----- Email groupé (broadcast segmenté) -----
    const SEGMENTS = [
      { value: "leads_active", label: "Leads actifs (nouveau + contacté)", count: () => leads.filter((l) => l.status === "new" || l.status === "contacted").length },
      { value: "leads_converted", label: "Leads convertis", count: () => leads.filter((l) => l.status === "converted").length },
      { value: "customers", label: "Clients (facturation)", count: () => customers.length },
    ];
    root.querySelector("[data-ck-broadcast]").addEventListener("click", async () => {
      if (!leads.length) { try { const r = await api("leads?select=*&order=created_at.desc"); leads = await r.json(); } catch {} }
      if (!customers.length) { try { const r = await api("customers?select=*&order=asso_name.asc"); customers = await r.json(); } catch {} }
      const sel = root.querySelector("[data-bb-segment]");
      sel.innerHTML = SEGMENTS.map((s) => '<option value="' + s.value + '">' + esc(s.label) + "</option>").join("");
      const upd = () => {
        const s = SEGMENTS.find((x) => x.value === sel.value);
        root.querySelector("[data-bb-count]").textContent = s ? s.count() + " destinataire(s)" : "";
      };
      sel.onchange = upd;
      upd();
      root.querySelector("[data-bb-subject]").value = "";
      root.querySelector("[data-bb-body]").value = "";
      root.querySelector("[data-bb-error]").hidden = true;
      openModal("broadcast");
    });
    root.querySelector("[data-bb-form]").addEventListener("submit", async (e) => {
      e.preventDefault();
      const btn = root.querySelector("[data-bb-send]");
      const errEl = root.querySelector("[data-bb-error]");
      const seg = root.querySelector("[data-bb-segment]").value;
      const s = SEGMENTS.find((x) => x.value === seg);
      if (!confirm("Envoyer cet email à " + (s ? s.count() : "?") + " destinataire(s) ?\nChacun reçoit un email individuel (pas de copie visible).")) return;
      btn.disabled = true; errEl.hidden = true;
      try {
        const res = await fn("cockpit-broadcast", { method: "POST", json: {
          segment: seg,
          subject: root.querySelector("[data-bb-subject]").value.trim(),
          body: root.querySelector("[data-bb-body]").value.trim(),
        }});
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || "HTTP " + res.status);
        closeModals();
        toast(data.sent + " email(s) envoyé(s) ✓" + (data.failed ? " — " + data.failed + " échec(s)" : ""));
      } catch (err) { errEl.textContent = err.message || "Envoi échoué."; errEl.hidden = false; }
      finally { btn.disabled = false; }
    });
    root.querySelector("[data-em-form]").addEventListener("submit", async (e) => {
      e.preventDefault();
      const btn = root.querySelector("[data-em-send]");
      const errEl = root.querySelector("[data-em-error]");
      btn.disabled = true; errEl.hidden = true;
      try {
        const res = await fn("cockpit-send-email", { method: "POST", json: {
          lead_id: emailLeadId,
          subject: root.querySelector("[data-em-subject]").value.trim(),
          body: root.querySelector("[data-em-body]").value.trim(),
        }});
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || "Envoi échoué");
        closeModals();
        toast("Email envoyé ✓");
        const el = listEl.querySelector('[data-lead="' + emailLeadId + '"] [data-lead-events]');
        if (el) { delete el.dataset.loaded; const card = el.closest("[data-lead]"); if (card && card.open) loadLeadEvents(emailLeadId, el); }
      } catch (err) { errEl.textContent = err.message || "Envoi échoué."; errEl.hidden = false; }
      finally { btn.disabled = false; }
    });

    // =========================================================
    // ============ MODULE 3 : FACTURATION ======================
    // =========================================================
    let customers = [];
    let invoicesList = [];
    const biContent = root.querySelector("[data-bi-content]");
    const bcContent = root.querySelector("[data-bc-content]");

    // ----- Clients -----
    async function loadCustomers() {
      const signal = freshSignal("customers");
      bcContent.innerHTML = '<p class="mt-12 text-center text-sm text-ink-500">Chargement…</p>';
      try {
        const res = await api("customers?select=*&order=asso_name.asc", { signal });
        customers = await res.json();
        renderCustomers();
      } catch (e) {
        if (isAbort(e)) return;
        bcContent.innerHTML = '<p class="mt-12 text-center text-sm text-rose-400">Erreur : ' + esc(String(e)) + '</p>';
      }
    }
    function renderCustomers() {
      if (!customers.length) {
        bcContent.innerHTML = '<p class="mt-12 text-center text-sm text-ink-500">Aucun client. Cliquez sur « Nouveau client » pour démarrer.</p>';
        return;
      }
      bcContent.innerHTML = '<div class="mt-6 overflow-hidden rounded-2xl border border-white/10 bg-white/[0.02]">' +
        '<table class="w-full text-sm">' +
        '<thead class="bg-white/[0.03] text-xs uppercase tracking-wide text-ink-500">' +
