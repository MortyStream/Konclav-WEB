          '<td class="px-4 py-3"><p class="text-ink-200">' + esc(c.contact_name) + '</p><p class="text-xs text-ink-500"><a href="mailto:' + esc(c.contact_email) + '" class="hover:text-accent-300">' + esc(c.contact_email) + '</a></p></td>' +
