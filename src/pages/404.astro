---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Page introuvable — Konclav"
  description="Cette page n'existe pas ou plus."
  noindex={true}
>
  <Navbar />
  <main>
    <section
      class="relative isolate flex min-h-[80vh] items-center overflow-hidden px-6 py-32"
    >
      <div
        aria-hidden="true"
        class="pointer-events-none absolute left-1/2 top-1/2 -z-10 h-[500px] w-[800px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-15 blur-3xl"
        style="background: radial-gradient(closest-side, #5e6ad2, transparent 70%);"
      >
      </div>

      <div class="mx-auto flex max-w-2xl flex-col items-center text-center">
        <div
          data-reveal
          class="mb-8 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-3 py-1 text-xs text-ink-400"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-accent-500"></span>
          Erreur 404
        </div>

        <p
          data-reveal
          class="bg-gradient-to-b from-ink-50 to-ink-500 bg-clip-text text-7xl font-semibold tracking-tight text-transparent sm:text-8xl md:text-9xl"
        >
          404
        </p>

        <h1
          data-reveal
          class="mt-6 text-balance text-2xl font-semibold tracking-tight text-ink-50 sm:text-3xl"
        >
          Cette page n'existe pas (ou plus).
        </h1>
        <p
          data-reveal
          class="mt-4 max-w-md text-pretty text-base leading-relaxed text-ink-400"
        >
          Le lien a peut-être bougé, ou n'a jamais existé. Aucun stress — on
          vous remet sur les rails.
        </p>

        <div
          data-reveal
          class="mt-10 flex flex-col items-center gap-3 sm:flex-row"
        >
          <a
            href="/"
            class="inline-flex items-center justify-center gap-1.5 rounded-lg bg-accent-500 px-5 py-3 text-sm font-medium text-white transition-colors hover:bg-accent-400"
          >
            Retour à l'accueil
            <svg
              viewBox="0 0 16 16"
              fill="none"
              class="h-4 w-4"
              aria-hidden="true"
            >
              <path
                d="M3.5 8h9m0 0L8 3.5M12.5 8 8 12.5"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </a>
          <a
            href="/demo"
            class="inline-flex items-center justify-center rounded-lg border border-white/10 bg-white/[0.02] px-5 py-3 text-sm font-medium text-ink-50 transition-colors hover:border-white/20 hover:bg-white/[0.04]"
          >
            Voir la démo
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
