---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import PhoneShot from "../components/PhoneShot.astro";

const screens = [
  { src: "/app/tache.webp", alt: "Konclav — détail d'une tâche avec validation" },
  { src: "/app/agenda-semaine.webp", alt: "Konclav — agenda, vue semaine des entraînements" },
  { src: "/app/agenda-mois.webp", alt: "Konclav — agenda, vue mois" },
  { src: "/app/documents.webp", alt: "Konclav — documents et dossiers de l'association" },
  { src: "/app/statuts.webp", alt: "Konclav — statuts et règlements" },
  { src: "/app/annuaire.webp", alt: "Konclav — annuaire des membres et rôles" },
  { src: "/app/association.webp", alt: "Konclav — espace association : cotisations, notes de frais" },
];

const captions = [
  {
    label: "Tâches & validations",
    description: "Kanban, attribution, deadlines — et un circuit de validation pour les dépenses.",
  },
  {
    label: "Agenda partagé",
    description: "Vues mois et semaine, événements par équipe, lieux et participants.",
  },
  {
    label: "Documents",
    description: "Statuts, PV, contrats, règlements — classés par pôle, recherche instantanée.",
  },
  {
    label: "Vie associative",
    description: "Annuaire et rôles, cotisations, notes de frais, sondages, réunions.",
  },
];
---

<Layout
  title="Inscrire mon asso — Konclav"
  description="Konclav en images. Présentez-nous votre association pour demander un accès — on étudie chaque demande sous 48h ouvrées."
>
  <Navbar />
  <main id="main">
    <!-- Mini hero -->
    <section class="relative isolate overflow-hidden px-6 pt-40 pb-8 sm:pt-48">
      <div class="mx-auto max-w-3xl text-center">
        <div
          data-reveal
          class="mb-8 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-3 py-1 text-xs text-ink-400"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-accent-500"></span>
          Inscription
        </div>
        <h1
          data-reveal
          data-split-text
          class="display-hero text-balance text-ink-50"
        >
          Toute la vie associative, dans une seule app.
        </h1>
        <p
          data-reveal
          class="mx-auto mt-6 max-w-xl text-pretty text-base leading-relaxed text-ink-400 sm:text-lg"
        >
          Découvrez Konclav en images. Si l'app vous parle, présentez-nous
          votre asso — on étudie chaque demande pour s'assurer que Konclav
          vous correspond.
        </p>
      </div>
    </section>

    <!-- Phone cluster -->
    <section class="relative isolate overflow-hidden px-6 pb-20">
      <div
        aria-hidden="true"
        data-parallax="0.08"
        class="pointer-events-none absolute left-1/2 top-1/2 -z-10 h-[800px] w-[1100px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-40 blur-3xl"
        style="background: radial-gradient(ellipse 60% 50% at center, rgba(94,106,210,0.30), transparent 70%);"
      >
      </div>

      <div class="mx-auto max-w-7xl">
        <div
          class="-mx-6 flex snap-x snap-mandatory gap-6 overflow-x-auto px-6 pb-4 no-scrollbar [&>*]:snap-always sm:gap-8"
        >
          {
            screens.map((s, i) => (
              <PhoneShot src={s.src} alt={s.alt} delay={i * 90} priority={i === 0} />
            ))
          }
        </div>

        <p
          class="mt-4 flex items-center justify-center gap-1.5 text-xs font-medium text-ink-500"
          aria-hidden="true"
        >
          Glissez pour explorer les écrans
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </p>
      </div>
    </section>

    <!-- Captions -->
    <section class="relative px-6 pb-32">
      <div class="mx-auto max-w-6xl">
        <div class="grid gap-x-8 gap-y-6 sm:grid-cols-2 lg:grid-cols-4">
          {
            captions.map((c, i) => (
              <div
                data-reveal
                style={`transition-delay: ${i * 80}ms`}
                class="text-center md:text-left"
              >
                <p class="text-sm font-medium text-ink-50">{c.label}</p>
                <p class="mt-1.5 text-xs leading-relaxed text-ink-400">
                  {c.description}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Demande d'accès : Google Form -->
    <section
      id="reserver"
      class="relative border-t border-white/[0.06] px-6 py-24 sm:py-32"
    >
      <div class="mx-auto max-w-4xl">
        <div data-reveal class="mx-auto max-w-2xl text-center">
          <p class="text-xs font-medium uppercase tracking-[0.18em] text-accent-400">Inscrire mon asso</p>
          <h2
            data-split-text
            class="display-section mt-4 text-balance text-ink-50"
          >
            Présentez-nous votre asso.
          </h2>
          <p class="mx-auto mt-5 max-w-xl text-pretty text-base leading-relaxed text-ink-400">
            Un court formulaire pour qu'on s'assure que Konclav vous
            correspond. On revient vers vous sous 48h ouvrées avec un accès
            ou une réponse argumentée.
          </p>
        </div>

        <!-- Ce qu'on regarde -->
        <ul
          data-reveal
          class="mx-auto mt-10 grid max-w-3xl gap-3 sm:grid-cols-3"
        >
          {[
            "Taille et nature de votre asso",
            "Vos outils actuels et leurs limites",
            "Vos contraintes (budget, RGPD, etc.)",
          ].map((item) => (
            <li class="flex items-start gap-2.5 rounded-xl border border-white/[0.06] bg-white/[0.02] p-4">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 h-4 w-4 shrink-0 text-accent-400" aria-hidden="true">
                <path d="m3.5 8.5 3 3 6-7" />
              </svg>
              <span class="text-sm leading-snug text-ink-50">{item}</span>
            </li>
          ))}
        </ul>

        <!-- CTA vers Google Form (s'ouvre dans un nouvel onglet) -->
        <div
          data-reveal
          class="mt-12 flex flex-col items-center gap-4"
        >
          <a
            href="https://docs.google.com/forms/d/e/1FAIpQLSexpAosU928HE5nSZbg1pFht-JEKuaS4X_0G9JrEtm-R9zUsw/viewform"
            data-join-open
            class="cta-shimmer group/cta inline-flex items-center justify-center gap-1.5 rounded-xl bg-accent-500 px-7 py-4 text-sm font-semibold text-white shadow-[var(--shadow-cta)] transition-colors hover:bg-accent-400"
          >
            S'inscrire
            <svg
              viewBox="0 0 16 16"
              fill="none"
              class="h-4 w-4 transition-transform duration-300 ease-out group-hover/cta:translate-x-0.5"
              aria-hidden="true"
            >
              <path d="M3.5 8h9m0 0L8 3.5M12.5 8 8 12.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
          <p class="text-xs text-ink-500">
            2 minutes · Réponse sous 48h ouvrées · Sans engagement
          </p>
        </div>

        <!-- Fallback mail -->
        <p data-reveal class="mt-10 text-center text-sm text-ink-400">
          Vous préférez écrire directement ?{" "}
          <a
            href="mailto:contact@konclav.ch?subject=Demande%20d%27acc%C3%A8s%20Konclav"
            class="link-underline font-medium text-ink-50"
          >
            contact@konclav.ch
          </a>
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
