---
import "../styles/global.css";
import "@fontsource/inter/latin-400.css";
import "@fontsource/inter/latin-500.css";
import "@fontsource/inter/latin-600.css";
import "@fontsource/inter/latin-700.css";
import "@fontsource/inter/latin-300-italic.css";
import "@fontsource/inter/latin-400-italic.css";
import JoinModal from "../components/JoinModal.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title = "Konclav — L'intranet privé pensé pour les associations",
  description = "Konclav est un intranet privé mobile pour les associations suisses. Tâches, agenda partagé, documents. Hébergé en Suisse, sans pub ni revente de données.",
  image = "/og.jpg",
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
const imageUrl = new URL(image, Astro.site ?? Astro.url.origin).toString();
---

<!doctype html>
<html lang="fr-CH">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#08090a" />
    <meta name="color-scheme" content="dark" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_CH" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Konclav — l'intranet privé pour associations suisses" />
    <meta property="og:site_name" content="Konclav" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content="Konclav — l'intranet privé pour associations suisses" />

    <!-- JSON-LD: Organization + WebSite (global) -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": new URL("/#organization", Astro.site ?? Astro.url.origin).toString(),
          "name": "Konclav",
          "url": (Astro.site ?? Astro.url.origin).toString(),
          "logo": new URL("/favicon-192.png", Astro.site ?? Astro.url.origin).toString(),
          "description": "Intranet privé mobile pour les associations suisses.",
          "areaServed": "CH"
        },
        {
          "@type": "WebSite",
          "@id": new URL("/#website", Astro.site ?? Astro.url.origin).toString(),
          "url": (Astro.site ?? Astro.url.origin).toString(),
          "name": "Konclav",
          "description": "Konclav — l'intranet privé pensé pour les associations suisses.",
          "publisher": { "@id": new URL("/#organization", Astro.site ?? Astro.url.origin).toString() },
          "inLanguage": "fr-CH"
        }
      ]
    })} />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://cloud.umami.is" crossorigin />

    <!-- Umami — mesure d'audience sans cookie -->
    <script
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="e72a2f9e-8a7e-42ad-9062-4488bcd0a0c9"
    ></script>

    <noscript>
      <style>
        [data-reveal],
        [data-split-text] .word { opacity: 1 !important; transform: none !important; }
      </style>
    </noscript>

    <title>{title}</title>
  </head>
  <body class="text-ink-50 font-sans antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-accent-500 focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-white"
    >
      Aller au contenu
    </a>
    <div aria-hidden="true" class="aurora-global"></div>
    <slot />
    <JoinModal />

    <script is:inline>
      (function () {
        const reducedMQ = window.matchMedia('(prefers-reduced-motion: reduce)');
        let reduced = reducedMQ.matches;
        if (reducedMQ.addEventListener) reducedMQ.addEventListener('change', (e) => { reduced = e.matches; });
        const supportsHover = window.matchMedia('(hover: hover)').matches;

        // Split-text — wrap text nodes in <span class="word"> while preserving nested elements (e.g. .italic-display)
        document.querySelectorAll('[data-split-text]').forEach((el) => {
          let wi = 0;
          const wrapText = (node) => {
            const text = node.nodeValue || '';
            if (!text.trim()) return null;
            const frag = document.createDocumentFragment();
            text.split(/(\s+)/).forEach((tok) => {
              if (!tok) return;
              if (/^\s+$/.test(tok)) { frag.appendChild(document.createTextNode(tok)); return; }
              const span = document.createElement('span');
              span.className = 'word';
              span.style.setProperty('--word-i', wi++);
              span.textContent = tok;
              frag.appendChild(span);
            });
            return frag;
          };
          const walk = (parent) => {
            Array.from(parent.childNodes).forEach((n) => {
              if (n.nodeType === 3) {
                const f = wrapText(n);
                if (f) parent.replaceChild(f, n);
              } else if (n.nodeType === 1 && !n.classList.contains('word') && !n.classList.contains('italic-display')) {
                walk(n);
              }
            });
          };
          walk(el);
        });

        // Reveal au scroll (toggle .is-visible)
        const revealEls = document.querySelectorAll('[data-reveal], [data-split-text], [data-draw]');
        if (revealEls.length) {
          if (reduced || !('IntersectionObserver' in window)) {
            revealEls.forEach((el) => el.classList.add('is-visible'));
          } else {
            const io = new IntersectionObserver(
              (entries) => {
                for (const entry of entries) {
                  if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                    io.unobserve(entry.target);
                  }
                }
              },
              { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
            );
            revealEls.forEach((el) => io.observe(el));
          }
        }

        // SVG draw-on-scroll — compute each path's total length so CSS can dash it
        document.querySelectorAll('[data-draw]').forEach((wrap) => {
          wrap.querySelectorAll('path').forEach((p) => {
            if (typeof p.getTotalLength === 'function') {
              p.style.setProperty('--len', p.getTotalLength());
            }
          });
        });

        // Cursor spotlight — délégué sur document
        if (supportsHover && !reduced) {
          document.addEventListener('mousemove', (e) => {
            const target = e.target && e.target.closest
              ? e.target.closest('[data-spotlight]')
              : null;
            if (!target) return;
            const rect = target.getBoundingClientRect();
            target.style.setProperty('--mx', e.clientX - rect.left + 'px');
            target.style.setProperty('--my', e.clientY - rect.top + 'px');
          }, { passive: true });
        }

        // Parallax — éléments avec data-parallax="0.3" se translatent au scroll
        const parallaxEls = document.querySelectorAll('[data-parallax]');
        if (parallaxEls.length && !reduced) {
          let ticking = false;
          const update = () => {
            const sy = window.scrollY;
            parallaxEls.forEach((el) => {
              const speed = parseFloat(el.dataset.parallax || '0.3');
              el.style.setProperty('--py', (sy * speed * -1) + 'px');
            });
            ticking = false;
          };
          window.addEventListener('scroll', () => {
            if (!ticking) {
              requestAnimationFrame(update);
              ticking = true;
            }
          }, { passive: true });
          update();
        }

        // Magnetic — boutons attirent le curseur dans un rayon de 100px
        if (supportsHover && !reduced) {
          document.querySelectorAll('[data-magnetic]').forEach((btn) => {
            const radius = 110;
            const strength = 0.32;
            const reset = () => { btn.style.transform = ''; };
            btn.addEventListener('mousemove', (e) => {
              const rect = btn.getBoundingClientRect();
              const cx = rect.left + rect.width / 2;
              const cy = rect.top + rect.height / 2;
              const dx = e.clientX - cx;
              const dy = e.clientY - cy;
              const dist = Math.hypot(dx, dy);
              if (dist < radius) {
                btn.style.transform = `translate3d(${dx * strength}px, ${dy * strength}px, 0)`;
              } else {
                reset();
              }
            });
            btn.addEventListener('mouseleave', reset);
            btn.addEventListener('blur', reset);
          });
        }

        // Tilt 3D — cards qui s'inclinent vers le curseur (max 5°)
        if (supportsHover && !reduced) {
          document.querySelectorAll('[data-tilt]').forEach((el) => {
            const max = 5;
            const reset = () => {
              el.style.setProperty('--tx', '0deg');
              el.style.setProperty('--ty', '0deg');
            };
            el.addEventListener('mousemove', (e) => {
              const rect = el.getBoundingClientRect();
              const px = (e.clientX - rect.left) / rect.width;
              const py = (e.clientY - rect.top) / rect.height;
              const ry = (px - 0.5) * max * 2;
              const rx = (0.5 - py) * max * 2;
              el.style.setProperty('--ty', ry.toFixed(2) + 'deg');
              el.style.setProperty('--tx', rx.toFixed(2) + 'deg');
            });
            el.addEventListener('mouseleave', reset);
          });
        }

        // Nav scroll shadow
        const nav = document.querySelector('header[data-nav]');
        if (nav) {
          const onScroll = () => {
            if (window.scrollY > 8) nav.classList.add('nav-scrolled');
            else nav.classList.remove('nav-scrolled');
          };
          onScroll();
          window.addEventListener('scroll', onScroll, { passive: true });
        }

        // Mobile menu drawer (a11y: focus trap, ESC close, body scroll lock)
        const menuToggle = document.querySelector('[data-menu-toggle]');
        const menuPanel = document.querySelector('[data-menu-panel]');
        const menuClose = document.querySelector('[data-menu-close]');
        if (menuToggle && menuPanel) {
          const openMenu = () => {
            menuPanel.classList.remove('hidden');
            menuPanel.removeAttribute('inert');
            menuPanel.setAttribute('aria-hidden', 'false');
            menuToggle.setAttribute('aria-expanded', 'true');
            document.body.style.overflow = 'hidden';
            const firstFocusable = menuPanel.querySelector('a, button');
            if (firstFocusable) firstFocusable.focus();
          };
          const closeMenu = () => {
            menuPanel.classList.add('hidden');
            menuPanel.setAttribute('inert', '');
            menuPanel.setAttribute('aria-hidden', 'true');
            menuToggle.setAttribute('aria-expanded', 'false');
            document.body.style.overflow = '';
            menuToggle.focus();
          };
          menuToggle.addEventListener('click', () => {
            if (menuPanel.classList.contains('hidden')) openMenu();
            else closeMenu();
          });
          menuClose?.addEventListener('click', closeMenu);
          document.addEventListener('keydown', (e) => {
            if (menuPanel.classList.contains('hidden')) return;
            if (e.key === 'Escape') { closeMenu(); return; }
            if (e.key === 'Tab') {
              const f = menuPanel.querySelectorAll('a[href], button:not([disabled])');
              if (!f.length) return;
              const first = f[0];
              const last = f[f.length - 1];
              if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
              else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
            }
          });
          menuPanel.querySelectorAll('a').forEach((a) => {
            a.addEventListener('click', closeMenu);
          });
        }

        // V2 — Bento mouse-position (--mx/--my for inner glow)
        if (supportsHover && !reduced) {
          document.querySelectorAll('.bento').forEach((card) => {
            card.addEventListener('mousemove', (e) => {
              const rect = card.getBoundingClientRect();
              const mx = ((e.clientX - rect.left) / rect.width) * 100;
              const my = ((e.clientY - rect.top) / rect.height) * 100;
              card.style.setProperty('--mx', mx + '%');
              card.style.setProperty('--my', my + '%');
            }, { passive: true });
          });
        }

      })();
    </script>
  </body>
</html>
