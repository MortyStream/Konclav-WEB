---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Konclav — L'intranet privé pensé pour les associations",
  description = "Konclav est un intranet privé mobile pour les associations suisses. Tâches, agenda partagé, documents. Hébergé en UE, sans tracker.",
  image = "/og.png",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
const imageUrl = new URL(image, Astro.site ?? Astro.url.origin).toString();
---

<!doctype html>
<html lang="fr-CH" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#08090a" />
    <meta name="color-scheme" content="dark" />
    <link rel="canonical" href={canonical} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_CH" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Konclav" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    />
    <title>{title}</title>
  </head>
  <body class="bg-ink-950 text-ink-50 font-sans antialiased">
    <slot />

    <script is:inline>
      (function () {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const supportsHover = window.matchMedia('(hover: hover)').matches;

        // Split-text — wrap words in <span class="word"> so CSS stagger can animate them
        document.querySelectorAll('[data-split-text]').forEach((el) => {
          const text = (el.textContent || '').trim();
          if (!text) return;
          const words = text.split(/\s+/);
          el.innerHTML = words
            .map((w, i) => `<span class="word" style="--word-i:${i}">${w}</span>`)
            .join(' ');
        });

        // Reveal au scroll (toggle .is-visible)
        const revealEls = document.querySelectorAll('[data-reveal], [data-split-text], [data-draw]');
        if (revealEls.length) {
          if (reduced || !('IntersectionObserver' in window)) {
            revealEls.forEach((el) => el.classList.add('is-visible'));
          } else {
            const io = new IntersectionObserver(
              (entries) => {
                for (const entry of entries) {
                  if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                    io.unobserve(entry.target);
                  }
                }
              },
              { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
            );
            revealEls.forEach((el) => io.observe(el));
          }
        }

        // SVG draw-on-scroll — compute each path's total length so CSS can dash it
        document.querySelectorAll('[data-draw]').forEach((wrap) => {
          wrap.querySelectorAll('path').forEach((p) => {
            if (typeof p.getTotalLength === 'function') {
              p.style.setProperty('--len', p.getTotalLength());
            }
          });
        });

        // Cursor spotlight — délégué sur document
        if (supportsHover && !reduced) {
          document.addEventListener('mousemove', (e) => {
            const target = e.target && e.target.closest
              ? e.target.closest('[data-spotlight]')
              : null;
            if (!target) return;
            const rect = target.getBoundingClientRect();
            target.style.setProperty('--mx', e.clientX - rect.left + 'px');
            target.style.setProperty('--my', e.clientY - rect.top + 'px');
          }, { passive: true });
        }

        // Cursor glow — gradient qui suit la souris sur les sections marquées
        const glowEls = Array.from(document.querySelectorAll('[data-cursor-glow]'));
        if (glowEls.length && supportsHover && !reduced) {
          document.addEventListener('mousemove', (e) => {
            for (const el of glowEls) {
              const rect = el.getBoundingClientRect();
              if (e.clientY < rect.top - 240 || e.clientY > rect.bottom + 240) continue;
              const x = ((e.clientX - rect.left) / rect.width) * 100;
              const y = ((e.clientY - rect.top) / rect.height) * 100;
              el.style.setProperty('--gx', x + '%');
              el.style.setProperty('--gy', y + '%');
            }
          }, { passive: true });
        }

        // Parallax — éléments avec data-parallax="0.3" se translatent au scroll
        const parallaxEls = document.querySelectorAll('[data-parallax]');
        if (parallaxEls.length && !reduced) {
          let ticking = false;
          const update = () => {
            const sy = window.scrollY;
            parallaxEls.forEach((el) => {
              const speed = parseFloat(el.dataset.parallax || '0.3');
              el.style.setProperty('--py', (sy * speed * -1) + 'px');
            });
            ticking = false;
          };
          window.addEventListener('scroll', () => {
            if (!ticking) {
              requestAnimationFrame(update);
              ticking = true;
            }
          }, { passive: true });
          update();
        }

        // Magnetic — boutons attirent le curseur dans un rayon de 100px
        if (supportsHover && !reduced) {
          document.querySelectorAll('[data-magnetic]').forEach((btn) => {
            const radius = 110;
            const strength = 0.32;
            const reset = () => { btn.style.transform = ''; };
            btn.addEventListener('mousemove', (e) => {
              const rect = btn.getBoundingClientRect();
              const cx = rect.left + rect.width / 2;
              const cy = rect.top + rect.height / 2;
              const dx = e.clientX - cx;
              const dy = e.clientY - cy;
              const dist = Math.hypot(dx, dy);
              if (dist < radius) {
                btn.style.transform = `translate3d(${dx * strength}px, ${dy * strength}px, 0)`;
              } else {
                reset();
              }
            });
            btn.addEventListener('mouseleave', reset);
            btn.addEventListener('blur', reset);
          });
        }

        // Tilt 3D — cards qui s'inclinent vers le curseur (max 5°)
        if (supportsHover && !reduced) {
          document.querySelectorAll('[data-tilt]').forEach((el) => {
            const max = 5;
            const reset = () => {
              el.style.setProperty('--tx', '0deg');
              el.style.setProperty('--ty', '0deg');
            };
            el.addEventListener('mousemove', (e) => {
              const rect = el.getBoundingClientRect();
              const px = (e.clientX - rect.left) / rect.width;
              const py = (e.clientY - rect.top) / rect.height;
              const ry = (px - 0.5) * max * 2;
              const rx = (0.5 - py) * max * 2;
              el.style.setProperty('--ty', ry.toFixed(2) + 'deg');
              el.style.setProperty('--tx', rx.toFixed(2) + 'deg');
            });
            el.addEventListener('mouseleave', reset);
          });
        }

        // Nav scroll shadow
        const nav = document.querySelector('header[data-nav]');
        if (nav) {
          const onScroll = () => {
            if (window.scrollY > 8) nav.classList.add('nav-scrolled');
            else nav.classList.remove('nav-scrolled');
          };
          onScroll();
          window.addEventListener('scroll', onScroll, { passive: true });
        }
      })();
    </script>
  </body>
</html>
