---
const weekDays = [
  { day: "Lun", date: 18, active: false },
  { day: "Mar", date: 19, active: false },
  { day: "Mer", date: 20, active: false },
  { day: "Jeu", date: 21, active: false },
  { day: "Ven", date: 22, active: true },
  { day: "Sam", date: 23, active: false },
  { day: "Dim", date: 24, active: false },
];
---

<div class="flex h-full flex-col text-white">
  <!-- App header -->
  <div
    class="flex items-center justify-between border-b border-white/[0.06] px-4 py-2.5"
  >
    <div class="flex items-center gap-1">
      <span class="text-sm font-semibold">Mai 2026</span>
      <svg
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        class="h-3 w-3 text-white/50"
      >
        <path d="m4 6 4 4 4-4"></path>
      </svg>
    </div>
    <div class="flex items-center gap-1.5">
      <div
        class="flex h-6 w-6 items-center justify-center rounded-md bg-white/[0.06] text-white/70"
      >
        <svg
          viewBox="0 0 16 16"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          class="h-3 w-3"
        >
          <path d="M2 4h12M4 8h8M6 12h4"></path>
        </svg>
      </div>
      <div
        class="flex h-6 w-6 items-center justify-center rounded-md bg-white/[0.06] text-white/70"
      >
        <svg
          viewBox="0 0 16 16"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          class="h-3 w-3"
        >
          <path d="M8 3v10M3 8h10"></path>
        </svg>
      </div>
    </div>
  </div>

  <!-- Week strip -->
  <div class="flex border-b border-white/[0.06] px-2 py-2">
    {
      weekDays.map((d) => (
        <div class="flex flex-1 flex-col items-center gap-1">
          <span class="text-[9px] text-white/40">{d.day}</span>
          {d.active ? (
            <span class="flex h-7 w-7 items-center justify-center rounded-full bg-accent-500 text-[11px] font-semibold text-white">
              {d.date}
            </span>
          ) : (
            <span class="flex h-7 w-7 items-center justify-center text-[11px] text-white/80">
              {d.date}
            </span>
          )}
        </div>
      ))
    }
  </div>

  <!-- Events grouped by day -->
  <div class="flex-1 overflow-hidden pt-2 pb-1">
    <p
      class="px-4 pb-1.5 text-[9px] font-semibold uppercase tracking-wider text-white/40"
    >
      Vendredi 22 Mai · Aujourd'hui
    </p>

    <div
      class="relative mx-3 mb-1.5 overflow-hidden rounded-xl border border-white/[0.06] bg-white/[0.03] p-2.5 pl-3.5"
    >
      <div
        class="absolute inset-y-2 left-1 w-[3px] rounded-r bg-emerald-400"
      >
      </div>
      <p class="text-[12px] font-medium leading-snug text-white/90">
        Entraînement Juniors
      </p>
      <p class="mt-0.5 text-[10px] text-white/50">
        18:00 – 19:30 · Centre sportif Vidy
      </p>
      <p class="mt-0.5 text-[10px] text-white/40">14 participants</p>
    </div>

    <div
      class="relative mx-3 mb-1.5 overflow-hidden rounded-xl border border-white/[0.06] bg-white/[0.03] p-2.5 pl-3.5"
    >
      <div class="absolute inset-y-2 left-1 w-[3px] rounded-r bg-amber-400">
      </div>
      <div class="flex items-start justify-between gap-2">
        <p class="text-[12px] font-medium leading-snug text-white/90">
          Tournoi inter-clubs
        </p>
        <span
          class="shrink-0 rounded bg-amber-400/15 px-1.5 py-px text-[9px] font-medium text-amber-300"
          >Externe</span
        >
      </div>
      <p class="mt-0.5 text-[10px] text-white/50">
        Toute la journée · Stade de la Pontaise
      </p>
    </div>

    <p
      class="mt-2 px-4 pb-1.5 text-[9px] font-semibold uppercase tracking-wider text-white/40"
    >
      Samedi 23 Mai
    </p>
    <div
      class="relative mx-3 overflow-hidden rounded-xl border border-white/[0.06] bg-white/[0.03] p-2.5 pl-3.5"
    >
      <div class="absolute inset-y-2 left-1 w-[3px] rounded-r bg-accent-500">
      </div>
      <div class="flex items-start justify-between gap-2">
        <p class="text-[12px] font-medium leading-snug text-white/90">
          AG annuelle
        </p>
        <span
          class="shrink-0 rounded bg-accent-500/15 px-1.5 py-px text-[9px] font-medium text-accent-500"
          >Important</span
        >
      </div>
      <p class="mt-0.5 text-[10px] text-white/50">
        10:00 – 12:30 · Hôtel de Ville, Vevey
      </p>
    </div>
  </div>
</div>
