---
const tasksTodo = [
  {
    title: "Réserver salle pour l'AG",
    label: { text: "Urgent", classes: "bg-rose-500/15 text-rose-300" },
    avatars: [
      { i: "MR", classes: "bg-amber-500/30 text-amber-300" },
      { i: "SB", classes: "bg-emerald-500/30 text-emerald-300" },
    ],
    date: "28 mai",
  },
  {
    title: "Commander maillots U15",
    label: { text: "FC Lausanne", classes: "bg-accent-500/15 text-accent-500" },
    avatars: [{ i: "LD", classes: "bg-accent-500/30 text-accent-400" }],
    date: "02 juin",
  },
  {
    title: "Rédiger PV comité",
    label: null,
    avatars: [{ i: "SB", classes: "bg-emerald-500/30 text-emerald-300" }],
    date: "25 mai",
  },
];
---

<div class="flex h-full flex-col text-white">
  <!-- App header -->
  <div
    class="flex items-center justify-between border-b border-white/[0.06] px-4 py-2.5"
  >
    <div class="flex items-center gap-2">
      <svg
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        class="h-3.5 w-3.5 text-white/50"
      >
        <path d="m10 4-4 4 4 4"></path>
      </svg>
      <span class="text-sm font-semibold">Tâches</span>
    </div>
    <div class="flex items-center gap-1.5">
      <div
        class="flex h-6 w-6 items-center justify-center rounded-full bg-accent-500/20 text-[10px] font-semibold text-accent-500"
      >
        LD
      </div>
      <div
        class="flex h-6 w-6 items-center justify-center rounded-md bg-white/[0.06] text-white/70"
      >
        <svg
          viewBox="0 0 16 16"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          class="h-3 w-3"
        >
          <path d="M8 3v10M3 8h10"></path>
        </svg>
      </div>
    </div>
  </div>

  <!-- Pill tabs -->
  <div class="flex gap-1 px-3 py-2 text-[11px]">
    <span class="rounded-md bg-white/[0.08] px-2 py-1 font-medium text-white"
      >Tableau</span
    >
    <span class="rounded-md px-2 py-1 text-white/40">Liste</span>
    <span class="rounded-md px-2 py-1 text-white/40">Mes tâches</span>
  </div>

  <!-- Kanban columns -->
  <div class="flex-1 overflow-hidden pb-1">
    <div class="flex h-full gap-2 px-2">
      <!-- Column 1 -->
      <div
        class="flex min-w-[160px] flex-col rounded-xl bg-white/[0.02] p-1.5"
      >
        <div class="mb-1.5 flex items-center justify-between px-1">
          <span
            class="text-[9px] font-semibold uppercase tracking-wider text-white/50"
            >À faire</span
          >
          <span class="text-[9px] text-white/40">3</span>
        </div>
        {
          tasksTodo.map((t) => (
            <div class="mb-1.5 space-y-1.5 rounded-lg border border-white/[0.08] bg-white/[0.03] p-2.5">
              {t.label && (
                <span
                  class={`inline-block rounded px-1.5 py-px text-[9px] font-medium ${t.label.classes}`}
                >
                  {t.label.text}
                </span>
              )}
              <p class="text-[12px] leading-snug text-white/90">{t.title}</p>
              <div class="flex items-center justify-between text-[10px] text-white/50">
                <div class="flex -space-x-1.5">
                  {t.avatars.map((av) => (
                    <div
                      class={`flex h-[18px] w-[18px] items-center justify-center rounded-full text-[8px] font-semibold ring-2 ring-black ${av.classes}`}
                    >
                      {av.i}
                    </div>
                  ))}
                </div>
                <span class="tabular-nums">{t.date}</span>
              </div>
            </div>
          ))
        }
      </div>

      <!-- Column 2 peek -->
      <div
        class="flex min-w-[160px] flex-col rounded-xl bg-white/[0.02] p-1.5"
      >
        <div class="mb-1.5 flex items-center justify-between px-1">
          <span
            class="text-[9px] font-semibold uppercase tracking-wider text-white/50"
            >En cours</span
          >
          <span class="text-[9px] text-white/40">1</span>
        </div>
        <div
          class="space-y-1.5 rounded-lg border border-white/[0.08] bg-white/[0.03] p-2.5"
        >
          <span
            class="inline-block rounded bg-accent-500/15 px-1.5 py-px text-[9px] font-medium text-accent-500"
            >Comité</span
          >
          <p class="text-[12px] leading-snug text-white/90">
            Préparer slides AG
          </p>
          <div
            class="flex items-center justify-between text-[10px] text-white/50"
          >
            <div class="flex -space-x-1.5">
              <div
                class="flex h-[18px] w-[18px] items-center justify-center rounded-full bg-amber-500/30 text-[8px] font-semibold text-amber-300 ring-2 ring-black"
              >
                MR
              </div>
              <div
                class="flex h-[18px] w-[18px] items-center justify-center rounded-full bg-accent-500/30 text-[8px] font-semibold text-accent-400 ring-2 ring-black"
              >
                LD
              </div>
            </div>
            <span class="tabular-nums">30 mai</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
