---
import PhoneFrame from "./PhoneFrame.astro";
import KanbanScreen from "./screens/KanbanScreen.astro";
---

<section
  class="relative isolate overflow-hidden px-6 pt-36 pb-24 sm:pt-44 sm:pb-32 lg:min-h-[92vh] lg:flex lg:items-center"
>
  <!-- Aurora blob (mouse-driven) -->
  <div aria-hidden="true" class="aurora aurora-strong"></div>

  <!-- Subtle technical grid background -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10 grid-bg opacity-50"
  ></div>

  <div class="mx-auto w-full max-w-7xl">
    <div class="grid grid-cols-12 items-center gap-x-8 gap-y-16">
      <!-- LEFT — editorial text -->
      <div class="col-span-12 lg:col-span-7">
        <div
          data-reveal
          class="inline-flex items-center gap-2.5 rounded-full border border-white/10 bg-white/[0.04] py-1.5 pl-2 pr-3.5 text-[11px] font-medium text-ink-400 backdrop-blur"
        >
          <span class="live-dot"></span>
          <span>
            <span
              data-counter="34"
              data-counter-prefix="+"
              data-counter-duration="1600"
              class="text-ink-50"
            >+0</span>
            <span class="text-ink-500">nouvelles assos · 30 derniers jours</span>
          </span>
        </div>

        <h1
          data-reveal
          data-split-text
          class="display-hero mt-7 text-balance text-ink-50"
        >
          L'intranet privé, pensé pour les associations suisses.
        </h1>

        <p
          data-reveal
          class="mt-7 max-w-xl text-pretty text-base leading-relaxed text-ink-400 sm:text-lg"
        >
          Tâches, agenda partagé, documents — réunis dans une seule app mobile.
          Sans tracker. Hébergé en Europe. Pensé pour la vie associative
          quotidienne.
        </p>

        <div
          data-reveal
          class="mt-10 flex flex-col items-start gap-3 sm:flex-row sm:items-center"
        >
          <a
            href="/demo"
            data-magnetic
            class="cta-shimmer group/cta inline-flex items-center justify-center gap-1.5 rounded-xl bg-accent-500 px-6 py-3.5 text-sm font-semibold text-white shadow-[0_18px_40px_-12px_rgba(94,106,210,0.7)] transition-colors hover:bg-accent-400"
          >
            Réserver ma démo
            <svg
              viewBox="0 0 16 16"
              fill="none"
              class="h-4 w-4 transition-transform duration-300 ease-out group-hover/cta:translate-x-0.5"
              aria-hidden="true"
            >
              <path
                d="M3.5 8h9m0 0L8 3.5M12.5 8 8 12.5"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </a>
          <a
            href="#features"
            class="inline-flex items-center justify-center gap-1.5 rounded-xl border border-white/10 bg-white/[0.02] px-6 py-3.5 text-sm font-semibold text-ink-50 transition-colors hover:border-white/20 hover:bg-white/[0.05]"
          >
            Voir les fonctionnalités
            <svg viewBox="0 0 16 16" fill="none" class="h-3.5 w-3.5 text-ink-400" aria-hidden="true">
              <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <!-- Inline counters strip -->
        <dl
          data-reveal
          class="mt-14 grid max-w-xl grid-cols-3 gap-x-4 gap-y-3 border-t border-white/[0.07] pt-7"
        >
          <div>
            <dt class="text-[10px] font-medium uppercase tracking-widest text-ink-500">Assos</dt>
            <dd class="mt-1 text-2xl font-semibold tracking-tight text-ink-50 sm:text-3xl">
              <span data-counter="218" data-counter-suffix="+">0</span>
            </dd>
          </div>
          <div>
            <dt class="text-[10px] font-medium uppercase tracking-widest text-ink-500">Trackers</dt>
            <dd class="mt-1 text-2xl font-semibold tracking-tight text-ink-50 sm:text-3xl tabular-nums">
              <span data-counter="0">0</span>
            </dd>
          </div>
          <div>
            <dt class="text-[10px] font-medium uppercase tracking-widest text-ink-500">Hébergé</dt>
            <dd class="mt-1 text-2xl font-semibold tracking-tight text-ink-50 sm:text-3xl">
              🇪🇺&nbsp;<span class="text-ink-400 text-base">UE</span>
            </dd>
          </div>
        </dl>
      </div>

      <!-- RIGHT — phone embed (lg+) -->
      <div
        data-reveal
        class="relative col-span-12 hidden justify-center lg:col-span-5 lg:flex"
        style="transition-delay: 200ms;"
      >
        <div class="tilt-breathe relative">
          <div
            aria-hidden="true"
            class="pointer-events-none absolute -inset-10 -z-10 rounded-full opacity-60 blur-3xl"
            style="background: radial-gradient(closest-side, rgba(94,106,210,0.45), transparent 70%);"
          >
          </div>
          <PhoneFrame
            activeTab="taches"
            rotate="-rotate-3"
            translateY=""
            delay={0}
            zIndex={1}
          >
            <KanbanScreen />
          </PhoneFrame>
        </div>
      </div>
    </div>
  </div>
</section>
