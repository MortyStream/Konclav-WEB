---
import PhoneFan from "./PhoneFan.astro";
import PhoneShot from "./PhoneShot.astro";
import CTAButton from "./CTAButton.astro";
---

<section
  class="relative isolate overflow-hidden px-6 pt-28 pb-24 sm:pt-44 sm:pb-32 lg:min-h-[92vh] lg:flex lg:items-center"
>
  <!-- Subtle technical grid background -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10 grid-bg opacity-60"
  ></div>

  <div class="mx-auto w-full max-w-7xl">
    <div class="grid grid-cols-12 items-center gap-x-8 gap-y-12 md:gap-y-16">
      <!-- LEFT — editorial text -->
      <div class="col-span-12 lg:col-span-7">
        <div
          data-reveal
          class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-[11px] font-medium text-ink-400 backdrop-blur"
        >
          <span class="inline-flex h-4 w-5 items-center justify-center overflow-hidden rounded-sm">
            <svg viewBox="0 0 32 32" class="h-3 w-3" aria-hidden="true">
              <rect width="32" height="32" fill="#DA291C" />
              <rect x="13" y="6" width="6" height="20" fill="#fff" />
              <rect x="6" y="13" width="20" height="6" fill="#fff" />
            </svg>
          </span>
          <span class="text-ink-50">Fait en Suisse</span>
          <span aria-hidden="true" class="text-ink-500">·</span>
          <span>pour les associations</span>
        </div>

        <h1
          data-reveal
          data-split-text
          class="display-hero mt-7 text-balance text-ink-50"
        >
          Gérez votre asso sans WhatsApp, Excel ni Drive.
        </h1>

        <p
          data-reveal
          class="mt-7 max-w-xl text-pretty text-base leading-relaxed text-ink-400 sm:text-lg"
        >
          Konclav, c'est <em class="not-italic font-semibold text-ink-50">l'intranet
          privé pensé pour les associations suisses</em>. Tâches, agenda,
          documents — réunis dans une seule app mobile. Sans pub ni cookie,
          données hébergées en UE.
        </p>

        <div
          data-reveal
          class="mt-10 flex flex-col items-start gap-3 sm:flex-row sm:items-center"
        >
          <CTAButton href="/demo" joinOpen magnetic size="lg">
            Réserver ma démo
          </CTAButton>
          <CTAButton href="#features" variant="secondary" size="lg" arrow={false}>
            Voir les fonctionnalités
            <svg viewBox="0 0 16 16" fill="none" class="ml-1 h-3.5 w-3.5 text-ink-400" aria-hidden="true">
              <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </CTAButton>
        </div>

        <!-- Honest stat strip : 2 real claims, no inflated numbers -->
        <dl
          data-reveal
          class="mt-14 grid max-w-md grid-cols-2 gap-x-6 gap-y-3 border-t border-white/[0.07] pt-7"
        >
          <div>
            <dt class="text-[10px] font-medium uppercase tracking-widest text-ink-500">Cookies</dt>
            <dd class="mt-1 text-2xl font-semibold tracking-tight text-ink-50 sm:text-3xl tabular-nums">
              0
            </dd>
          </div>
          <div>
            <dt class="text-[10px] font-medium uppercase tracking-widest text-ink-500">Hébergement</dt>
            <dd class="mt-1 text-2xl font-semibold tracking-tight text-ink-50 sm:text-3xl">
              100% <span class="text-sm text-ink-400">UE</span>
            </dd>
          </div>
        </dl>
      </div>

      <!-- RIGHT — aperçu de l'app -->
      <div class="relative col-span-12 lg:col-span-5">
        <!-- mobile / tablette : carrousel d'écrans, glissable -->
        <div class="lg:hidden">
          <div class="relative">
            <div
              aria-hidden="true"
              class="pointer-events-none absolute left-1/2 top-1/2 -z-10 h-72 w-80 -translate-x-1/2 -translate-y-1/2 rounded-full opacity-50 blur-3xl"
              style="background: radial-gradient(closest-side, rgba(94,106,210,0.45), transparent 70%);"
            >
            </div>
            <div class="-mx-6 flex snap-x snap-mandatory gap-5 overflow-x-auto px-6 pb-1 no-scrollbar [&>*]:snap-always">
              <PhoneShot src="/app/agenda-semaine.webp" alt="Konclav — agenda, vue semaine des entraînements" priority />
              <PhoneShot src="/app/tache.webp" alt="Konclav — détail d'une tâche avec validation" />
              <PhoneShot src="/app/documents.webp" alt="Konclav — documents et dossiers" />
              <PhoneShot src="/app/annuaire.webp" alt="Konclav — annuaire des membres" />
            </div>
          </div>
          <p
            class="mt-4 flex items-center justify-center gap-1.5 text-xs font-medium text-ink-500"
            aria-hidden="true"
          >
            Glissez pour voir les écrans
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
              <path d="M5 12h14M13 6l6 6-6 6" />
            </svg>
          </p>
        </div>
        <!-- desktop : éventail -->
        <div class="hidden lg:block">
          <PhoneFan />
        </div>
      </div>
    </div>
  </div>
</section>
