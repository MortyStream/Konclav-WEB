---

---

<section
  id="contact"
  class="relative isolate overflow-hidden border-t border-white/[0.06] px-6 py-32 sm:py-44 lg:py-56"
>
  <!-- Aurora large -->
  <div aria-hidden="true" class="aurora aurora-strong opacity-90"></div>

  <!-- Grid bg -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10 grid-bg opacity-40"
  ></div>

  <div class="mx-auto max-w-5xl text-center">
    <p data-reveal class="text-xs font-medium uppercase tracking-[0.18em] text-accent-500">
      On se cale ?
    </p>

    <h2
      data-reveal
      data-split-text
      class="display-section mt-6 text-balance text-ink-50"
    >
      Prêt à voir Konclav en action ?
    </h2>

    <p
      data-reveal
      class="mx-auto mt-6 max-w-xl text-pretty text-base leading-relaxed text-ink-400 sm:text-lg"
    >
      Une démo personnalisée de 20 minutes. Pas de blabla commercial — on
      regarde ensemble si Konclav colle à votre asso.
    </p>

    <div
      data-reveal
      class="mt-12 flex flex-col items-center justify-center gap-3 sm:flex-row"
    >
      <a
        href="/demo"
        data-magnetic
        class="cta-shimmer group/cta inline-flex items-center justify-center gap-1.5 rounded-xl bg-accent-500 px-7 py-4 text-sm font-semibold text-white shadow-[0_20px_50px_-12px_rgba(94,106,210,0.7)] transition-colors hover:bg-accent-400"
      >
        Réserver ma démo
        <svg
          viewBox="0 0 16 16"
          fill="none"
          class="h-4 w-4 transition-transform duration-300 ease-out group-hover/cta:translate-x-0.5"
          aria-hidden="true"
        >
          <path
            d="M3.5 8h9m0 0L8 3.5M12.5 8 8 12.5"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </a>
      <a
        href="mailto:mxrtystream@gmail.com"
        class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/[0.02] px-7 py-4 text-sm font-semibold text-ink-50 transition-colors hover:border-white/20 hover:bg-white/[0.05]"
      >
        Écrire un mail
      </a>
    </div>

    <p
      data-reveal
      class="mt-10 text-[11px] text-ink-500"
    >
      Réponse sous 24h ouvrées · Démo en français · Sans engagement
    </p>
  </div>
</section>
