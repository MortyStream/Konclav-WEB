---
import PhoneShot from "./PhoneShot.astro";

const badgeStyles: Record<string, string> = {
  accent: "border-accent-500/30 bg-accent-500/10 text-accent-400",
  emerald: "border-emerald-400/30 bg-emerald-400/10 text-emerald-300",
  rose: "border-rose-400/30 bg-rose-400/10 text-rose-300",
  sky: "border-sky-400/30 bg-sky-400/10 text-sky-300",
};

const features = [
  {
    badge: "Tâches",
    color: "accent",
    title: "Du chaos du PV à la clarté du sprint.",
    desc: "À faire / En cours / Fait, attribution, deadlines. Et un vrai circuit de validation : chaque dépense passe par un responsable.",
    points: ["Attribution & échéances", "Validation des dépenses", "Étiquettes par équipe"],
    src: "/app/tache.webp",
    alt: "Konclav — détail d'une tâche avec validation Approuver / Rejeter",
  },
  {
    badge: "Agenda",
    color: "emerald",
    title: "Tous les rendez-vous, au même endroit.",
    desc: "Vues mois, semaine et jour. Événements par équipe, lieux et participants — synchronisés avec Google et Apple.",
    points: ["Vues mois / semaine / jour", "Sync Google & Apple", "Par équipe et par pôle"],
    src: "/app/agenda-semaine.webp",
    alt: "Konclav — agenda, vue semaine des entraînements",
  },
  {
    badge: "Documents",
    color: "rose",
    title: "La Bible documentaire.",
    desc: "Statuts, PV, contrats, règlements — classés par pôle. Recherche instantanée, fichiers et liens, tout au même endroit.",
    points: ["Classé par pôle", "Recherche instantanée", "Fichiers & liens externes"],
    src: "/app/documents.webp",
    alt: "Konclav — documents et dossiers de l'association",
  },
  {
    badge: "Membres",
    color: "sky",
    title: "L'annuaire et toute la vie interne.",
    desc: "Annuaire avec rôles (comité, responsables de pôle), cotisations, notes de frais, sondages et réunions.",
    points: ["Annuaire & rôles", "Cotisations & notes de frais", "Sondages & réunions"],
    src: "/app/annuaire.webp",
    alt: "Konclav — annuaire des membres et rôles",
  },
];
---

<section id="features" class="relative px-6 py-32 sm:py-40">
  <div class="mx-auto max-w-6xl">
    <div class="mx-auto max-w-3xl text-center">
      <p data-reveal class="text-xs font-medium uppercase tracking-[0.18em] text-accent-500">
        Fonctionnalités
      </p>
      <h2
        data-reveal
        data-split-text
        class="display-section mt-4 text-balance text-ink-50"
      >
        Quatre outils, une seule app.
      </h2>
      <p
        data-reveal
        class="mx-auto mt-5 max-w-xl text-pretty text-base leading-relaxed text-ink-400 sm:text-lg"
      >
        Pensé pour la vie quotidienne d'une association — du comité aux
        bénévoles, du mobile au desktop.
      </p>
    </div>

    <div class="mt-20 space-y-6 sm:space-y-8">
      {
        features.map((f, i) => (
          <article
            data-reveal
            class="bento relative grid items-center gap-8 p-7 sm:p-10 md:grid-cols-2 md:gap-12"
          >
            <div class={i % 2 === 1 ? "md:order-2" : ""}>
              <span
                class={`inline-block rounded-md border px-2 py-0.5 text-[10px] font-medium uppercase tracking-wider ${badgeStyles[f.color]}`}
              >
                {f.badge}
              </span>
              <h3 class="mt-4 text-2xl font-semibold leading-tight tracking-tight text-ink-50 sm:text-3xl">
                {f.title}
              </h3>
              <p class="mt-3 max-w-md text-sm leading-relaxed text-ink-400 sm:text-base">
                {f.desc}
              </p>
              <ul class="mt-6 space-y-2.5">
                {f.points.map((pt) => (
                  <li class="flex items-center gap-2.5 text-sm text-ink-300">
                    <svg
                      viewBox="0 0 16 16"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.75"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="h-4 w-4 shrink-0 text-accent-400"
                      aria-hidden="true"
                    >
                      <path d="m3.5 8.5 3 3 6-7" />
                    </svg>
                    {pt}
                  </li>
                ))}
              </ul>
            </div>
            <div class={`flex justify-center ${i % 2 === 1 ? "md:order-1" : ""}`}>
              <PhoneShot src={f.src} alt={f.alt} />
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
