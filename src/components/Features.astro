---
import Icon from "./Icon.astro";

const features = [
  {
    icon: "kanban" as const,
    title: "Tâches Kanban",
    description:
      "Colonnes À faire / En cours / Fait. Attribution, deadlines, étiquettes. Du chaos du PV à la clarté du sprint.",
  },
  {
    icon: "calendar" as const,
    title: "Calendrier partagé",
    description:
      "Évènements, AG, permanences. Tout le monde voit la même chose. Synchro Google et Apple, sans friction.",
  },
  {
    icon: "book-open" as const,
    title: "La Bible documentaire",
    description:
      "Statuts, PV, contrats, modèles. Recherche instantanée, versions, droits granulaires. Fini les pièces jointes perdues.",
  },
  {
    icon: "bell" as const,
    title: "Notifications intelligentes",
    description:
      "Push mobile seulement quand ça compte. Pas de spam, pas d'emails inutiles. Chaque membre règle son canal.",
  },
];
---

<section id="features" class="relative px-6 py-32 sm:py-40">
  <div class="mx-auto max-w-6xl">
    <div class="mx-auto max-w-2xl text-center">
      <p data-reveal class="text-sm font-medium text-accent-500">
        Fonctionnalités
      </p>
      <h2
        data-reveal
        class="mt-3 text-balance text-3xl font-semibold leading-tight tracking-tight text-ink-50 sm:text-4xl md:text-5xl"
      >
        Quatre outils, une seule app.
      </h2>
      <p
        data-reveal
        class="mt-4 text-pretty text-base leading-relaxed text-ink-400 sm:text-lg"
      >
        Pensé pour la vie quotidienne d'une association — du comité aux
        bénévoles, du mobile au desktop.
      </p>
    </div>

    <div class="mt-16 grid gap-5 sm:grid-cols-2">
      {
        features.map((f, i) => (
          <article
            data-reveal
            data-spotlight
            style={`transition-delay: ${i * 80}ms`}
            class="group relative overflow-hidden rounded-2xl border border-white/10 bg-white/[0.02] p-7 transition-colors hover:border-white/20 hover:bg-white/[0.035]"
          >
            <div class="mb-5 inline-flex items-center justify-center rounded-lg border border-white/10 bg-ink-900 p-2.5 text-accent-500">
              <Icon name={f.icon} class="h-5 w-5" />
            </div>
            <h3 class="text-lg font-semibold tracking-tight text-ink-50">
              {f.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-400">
              {f.description}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
