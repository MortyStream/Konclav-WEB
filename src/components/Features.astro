---
import PhoneShot from "./PhoneShot.astro";

const badgeStyles: Record<string, string> = {
  accent: "border-accent-500/30 bg-accent-500/10 text-accent-400",
  amber: "border-amber-400/30 bg-amber-400/10 text-amber-300",
  sky: "border-sky-400/30 bg-sky-400/10 text-sky-300",
  fuchsia: "border-fuchsia-400/30 bg-fuchsia-400/10 text-fuchsia-300",
  emerald: "border-emerald-400/30 bg-emerald-400/10 text-emerald-300",
  rose: "border-rose-400/30 bg-rose-400/10 text-rose-300",
};

const haloColors: Record<string, string> = {
  accent: "rgba(94,106,210,0.55)",
  amber: "rgba(251,191,36,0.45)",
  sky: "rgba(56,189,248,0.45)",
  fuchsia: "rgba(217,70,239,0.45)",
  emerald: "rgba(74,222,128,0.45)",
  rose: "rgba(244,63,94,0.45)",
};

const tabs = [
  {
    tab: "Tâches",
    color: "accent",
    title: "Des tâches qui passent par une validation.",
    desc: "Assignez, fixez une échéance, suivez l'avancement. Et pour les dépenses, un vrai circuit d'approbation : chaque achat passe par un responsable avant d'être engagé.",
    points: ["Attribution & échéances", "Validation des dépenses (approuver / rejeter)", "Priorités et rappels"],
    src: "/app/feat-taches.webp",
    alt: "Konclav — détail d'une tâche avec circuit de validation Approuver / Rejeter",
  },
  {
    tab: "Calendrier",
    color: "amber",
    title: "Tous les événements, par équipe.",
    desc: "Vues mois, semaine et jour. Entraînements, répétitions, matchs ou réunions — chaque événement avec son lieu et ses participants.",
    points: ["Vues mois / semaine / jour", "Événements par équipe et par pôle", "Lieux et participants"],
    src: "/app/feat-calendrier.webp",
    alt: "Konclav — calendrier de l'association, vue mois",
  },
  {
    tab: "Annuaire",
    color: "sky",
    title: "Qui fait quoi, en un coup d'œil.",
    desc: "Tous les membres, leurs rôles et leurs pôles au même endroit. Le comité voit qui s'est connecté et qui reste à intégrer.",
    points: ["Rôles & pôles", "Recherche instantanée", "Profils et coordonnées"],
    src: "/app/feat-annuaire.webp",
    alt: "Konclav — annuaire des membres avec rôles et pôles",
  },
  {
    tab: "Documents",
    color: "fuchsia",
    title: "Statuts, PV, contrats — classés par pôle.",
    desc: "La mémoire de l'association au même endroit. Comité, sportif, communication, logistique : chacun son espace, recherche instantanée.",
    points: ["Classé par pôle", "Statuts, PV, contrats, sponsoring", "Recherche instantanée"],
    src: "/app/feat-documents.webp",
    alt: "Konclav — documents et dossiers classés par pôle",
  },
  {
    tab: "Cotisations & finances",
    color: "emerald",
    title: "La trésorerie, sans tableur.",
    desc: "Cotisations encaissées, frais remboursés, balance de l'année — en direct. Le trésorier voit ce qu'il reste à recouvrer et les notes à traiter, sans ouvrir Excel.",
    points: ["Suivi des cotisations", "Notes de frais & remboursements", "Balance et flux mensuels"],
    src: "/app/feat-finances.webp",
    alt: "Konclav — tableau de bord financier : balance, cotisations, frais remboursés",
  },
  {
    tab: "AG & signatures",
    color: "rose",
    title: "L'assemblée générale, dans votre poche.",
    desc: "Démarrez une AG : les membres confirment leur présence par signature électronique, votent les ordres du jour, et le procès-verbal est archivé — horodaté et conservé.",
    points: ["Signature électronique de présence", "Votations en direct", "PV archivé automatiquement"],
    src: "/app/feat-ag.webp",
    alt: "Konclav — confirmation de présence à l'AG par signature électronique",
  },
];
---

<section id="features" class="relative px-6 pt-32 pb-24 sm:pt-40 sm:pb-32">
  <div class="mx-auto max-w-6xl">
    <div class="mx-auto max-w-3xl text-center">
      <p data-reveal class="text-xs font-medium uppercase tracking-[0.18em] text-accent-400">
        Fonctionnalités
      </p>
      <h2
        data-reveal
        data-split-text
        class="display-section mt-4 text-balance text-ink-50"
      >
        Toute votre asso, écran par écran.
      </h2>
      <p
        data-reveal
        class="mx-auto mt-5 max-w-xl text-pretty text-base leading-relaxed text-ink-400 sm:text-lg"
      >
        Tâches, agenda, annuaire, documents, finances, assemblées — chaque
        espace de l'app, pensé pour le quotidien d'une association.
      </p>
    </div>

    <!-- ============================================
         MOBILE : carousel cinéma plein-écran
         ============================================ -->
    <div data-feature-carousel class="mt-16 md:hidden">
      <div
        data-carousel-track
        class="-mx-6 flex snap-x snap-mandatory gap-6 overflow-x-auto px-6 pb-2 no-scrollbar"
      >
        {
          tabs.map((t, i) => (
            <article
              data-carousel-item
              data-index={i}
              class="flex w-[88%] shrink-0 snap-center flex-col items-center"
            >
              <div class="relative">
                <div
                  aria-hidden="true"
                  class="pointer-events-none absolute -inset-12 -z-10 rounded-full opacity-60 blur-3xl"
                  style={`background: radial-gradient(closest-side, ${haloColors[t.color]}, transparent 70%);`}
                />
                <PhoneShot src={t.src} alt={t.alt} reveal={false} hoverScale={false} priority={i === 0} />
              </div>
              <div class="mt-8 text-center">
                <span
                  class={`inline-block rounded-md border px-2 py-0.5 text-[10px] font-medium uppercase tracking-wider ${badgeStyles[t.color]}`}
                >
                  {t.tab}
                </span>
                <h3 class="mt-3 text-xl font-semibold leading-tight tracking-tight text-ink-50">
                  {t.title}
                </h3>
                <p class="mx-auto mt-2 max-w-sm text-sm leading-relaxed text-ink-400">
                  {t.desc}
                </p>
              </div>
            </article>
          ))
        }
      </div>

      <!-- Pagination dots -->
      <div
        class="mt-8 flex justify-center gap-2"
        role="tablist"
        aria-label="Naviguer entre les fonctionnalités"
      >
        {
          tabs.map((t, i) => (
            <button
              type="button"
              data-dot
              data-index={i}
              aria-label={`Aller à ${t.tab}`}
              aria-selected={i === 0 ? "true" : "false"}
              class="dot h-1.5 rounded-full transition-all duration-300 aria-selected:bg-ink-50"
              style={`width: ${i === 0 ? "1.5rem" : "0.375rem"}; background-color: ${i === 0 ? "" : "rgba(255,255,255,0.2)"};`}
            />
          ))
        }
      </div>
    </div>

    <!-- ============================================
         DESKTOP : sticky scroll storytelling
         ============================================ -->
    <div
      data-feature-sticky
      class="mt-20 hidden md:grid md:grid-cols-2 md:gap-12 lg:gap-20"
    >
      <!-- LEFT COLUMN : sections scroll naturellement -->
      <div>
        {
          tabs.map((t, i) => (
            <section
              data-feature-section
              data-index={i}
              class="flex min-h-[88vh] flex-col justify-center"
            >
              <span
                class={`inline-block self-start rounded-md border px-2.5 py-1 text-[10px] font-medium uppercase tracking-wider ${badgeStyles[t.color]}`}
              >
                {t.tab}
              </span>
              <h3 class="mt-5 text-3xl font-semibold leading-[1.1] tracking-tight text-ink-50 lg:text-4xl">
                {t.title}
              </h3>
              <p class="mt-5 max-w-md text-base leading-relaxed text-ink-400 lg:text-lg">
                {t.desc}
              </p>
              <ul class="mt-8 space-y-3">
                {t.points.map((pt) => (
                  <li class="flex items-start gap-2.5 text-sm text-ink-300 lg:text-base">
                    <svg
                      viewBox="0 0 16 16"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.75"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="mt-0.5 h-4 w-4 shrink-0 text-accent-400"
                      aria-hidden="true"
                    >
                      <path d="m3.5 8.5 3 3 6-7" />
                    </svg>
                    {pt}
                  </li>
                ))}
              </ul>
            </section>
          ))
        }
      </div>

      <!-- RIGHT COLUMN : phone sticky qui morph -->
      <div aria-hidden="true" class="relative">
        <div class="sticky top-0 flex h-screen items-center justify-center">
          <div class="relative h-[540px] w-[260px]">
            {
              tabs.map((t, i) => (
                <div
                  data-feature-image
                  data-index={i}
                  class="absolute inset-0 transition-all duration-700 ease-out"
                  style={`opacity: ${i === 0 ? "1" : "0"}; transform: scale(${i === 0 ? "1" : "0.96"});`}
                >
                  <div
                    aria-hidden="true"
                    class="pointer-events-none absolute -inset-16 -z-10 rounded-full opacity-55 blur-3xl"
                    style={`background: radial-gradient(closest-side, ${haloColors[t.color]}, transparent 70%);`}
                  />
                  <PhoneShot src={t.src} alt={t.alt} reveal={false} hoverScale={false} priority={true} />
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    // === DESKTOP: sticky scroll storytelling ===
    const sticky = document.querySelector("[data-feature-sticky]");
    if (sticky) {
      const sections = Array.from(sticky.querySelectorAll("[data-feature-section]"));
      const images = Array.from(sticky.querySelectorAll("[data-feature-image]"));
      let activeIdx = 0;
      const activate = (i) => {
        if (i === activeIdx) return;
        activeIdx = i;
        images.forEach((img, idx) => {
          const on = idx === i;
          img.style.opacity = on ? "1" : "0";
          img.style.transform = on ? "scale(1)" : "scale(0.96)";
        });
      };
      const visible = new Set();
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            const i = parseInt(e.target.getAttribute("data-index"), 10);
            if (e.isIntersecting) visible.add(i);
            else visible.delete(i);
          });
          if (visible.size > 0) activate(Math.min(...visible));
        },
        { rootMargin: "-45% 0px -45% 0px", threshold: 0 }
      );
      sections.forEach((s) => io.observe(s));
    }

    // === MOBILE: cinema carousel dots ===
    const carousel = document.querySelector("[data-feature-carousel]");
    if (carousel) {
      const track = carousel.querySelector("[data-carousel-track]");
      const items = Array.from(carousel.querySelectorAll("[data-carousel-item]"));
      const dots = Array.from(carousel.querySelectorAll("[data-dot]"));
      const setActive = (i) => {
        dots.forEach((d, idx) => {
          const on = idx === i;
          d.setAttribute("aria-selected", on ? "true" : "false");
          d.style.width = on ? "1.5rem" : "0.375rem";
          d.style.backgroundColor = on ? "" : "rgba(255,255,255,0.2)";
        });
      };
      const cio = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.intersectionRatio > 0.6) {
              const i = parseInt(e.target.getAttribute("data-index"), 10);
              setActive(i);
            }
          });
        },
        { root: track, threshold: [0.6, 0.9] }
      );
      items.forEach((it) => cio.observe(it));
      // Dot click → scroll to item
      dots.forEach((d, i) => {
        d.addEventListener("click", () => {
          items[i].scrollIntoView({ behavior: "smooth", inline: "center", block: "nearest" });
        });
      });
    }
  })();
</script>
