---
const columns = [
  {
    title: "À faire",
    count: 4,
    tasks: [
      {
        label: { text: "Urgent", classes: "bg-rose-500/15 text-rose-300" },
        title: "Réserver salle pour l'AG",
        avatars: [
          { i: "MR", classes: "bg-amber-500/30 text-amber-300" },
          { i: "SB", classes: "bg-emerald-500/30 text-emerald-300" },
        ],
        date: "28 mai",
      },
      {
        label: { text: "FC Lausanne", classes: "bg-accent-500/15 text-accent-400" },
        title: "Commander maillots U15",
        avatars: [{ i: "LD", classes: "bg-accent-500/30 text-accent-400" }],
        date: "02 juin",
      },
      {
        label: null,
        title: "Rédiger PV comité",
        avatars: [{ i: "SB", classes: "bg-emerald-500/30 text-emerald-300" }],
        date: "25 mai",
      },
    ],
  },
  {
    title: "En cours",
    count: 2,
    tasks: [
      {
        label: { text: "Comité", classes: "bg-accent-500/15 text-accent-400" },
        title: "Préparer slides AG",
        avatars: [
          { i: "MR", classes: "bg-amber-500/30 text-amber-300" },
          { i: "LD", classes: "bg-accent-500/30 text-accent-400" },
        ],
        date: "30 mai",
      },
      {
        label: { text: "Trésorerie", classes: "bg-sky-500/15 text-sky-300" },
        title: "Clôture comptes 2025",
        avatars: [{ i: "JG", classes: "bg-sky-500/30 text-sky-300" }],
        date: "12 juin",
      },
    ],
  },
  {
    title: "Fait",
    count: 1,
    tasks: [
      {
        label: { text: "Statuts", classes: "bg-emerald-500/15 text-emerald-300" },
        title: "Voter modification art. 12",
        avatars: [{ i: "SB", classes: "bg-emerald-500/30 text-emerald-300" }],
        date: "20 mai",
      },
    ],
  },
];
---

<div class="mockup-kanban relative h-full w-full overflow-hidden rounded-xl border border-white/[0.06] bg-ink-950/60">
  <!-- Mini app chrome -->
  <div class="flex items-center justify-between border-b border-white/[0.06] px-3.5 py-2">
    <div class="flex items-center gap-1.5">
      <span class="text-[12px] font-semibold text-white/90">Tâches · FC Lausanne</span>
    </div>
    <div class="flex items-center gap-1">
      <span class="rounded-md bg-white/[0.06] px-1.5 py-0.5 text-[9px] font-medium text-white/60">Tableau</span>
      <span class="px-1.5 py-0.5 text-[9px] text-white/30">Liste</span>
    </div>
  </div>

  <!-- Columns -->
  <div class="flex h-full gap-2 overflow-hidden p-2 fade-bottom">
    {columns.map((col) => (
      <div class="flex w-44 shrink-0 flex-col rounded-lg bg-white/[0.02] p-1.5">
        <div class="mb-1 flex items-center justify-between px-1">
          <span class="text-[9px] font-semibold uppercase tracking-wider text-white/50">
            {col.title}
          </span>
          <span class="text-[9px] tabular-nums text-white/40">{col.count}</span>
        </div>
        {col.tasks.map((t) => (
          <div class="mb-1.5 space-y-1 rounded-md border border-white/[0.08] bg-white/[0.03] p-2">
            {t.label && (
              <span
                class={`inline-block rounded px-1 py-px text-[8px] font-medium ${t.label.classes}`}
              >
                {t.label.text}
              </span>
            )}
            <p class="text-[11px] leading-snug text-white/90">{t.title}</p>
            <div class="flex items-center justify-between text-[9px] text-white/40">
              <div class="flex -space-x-1">
                {t.avatars.map((av) => (
                  <div
                    class={`flex h-3.5 w-3.5 items-center justify-center rounded-full text-[7px] font-semibold ring-[1.5px] ring-ink-950 ${av.classes}`}
                  >
                    {av.i}
                  </div>
                ))}
              </div>
              <span class="tabular-nums">{t.date}</span>
            </div>
          </div>
        ))}
      </div>
    ))}
  </div>
</div>
