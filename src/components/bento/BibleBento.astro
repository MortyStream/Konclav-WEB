---
const docs = [
  { ext: "PDF", name: "Statuts v3.pdf", meta: "1.2 MB · 12 mai", classes: "bg-rose-500/15 text-rose-300" },
  { ext: "DOC", name: "Modèle AG.docx", meta: "48 KB · 08 mai", classes: "bg-sky-500/15 text-sky-300" },
  { ext: "PDF", name: "PV-2024-10.pdf", meta: "320 KB · 02 mai", classes: "bg-rose-500/15 text-rose-300", badge: "Nouveau" },
];
---

<div class="relative h-full w-full overflow-hidden rounded-xl border border-white/[0.08] bg-gradient-to-b from-white/[0.04] to-white/[0.01] p-3.5">
  <!-- Search bar -->
  <div class="mb-3 flex h-8 items-center gap-2 rounded-lg border border-white/[0.08] bg-white/[0.04] px-2.5">
    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" class="h-3 w-3 text-white/45" aria-hidden="true">
      <circle cx="7" cy="7" r="4" />
      <path d="m13 13-3-3" />
    </svg>
    <span class="text-[11px] text-white/45">Rechercher un document…</span>
  </div>

  <!-- Filter pills -->
  <div class="mb-2.5 flex gap-1 text-[10px]">
    <span class="rounded-full border border-accent-500/30 bg-accent-500/15 px-2 py-0.5 font-medium text-accent-300">Tous</span>
    <span class="rounded-full px-2 py-0.5 text-white/45">PDF</span>
    <span class="rounded-full px-2 py-0.5 text-white/45">Récents</span>
  </div>

  <!-- File list -->
  <div class="space-y-1.5 fade-bottom">
    {docs.map((d) => (
      <div class="flex items-center gap-2.5 rounded-lg border border-white/[0.06] bg-white/[0.025] p-2">
        <div class={`flex h-8 w-8 shrink-0 items-center justify-center rounded-md text-[9px] font-bold ${d.classes}`}>
          {d.ext}
        </div>
        <div class="min-w-0 flex-1">
          <div class="flex items-center gap-1.5">
            <p class="truncate text-[12px] font-medium text-white/95">{d.name}</p>
            {d.badge && (
              <span class="shrink-0 rounded bg-emerald-400/15 px-1.5 py-px text-[9px] font-medium text-emerald-300">
                {d.badge}
              </span>
            )}
          </div>
          <p class="truncate text-[10px] text-white/45">{d.meta}</p>
        </div>
      </div>
    ))}
  </div>
</div>
