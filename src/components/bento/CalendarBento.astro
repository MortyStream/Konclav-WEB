---
const days = Array.from({ length: 35 }, (_, i) => {
  const date = i - 3;
  return {
    label: date > 0 && date <= 31 ? date : null,
    muted: date <= 0 || date > 31,
  };
});

const eventDays = new Set([5, 12, 13, 19, 22, 24, 28]);
const activeDay = 22;
---

<div class="relative flex h-full w-full flex-col overflow-hidden rounded-xl border border-white/[0.08] bg-gradient-to-b from-white/[0.04] to-white/[0.01] p-3.5">
  <!-- Month header -->
  <div class="mb-3 flex items-center justify-between">
    <div class="flex items-center gap-1.5">
      <span class="text-[12px] font-semibold text-white/95">Mai 2026</span>
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" class="h-3 w-3 text-white/40" aria-hidden="true">
        <path d="m4 6 4 4 4-4" />
      </svg>
    </div>
    <span class="rounded-md border border-accent-500/30 bg-accent-500/15 px-2 py-0.5 text-[10px] font-medium text-accent-300">AG samedi</span>
  </div>

  <!-- Weekday labels -->
  <div class="mb-1.5 grid grid-cols-7 gap-0.5 text-center">
    {["L", "M", "M", "J", "V", "S", "D"].map((d) => (
      <span class="text-[9px] font-medium uppercase tracking-wider text-white/45">{d}</span>
    ))}
  </div>

  <!-- Day grid (flex-1 to fill the card height) -->
  <div class="grid flex-1 grid-cols-7 gap-1 content-start">
    {days.map((d) => {
      if (!d.label) return <span class="aspect-square"></span>;
      const isActive = d.label === activeDay;
      const hasEvent = eventDays.has(d.label);
      return (
        <span
          class={`relative flex aspect-square items-center justify-center rounded-md text-[11px] tabular-nums ${
            isActive
              ? "bg-accent-500 font-semibold text-white shadow-[0_4px_12px_-2px_rgba(94,106,210,0.6)]"
              : hasEvent
              ? "bg-white/[0.05] font-medium text-white/85"
              : "text-white/55"
          }`}
        >
          {d.label}
          {hasEvent && !isActive && (
            <span class="absolute bottom-0.5 h-1 w-1 rounded-full bg-accent-400"></span>
          )}
        </span>
      );
    })}
  </div>
</div>
