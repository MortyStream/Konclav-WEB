---
import CTAButton from "./CTAButton.astro";

const links = [
  { href: "/#features", label: "Fonctionnalités" },
  { href: "/#security", label: "Sécurité" },
  { href: "/tarifs", label: "Tarifs" },
  { href: "/#faq", label: "FAQ" },
];
---

<header
  data-nav
  class="fixed inset-x-0 top-0 z-50 border-b border-white/5 bg-ink-950/60 backdrop-blur-md transition-[background-color,box-shadow] duration-300 ease-out"
>
  <nav
    class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6"
    aria-label="Navigation principale"
  >
    <a
      href="/"
      class="group flex items-center gap-2 text-base font-semibold tracking-tight text-ink-50"
    >
      <svg
        viewBox="0 0 32 32"
        fill="none"
        class="h-7 w-7 transition-transform duration-300 ease-out group-hover:scale-110 group-hover:rotate-3"
        aria-hidden="true"
      >
        <rect width="32" height="32" rx="7" fill="#0f1011"></rect>
        <path
          d="M11 8v16M11 16l8-8M11 16l8 8"
          stroke="#5e6ad2"
          stroke-width="2.4"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
      Konclav
    </a>

    <ul class="hidden items-center gap-8 md:flex">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="link-underline text-sm text-ink-400 transition-colors hover:text-ink-50"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Desktop CTA -->
    <div class="hidden md:block">
      <CTAButton href="/demo" magnetic arrow={false} class="px-3.5 py-2 text-sm">
        Réserver une démo
      </CTAButton>
    </div>

    <!-- Mobile burger -->
    <button
      type="button"
      data-menu-toggle
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-white/10 bg-white/[0.02] text-ink-50 md:hidden"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" class="h-5 w-5" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16" />
      </svg>
    </button>
  </nav>
</header>

<!-- Mobile menu drawer -->
<div
  id="mobile-menu"
  data-menu-panel
  inert
  aria-hidden="true"
  class="fixed inset-0 z-[60] hidden bg-ink-950/95 backdrop-blur-md"
>
  <div class="flex h-16 items-center justify-between border-b border-white/5 px-6">
    <span class="text-base font-semibold tracking-tight text-ink-50">Menu</span>
    <button
      type="button"
      data-menu-close
      aria-label="Fermer le menu"
      class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-white/10 bg-white/[0.02] text-ink-50"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" class="h-5 w-5" aria-hidden="true">
        <path d="M6 6l12 12M18 6l-12 12" />
      </svg>
    </button>
  </div>

  <nav class="px-6 py-8" aria-label="Navigation mobile">
    <ul class="flex flex-col gap-1">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="block rounded-lg border border-transparent px-4 py-3 text-base font-medium text-ink-50 transition-colors hover:border-white/10 hover:bg-white/[0.02]"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
    <div class="mt-8 border-t border-white/[0.06] pt-8">
      <CTAButton href="/demo" arrow size="lg" class="w-full">
        Réserver une démo
      </CTAButton>
    </div>
  </nav>
</div>
