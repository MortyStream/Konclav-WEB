---
const links = [
  { href: "#features", label: "Fonctionnalités" },
  { href: "#security", label: "Sécurité" },
  { href: "#faq", label: "FAQ" },
];
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-white/5 bg-ink-950/70 backdrop-blur-md"
>
  <nav
    class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6"
    aria-label="Navigation principale"
  >
    <a
      href="/"
      class="flex items-center gap-2 text-base font-semibold tracking-tight text-ink-50"
    >
      <svg
        viewBox="0 0 32 32"
        fill="none"
        class="h-7 w-7"
        aria-hidden="true"
      >
        <rect width="32" height="32" rx="7" fill="#0f1011"></rect>
        <path
          d="M11 8v16M11 16l8-8M11 16l8 8"
          stroke="#5e6ad2"
          stroke-width="2.4"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
      Konclav
    </a>

    <ul class="hidden items-center gap-8 md:flex">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sm text-ink-400 transition-colors hover:text-ink-50"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <a
      href="/demo"
      class="inline-flex items-center rounded-lg bg-accent-500 px-3.5 py-2 text-sm font-medium text-white transition-colors hover:bg-accent-400"
    >
      Réserver une démo
    </a>
  </nav>
</header>
