---
const productLinks = [
  { href: "#features", label: "Fonctionnalités" },
  { href: "#security", label: "Sécurité" },
  { href: "/tarifs", label: "Tarifs" },
  { href: "/demo", label: "Demander une démo" },
  { href: "#faq", label: "FAQ" },
];

const legalLinks = [
  { href: "/confidentialite", label: "Confidentialité" },
  { href: "/conditions", label: "Conditions" },
  { href: "/mentions-legales", label: "Mentions légales" },
];

const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 px-6 py-12">
  <div class="mx-auto max-w-6xl">
    <div
      class="flex flex-col gap-8 md:flex-row md:items-center md:justify-between"
    >
      <a
        href="/"
        class="flex items-center gap-2 text-base font-semibold tracking-tight text-ink-50"
      >
        <svg
          viewBox="0 0 32 32"
          fill="none"
          class="h-7 w-7"
          aria-hidden="true"
        >
          <rect width="32" height="32" rx="7" fill="#0f1011"></rect>
          <path
            d="M11 8v16M11 16l8-8M11 16l8 8"
            stroke="#5e6ad2"
            stroke-width="2.4"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        Konclav
      </a>

      <ul
        class="flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-ink-400"
      >
        {
          productLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="transition-colors hover:text-ink-50"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div
      class="mt-10 flex flex-col gap-4 border-t border-white/5 pt-6 md:flex-row md:items-center md:justify-between"
    >
      <p class="text-xs text-ink-500">
        © {year} Konclav. Fait en Suisse.
      </p>
      <ul
        class="flex flex-wrap items-center gap-x-6 gap-y-2 text-xs text-ink-500"
      >
        {
          legalLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="transition-colors hover:text-ink-50"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</footer>
