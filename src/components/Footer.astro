---
const legalLinks = [
  { href: "/confidentialite", label: "Confidentialité" },
  { href: "/conditions", label: "Conditions" },
  { href: "/sous-traitance", label: "Sous-traitance" },
  { href: "/suppression-compte", label: "Suppression de compte" },
  { href: "/mentions-legales", label: "Mentions légales" },
];

const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 px-6 py-10">
  <div
    class="mx-auto flex max-w-6xl flex-col gap-4 md:flex-row md:items-center md:justify-between"
  >
    <p class="text-xs text-ink-500">
      © {year} Konclav. Fait en Suisse.
    </p>
    <nav aria-label="Liens légaux">
      <ul
        class="flex flex-wrap items-center gap-x-5 gap-y-2 text-xs text-ink-500"
      >
        {
          legalLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="link-underline inline-block py-1.5 -my-1.5 transition-colors hover:text-ink-50"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</footer>
