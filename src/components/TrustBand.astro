---
const badges = [
  {
    label: "Conçu en Suisse",
    sub: "Pensé en Suisse romande",
    icon: "ch",
  },
  {
    label: "Conforme LPD & RGPD",
    sub: "Suisse et UE",
    icon: "shield",
  },
  {
    label: "Sans engagement",
    sub: "Résiliable au mois",
    icon: "globe",
  },
  {
    label: "Chiffré AES-256",
    sub: "Au repos, en transit",
    icon: "lock",
  },
];
---

<section
  aria-label="Garanties techniques et conformité"
  class="relative border-y border-white/[0.06] px-6 py-8"
>
  <ul
    class="mx-auto grid max-w-6xl grid-cols-2 gap-x-6 gap-y-5 sm:grid-cols-4"
  >
    {badges.map((b, i) => (
      <li
        data-reveal
        style={`transition-delay: ${i * 60}ms`}
        class="flex items-center gap-3"
      >
        <span class="icon-tile flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-white/10 bg-white/[0.02] text-accent-400">
          {b.icon === "ch" && (
            <svg viewBox="0 0 32 32" class="h-4 w-4" aria-hidden="true">
              <rect width="32" height="32" rx="3" fill="#DA291C" />
              <rect x="13" y="6" width="6" height="20" fill="#fff" />
              <rect x="6" y="13" width="20" height="6" fill="#fff" />
            </svg>
          )}
          {b.icon === "shield" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
              <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z" />
              <path d="m9 12 2 2 4-4" />
            </svg>
          )}
          {b.icon === "globe" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
              <circle cx="12" cy="12" r="10" />
              <path d="M12 2a14.5 14.5 0 0 1 0 20a14.5 14.5 0 0 1 0-20" />
              <path d="M2 12h20" />
            </svg>
          )}
          {b.icon === "lock" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
              <rect width="18" height="11" x="3" y="11" rx="2" ry="2" />
              <path d="M7 11V7a5 5 0 0 1 10 0v4" />
            </svg>
          )}
        </span>
        <div class="min-w-0">
          <p class="truncate text-sm font-medium text-ink-50">{b.label}</p>
          <p class="truncate text-[11px] text-ink-400">{b.sub}</p>
        </div>
      </li>
    ))}
  </ul>
</section>
