---
interface Props {
  href: string;
  variant?: "primary" | "secondary";
  size?: "md" | "lg";
  arrow?: boolean;
  joinOpen?: boolean;
  class?: string;
}

const {
  href,
  variant = "primary",
  size = "md",
  arrow = true,
  joinOpen = false,
  class: extraClass = "",
} = Astro.props;

const sizeClass = size === "lg" ? "px-7 py-4 text-sm" : "px-5 py-3 text-sm";

const variantClass =
  variant === "primary"
    ? "cta-shimmer bg-accent-500 text-white shadow-[var(--shadow-cta)] hover:bg-accent-400"
    : "border border-white/10 bg-white/[0.02] text-ink-50 hover:border-white/20 hover:bg-white/[0.05]";

const baseClass = "group/cta inline-flex items-center justify-center gap-1.5 rounded-xl font-semibold transition-colors";
---

<a
  href={href}
  data-join-open={joinOpen ? "" : undefined}
  class={`${baseClass} ${sizeClass} ${variantClass} ${extraClass}`}
>
  <slot />
  {arrow && (
    <svg
      viewBox="0 0 16 16"
      fill="none"
      class="h-4 w-4 transition-transform duration-300 ease-out group-hover/cta:translate-x-0.5"
      aria-hidden="true"
    >
      <path
        d="M3.5 8h9m0 0L8 3.5M12.5 8 8 12.5"
        stroke="currentColor"
        stroke-width="1.75"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  )}
</a>
