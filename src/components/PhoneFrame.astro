---
interface Props {
  activeTab?: "accueil" | "taches" | "agenda" | "plus";
  rotate?: string;
  translateY?: string;
  delay?: number;
  zIndex?: number;
  float?: "" | "float" | "float-delay" | "float-slow" | "float-late";
  hoverScale?: boolean;
}

const {
  activeTab = "accueil",
  rotate = "",
  translateY = "",
  delay = 0,
  zIndex = 0,
  float = "",
  hoverScale = true,
} = Astro.props;

const floatClass = float ? `animate-${float}` : "";
const hoverClass = hoverScale ? "hover:scale-[1.03]" : "";

const tabs = [
  { id: "accueil", label: "Accueil" },
  { id: "taches", label: "Tâches" },
  { id: "agenda", label: "Agenda" },
  { id: "plus", label: "Plus" },
] as const;
---

<div
  data-reveal
  style={`transition-delay: ${delay}ms; z-index: ${zIndex};`}
  class="relative shrink-0 snap-center"
>
  <div class={floatClass}>
  <div
    class={`transition-transform duration-500 ease-out ${hoverClass} ${rotate} ${translateY}`}
  >
    <div
      class="relative h-[540px] w-[260px] rounded-[44px] border border-white/10 bg-neutral-950 p-[6px] shadow-[0_30px_80px_-20px_rgba(94,106,210,0.35),0_0_0_1px_rgba(255,255,255,0.04)]"
    >
      <div
        class="relative h-full overflow-hidden rounded-[38px] bg-black ring-1 ring-white/5"
      >
        <!-- Notch -->
        <div
          class="absolute left-1/2 top-2 z-30 flex h-6 w-20 -translate-x-1/2 items-center justify-center rounded-full bg-black"
        >
          <div class="h-1 w-1 rounded-full bg-white/20"></div>
        </div>

        <!-- Inner violet glow at top -->
        <div
          aria-hidden="true"
          class="pointer-events-none absolute inset-x-0 top-0 z-0 h-32"
          style="background: radial-gradient(circle at 50% 0%, rgba(94,106,210,0.18), transparent 60%);"
        >
        </div>

        <!-- Status bar -->
        <div
          class="relative z-20 flex h-9 items-center justify-between px-5 text-[10px] font-medium text-white/70"
        >
          <span class="tabular-nums">13:37</span>
          <div class="flex items-center gap-1">
            <div class="flex items-end gap-px">
              <div class="h-1 w-0.5 rounded-sm bg-white/70"></div>
              <div class="h-1.5 w-0.5 rounded-sm bg-white/70"></div>
              <div class="h-2 w-0.5 rounded-sm bg-white/70"></div>
            </div>
            <span>5G</span>
            <div
              class="relative ml-0.5 flex h-[10px] w-[18px] items-center rounded-[2px] border border-white/40 px-[1px]"
            >
              <div class="h-[6px] w-[10px] rounded-[1px] bg-white/70"></div>
            </div>
          </div>
        </div>

        <!-- Screen content slot -->
        <div class="absolute inset-x-0 top-9 bottom-16 overflow-hidden">
          <slot />
        </div>

        <!-- Bottom nav -->
        <div
          class="absolute inset-x-0 bottom-0 z-20 grid h-16 grid-cols-4 border-t border-white/[0.06] bg-black/60 backdrop-blur"
        >
          {
            tabs.map((tab) => {
              const active = tab.id === activeTab;
              return (
                <div class="relative flex flex-col items-center justify-center gap-1">
                  {active && (
                    <div class="absolute top-2 h-1 w-1 rounded-full bg-accent-500" />
                  )}
                  <svg
                    class={`h-4 w-4 ${active ? "text-accent-500" : "text-white/40"}`}
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    {tab.id === "accueil" && (
                      <path d="M3 11l9-8 9 8v9a2 2 0 0 1-2 2h-4v-7h-6v7H5a2 2 0 0 1-2-2z" />
                    )}
                    {tab.id === "taches" && (
                      <Fragment>
                        <rect width="18" height="18" x="3" y="3" rx="2" />
                        <path d="M8 7v9M12 7v6M16 7v11" />
                      </Fragment>
                    )}
                    {tab.id === "agenda" && (
                      <Fragment>
                        <path d="M8 2v4M16 2v4" />
                        <rect width="18" height="18" x="3" y="4" rx="2" />
                        <path d="M3 10h18" />
                      </Fragment>
                    )}
                    {tab.id === "plus" && (
                      <Fragment>
                        <circle cx="5" cy="12" r="1" />
                        <circle cx="12" cy="12" r="1" />
                        <circle cx="19" cy="12" r="1" />
                      </Fragment>
                    )}
                  </svg>
                  <span
                    class={`text-[9px] font-medium ${active ? "text-accent-500" : "text-white/40"}`}
                  >
                    {tab.label}
                  </span>
                </div>
              );
            })
          }
        </div>
      </div>
    </div>
  </div>
  </div>
</div>
