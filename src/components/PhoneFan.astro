---
import PhoneShot from "./PhoneShot.astro";

// Cluster "main de cartes" : 2 téléphones au centre (devant/hauts),
// 2 sur les côtés (derrière/bas). Au survol, le tel se soulève et passe devant.
const phones = [
  { pos: "l", src: "/app/agenda-semaine.webp", alt: "Konclav — agenda, vue semaine des entraînements", delay: 0, float: "float-slow", priority: false },
  { pos: "c1", src: "/app/tache.webp", alt: "Konclav — détail d'une tâche avec validation", delay: 120, float: "float", priority: true },
  { pos: "c2", src: "/app/documents.webp", alt: "Konclav — documents et dossiers de l'association", delay: 240, float: "float-late", priority: true },
  { pos: "r", src: "/app/annuaire.webp", alt: "Konclav — annuaire des membres", delay: 360, float: "float-delay", priority: false },
] as const;
---

<div class="phone-show">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute left-1/2 top-1/2 -z-10 h-[120%] w-[125%] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-60 blur-3xl"
    style="background: radial-gradient(ellipse 60% 55% at center, rgba(94,106,210,0.42), transparent 70%);"
  >
  </div>

  {
    phones.map((p) => (
      <div class="phone-show__item" data-pos={p.pos}>
        <PhoneShot src={p.src} alt={p.alt} delay={p.delay} float={p.float} hoverScale={false} priority={p.priority} />
      </div>
    ))
  }
</div>

<script is:inline>
  (function () {
    const el = document.querySelector(".phone-show");
    if (!el) return;
    // Échelle fluide : interpole entre deux largeurs d'écran, puis borne.
    const MINW = 1024,
      MAXW = 1800,
      MINF = 0.52,
      MAXF = 0.92;
    const apply = () => {
      const t = Math.max(0, Math.min(1, (window.innerWidth - MINW) / (MAXW - MINW)));
      el.style.setProperty("--fit", (MINF + t * (MAXF - MINF)).toFixed(3));
    };
    apply();
    let raf = 0;
    window.addEventListener(
      "resize",
      () => {
        if (raf) return;
        raf = requestAnimationFrame(() => {
          raf = 0;
          apply();
        });
      },
      { passive: true }
    );
  })();
</script>
