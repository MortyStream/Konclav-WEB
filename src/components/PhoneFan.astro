---
import PhoneShot from "./PhoneShot.astro";

// Cluster "main de cartes" : 2 téléphones au centre (devant/hauts),
// 2 sur les côtés (derrière/bas). Au survol, le tel se soulève et passe devant.
const phones = [
  { pos: "l", src: "/app/agenda-semaine.webp", alt: "Konclav — agenda, vue semaine des entraînements", delay: 0, float: "float-slow" },
  { pos: "c1", src: "/app/tache.webp", alt: "Konclav — détail d'une tâche avec validation", delay: 120, float: "float" },
  { pos: "c2", src: "/app/documents.webp", alt: "Konclav — documents et dossiers de l'association", delay: 240, float: "float-late" },
  { pos: "r", src: "/app/annuaire.webp", alt: "Konclav — annuaire des membres", delay: 360, float: "float-delay" },
] as const;
---

<div class="phone-show">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute left-1/2 top-1/2 -z-10 h-[120%] w-[125%] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-60 blur-3xl"
    style="background: radial-gradient(ellipse 60% 55% at center, rgba(94,106,210,0.42), transparent 70%);"
  >
  </div>

  {
    phones.map((p) => (
      <div class="phone-show__item" data-pos={p.pos}>
        <PhoneShot src={p.src} alt={p.alt} delay={p.delay} float={p.float} hoverScale={false} />
      </div>
    ))
  }
</div>
