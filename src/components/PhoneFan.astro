---
import PhoneFrame from "./PhoneFrame.astro";
import KanbanScreen from "./screens/KanbanScreen.astro";
import AgendaScreen from "./screens/AgendaScreen.astro";
import BibleScreen from "./screens/BibleScreen.astro";
import NotificationsScreen from "./screens/NotificationsScreen.astro";

// Cluster "main de cartes" : 2 téléphones au centre (devant/hauts),
// 2 sur les côtés (derrière/bas). Au survol, le tel se soulève et passe devant.
const phones = [
  { pos: "l", tab: "taches", Screen: KanbanScreen, delay: 0, float: "float-slow" },
  { pos: "c1", tab: "agenda", Screen: AgendaScreen, delay: 120, float: "float" },
  { pos: "c2", tab: "plus", Screen: BibleScreen, delay: 240, float: "float-late" },
  { pos: "r", tab: "accueil", Screen: NotificationsScreen, delay: 360, float: "float-delay" },
] as const;
---

<div class="phone-show">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute left-1/2 top-1/2 -z-10 h-[120%] w-[125%] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-60 blur-3xl"
    style="background: radial-gradient(ellipse 60% 55% at center, rgba(94,106,210,0.42), transparent 70%);"
  >
  </div>

  {
    phones.map((p) => {
      const Screen = p.Screen;
      return (
        <div class="phone-show__item" data-pos={p.pos}>
          <PhoneFrame activeTab={p.tab} delay={p.delay} float={p.float} hoverScale={false}>
            <Screen />
          </PhoneFrame>
        </div>
      );
    })
  }
</div>
