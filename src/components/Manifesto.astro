---

---

<section
  class="relative isolate overflow-hidden px-6 py-40 sm:py-48 lg:py-56"
>
  <!-- Vertical accent rule on the left -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute left-6 top-1/2 -z-10 hidden h-32 w-px -translate-y-1/2 bg-gradient-to-b from-transparent via-accent-500/40 to-transparent lg:block"
  ></div>

  <div class="mx-auto max-w-6xl">
    <p
      data-reveal
      class="text-center text-xs font-medium uppercase tracking-[0.18em] text-accent-500"
    >
      Manifeste
    </p>

    <h2
      data-reveal
      data-split-text
      class="display-manifesto mt-10 text-balance text-center text-ink-50"
    >
      Vos données. Vos <span class="italic-display">règles</span>. Votre asso.
    </h2>

    <p
      data-reveal
      class="mx-auto mt-12 max-w-2xl text-pretty text-center text-base leading-relaxed text-ink-400 sm:text-lg"
    >
      Konclav est un <em class="not-italic font-semibold text-ink-50">outil</em>.
      Pas un produit qui transforme vos membres en données vendables. Pas de
      pub, pas de pixels, pas de « data partner » — juste une mesure d'audience
      anonyme et sans cookie. Vous payez l'app, vous possédez tout.
    </p>

    <!-- Single stat callout replacing the redundant pill row -->
    <div
      data-reveal
      class="mx-auto mt-14 grid max-w-2xl grid-cols-1 gap-3 sm:grid-cols-3"
    >
      <div class="bento p-5 text-center">
        <p class="text-3xl font-semibold tabular-nums text-ink-50 sm:text-4xl">0</p>
        <p class="mt-1 text-[11px] uppercase tracking-widest text-ink-500">Trackers</p>
      </div>
      <div class="bento p-5 text-center">
        <p class="text-3xl font-semibold tabular-nums text-ink-50 sm:text-4xl">100<span class="text-xl">%</span></p>
        <p class="mt-1 text-[11px] uppercase tracking-widest text-ink-500">Hébergé UE</p>
      </div>
      <div class="bento p-5 text-center">
        <p class="text-3xl font-semibold tabular-nums text-ink-50 sm:text-4xl">30j</p>
        <p class="mt-1 text-[11px] uppercase tracking-widest text-ink-500">Backups chiffrés</p>
      </div>
    </div>
  </div>
</section>
