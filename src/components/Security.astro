---
import Icon from "./Icon.astro";

const points = [
  {
    icon: "database" as const,
    title: "Cloisonnement RLS Postgres",
    description:
      "Row Level Security stricte. Chaque association ne voit que ses propres données, garanti par la base.",
  },
  {
    icon: "lock" as const,
    title: "TLS 1.2+ & AES-256",
    description:
      "Chiffrement en transit et au repos. Standards industriels modernes, sans compromis.",
  },
  {
    icon: "shield-check" as const,
    title: "2FA TOTP",
    description:
      "Second facteur pour tous les comptes admin. Compatible Google Authenticator, Authy, 1Password.",
  },
  {
    icon: "hard-drive" as const,
    title: "Sauvegardes chiffrées 30j",
    description:
      "Backups quotidiens chiffrés, conservés 30 jours, restauration testée régulièrement.",
  },
];
---

<section
  id="security"
  class="relative border-t border-white/[0.06] px-6 py-32 sm:py-40"
>
  <div class="mx-auto max-w-7xl">
    <div class="mx-auto max-w-3xl text-center">
      <p data-reveal class="text-xs font-medium uppercase tracking-[0.18em] text-accent-400">
        Sécurité
      </p>
      <h2
        data-reveal
        data-split-text
        class="display-section mt-4 text-balance text-ink-50"
      >
        Privé veut dire privé.
      </h2>
      <p
        data-reveal
        class="mx-auto mt-5 max-w-xl text-pretty text-base leading-relaxed text-ink-400 sm:text-lg"
      >
        Pas de publicité, pas de revente, pas de « data partner ». Vos données
        restent les vôtres — techniquement et contractuellement.
      </p>
    </div>

    <!-- Top : 2 huge stat bento cards -->
    <div class="mt-20 grid grid-cols-12 gap-4 sm:gap-5">
      <article
        data-reveal
        class="bento group relative col-span-12 flex min-h-[280px] flex-col justify-between overflow-hidden p-7 sm:p-10 lg:col-span-7"
      >
        <div>
          <span class="rounded-md border border-emerald-400/30 bg-emerald-400/10 px-2 py-0.5 text-[10px] font-medium uppercase tracking-wider text-emerald-300">
            Mesure d'audience
          </span>
        </div>
        <div>
          <div class="text-5xl font-semibold tracking-tight text-ink-50 sm:text-6xl">Umami</div>
          <p class="mt-4 max-w-md text-sm leading-relaxed text-ink-400">
            Pas de Google Analytics, pas de pixels publicitaires, aucun cookie
            marketing — juste Umami, une mesure d'audience anonyme et sans
            cookie. Le formulaire de démo passe par Google Forms (US) ; détails
            dans la politique de confidentialité.
          </p>
        </div>
        <div
          aria-hidden="true"
          class="pointer-events-none absolute -bottom-20 -right-20 h-72 w-72 rounded-full opacity-40 blur-3xl"
          style="background: radial-gradient(closest-side, rgba(74,222,128,0.25), transparent 70%);"
        ></div>
      </article>

      <article
        data-reveal
        style="transition-delay: 80ms;"
        class="bento group relative col-span-12 flex min-h-[280px] flex-col justify-between overflow-hidden p-7 sm:p-10 lg:col-span-5"
      >
        <div>
          <span class="rounded-md border border-accent-500/30 bg-accent-500/10 px-2 py-0.5 text-[10px] font-medium uppercase tracking-wider text-accent-400">
            Hébergement
          </span>
        </div>
        <div>
          <div class="text-5xl font-semibold tracking-tight text-ink-50 sm:text-6xl">UE</div>
          <p class="mt-4 max-w-sm text-sm leading-relaxed text-ink-400">
            Base de données et fichiers sur AWS eu-west-1 (Irlande). Certains
            services accessoires (notifications push, e-mails transactionnels)
            transitent par les États-Unis — détails dans la politique de
            confidentialité.
          </p>
        </div>
        <div
          aria-hidden="true"
          class="pointer-events-none absolute -bottom-20 -right-12 h-72 w-72 rounded-full opacity-40 blur-3xl"
          style="background: radial-gradient(closest-side, rgba(94,106,210,0.35), transparent 70%);"
        ></div>
      </article>

      <!-- Bottom : 4 detail items in a row -->
      {points.map((p, i) => (
        <article
          data-reveal
          style={`transition-delay: ${(i + 2) * 80}ms`}
          class="bento group relative col-span-12 flex flex-col gap-3 p-6 sm:col-span-6 lg:col-span-3"
        >
          <div class="icon-tile inline-flex h-9 w-9 items-center justify-center rounded-lg border border-white/10 bg-white/[0.03] text-accent-400">
            <Icon name={p.icon} class="h-4 w-4" />
          </div>
          <h3 class="text-sm font-semibold tracking-tight text-ink-50">{p.title}</h3>
          <p class="text-sm leading-relaxed text-ink-400">{p.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
