---
const steps = [
  {
    title: "Contact",
    description:
      "On échange 30 minutes. On comprend votre asso, vos workflows actuels, vos contraintes.",
  },
  {
    title: "Provisionnement",
    description:
      "On crée votre espace, on configure vos rôles, on importe vos membres existants (CSV ou copier-coller).",
  },
  {
    title: "Go live",
    description:
      "Formation d'une heure avec votre comité, support dédié les premiers jours. Vos membres reçoivent leur accès.",
  },
];
---

<section
  id="onboarding"
  class="relative border-t border-white/5 px-6 py-32 sm:py-40"
>
  <div class="mx-auto max-w-6xl">
    <div class="mx-auto max-w-3xl text-center">
      <p data-reveal class="text-xs font-medium uppercase tracking-[0.18em] text-accent-500">Démarrage</p>
      <h2
        data-reveal
        data-split-text
        class="display-section mt-4 text-balance text-ink-50"
      >
        De zéro à go live en 7 jours.
      </h2>
      <p
        data-reveal
        class="mx-auto mt-5 max-w-xl text-pretty text-base leading-relaxed text-ink-400 sm:text-lg"
      >
        Pas d'installation, pas de migration douloureuse. On vous accompagne
        pas à pas.
      </p>
    </div>

    <div class="relative mt-16">
      <!-- Connecteur SVG draw-on-scroll, desktop only -->
      <svg
        data-draw
        aria-hidden="true"
        viewBox="0 0 1000 60"
        preserveAspectRatio="none"
        class="pointer-events-none absolute left-0 right-0 top-3 hidden h-14 w-full sm:block"
      >
        <defs>
          <linearGradient id="step-line" x1="0" x2="1" y1="0" y2="0">
            <stop offset="0%" stop-color="#5e6ad2" stop-opacity="0.15" />
            <stop offset="50%" stop-color="#7170ff" stop-opacity="0.9" />
            <stop offset="100%" stop-color="#5e6ad2" stop-opacity="0.15" />
          </linearGradient>
        </defs>
        <path
          d="M 80 30 Q 250 -8 500 30 T 920 30"
          stroke="url(#step-line)"
          stroke-width="1.5"
          stroke-linecap="round"
          fill="none"
        />
      </svg>

      <ol class="relative grid gap-x-8 gap-y-12 sm:grid-cols-3">
        {
          steps.map((step, i) => (
            <li
              data-reveal
              style={`transition-delay: ${i * 120}ms`}
              class="relative"
            >
              <div class="flex items-center gap-3">
                <span class="step-dot inline-flex h-6 w-6 items-center justify-center rounded-full border border-accent-500/40 bg-ink-950 text-[10px] font-semibold tabular-nums text-accent-400">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <span class="text-xs font-medium tracking-widest text-accent-500 uppercase">
                  Étape
                </span>
              </div>
              <h3 class="mt-4 text-lg font-semibold tracking-tight text-ink-50">
                {step.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-400">
                {step.description}
              </p>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>
