---
const steps = [
  {
    title: "Contact",
    description:
      "On échange 20 minutes. On comprend votre asso, vos workflows actuels, vos contraintes.",
    duration: "20 min",
  },
  {
    title: "Provisionnement",
    description:
      "On crée votre espace, on configure vos rôles, on importe vos membres existants (CSV ou copier-coller).",
    duration: "48 h",
  },
  {
    title: "Go live",
    description:
      "Formation d'une heure avec votre comité, support dédié les premiers jours. Vos membres reçoivent leur accès.",
    duration: "7 jours",
  },
];
---

<section
  id="onboarding"
  class="relative border-t border-white/[0.06] px-6 py-28 sm:py-36"
>
  <div class="mx-auto max-w-7xl">
    <div class="mx-auto max-w-3xl text-center">
      <p data-reveal class="text-xs font-medium uppercase tracking-[0.18em] text-accent-500">Démarrage</p>
      <h2
        data-reveal
        data-split-text
        class="display-section mt-4 text-balance text-ink-50"
      >
        De zéro à go live en 7 jours.
      </h2>
      <p
        data-reveal
        class="mx-auto mt-5 max-w-xl text-pretty text-base leading-relaxed text-ink-400 sm:text-lg"
      >
        Pas d'installation, pas de migration douloureuse. On vous accompagne
        pas à pas.
      </p>
    </div>

    <ol class="relative mt-16 grid gap-4 sm:gap-5 lg:grid-cols-3">
      {steps.map((step, i) => (
        <li
          data-reveal
          style={`transition-delay: ${i * 120}ms`}
          class="bento group relative flex flex-col p-6 sm:p-7"
        >
          <!-- Step number badge -->
          <div class="flex items-center gap-3">
            <span class="step-dot inline-flex h-8 w-8 items-center justify-center rounded-full border border-accent-500/40 bg-ink-950 text-[11px] font-semibold tabular-nums text-accent-300">
              {String(i + 1).padStart(2, "0")}
            </span>
            <span class="text-[10px] font-semibold uppercase tracking-[0.18em] text-ink-500">
              Étape {i + 1} / 3
            </span>
          </div>

          <h3 class="mt-5 text-xl font-semibold tracking-tight text-ink-50">
            {step.title}
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-400">
            {step.description}
          </p>

          <!-- Duration indicator at bottom -->
          <div class="mt-6 flex items-center gap-2 border-t border-white/[0.05] pt-4">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="h-3.5 w-3.5 text-accent-400" aria-hidden="true">
              <circle cx="8" cy="8" r="6" />
              <path d="M8 4.5V8l2 1.5" />
            </svg>
            <span class="text-[12px] font-medium tabular-nums text-ink-50">{step.duration}</span>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
