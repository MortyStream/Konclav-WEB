---

---

<section class="relative border-t border-white/[0.06] px-6 py-28 sm:py-32">
  <div class="mx-auto max-w-5xl">
    <div class="mx-auto max-w-3xl text-center">
      <p data-reveal class="text-xs font-medium uppercase tracking-[0.18em] text-accent-500">
        Simulateur
      </p>
      <h2
        data-reveal
        data-split-text
        class="display-section mt-4 text-balance text-ink-50"
      >
        Combien ça coûte pour <span class="italic-display">votre</span> asso ?
      </h2>
      <p
        data-reveal
        class="mx-auto mt-5 max-w-xl text-pretty text-base leading-relaxed text-ink-400 sm:text-lg"
      >
        Estimation honnête. On ne facture que les membres connectés au moins
        une fois dans le mois.
      </p>
    </div>

    <div
      data-reveal
      class="bento mt-14 grid grid-cols-1 gap-8 p-6 sm:p-10 lg:grid-cols-2 lg:items-center"
    >
      <!-- Controls -->
      <div class="space-y-8">
        <div>
          <label for="sim-members" class="flex items-baseline justify-between text-sm">
            <span class="font-medium text-ink-50">Membres dans votre asso</span>
            <span class="text-lg font-semibold tabular-nums text-ink-50">
              <output id="sim-members-value" for="sim-members">60</output>
            </span>
          </label>
          <input
            id="sim-members"
            type="range"
            min="10"
            max="500"
            step="5"
            value="60"
            class="mt-3 w-full accent-accent-500"
            aria-describedby="sim-members-hint"
          />
          <div class="mt-2 flex justify-between text-[10px] text-ink-500 tabular-nums">
            <span>10</span><span>250</span><span>500+</span>
          </div>
          <p id="sim-members-hint" class="mt-2 text-xs text-ink-500">
            Total de membres inscrits dans votre asso, actifs ou non.
          </p>
        </div>

        <div>
          <label for="sim-active" class="flex items-baseline justify-between text-sm">
            <span class="font-medium text-ink-50">Taux de membres actifs</span>
            <span class="text-lg font-semibold tabular-nums text-ink-50">
              <output id="sim-active-value" for="sim-active">40</output>%
            </span>
          </label>
          <input
            id="sim-active"
            type="range"
            min="10"
            max="100"
            step="5"
            value="40"
            class="mt-3 w-full accent-accent-500"
            aria-describedby="sim-active-hint"
          />
          <div class="mt-2 flex justify-between text-[10px] text-ink-500 tabular-nums">
            <span>10%</span><span>55%</span><span>100%</span>
          </div>
          <p id="sim-active-hint" class="mt-2 text-xs text-ink-500">
            Moyenne observée : 40%. Les membres qui ne se connectent pas ne
            sont jamais facturés.
          </p>
        </div>
      </div>

      <!-- Result -->
      <div class="rounded-xl border border-white/[0.08] bg-gradient-to-b from-accent-500/[0.06] to-transparent p-6 text-center sm:p-8">
        <p class="text-xs font-medium uppercase tracking-widest text-ink-500">Votre coût estimé</p>
        <p class="mt-3 flex items-baseline justify-center gap-1.5">
          <span id="sim-price" class="display-stat tabular-nums text-ink-50">96</span>
          <span class="text-lg font-medium text-ink-400">CHF / mois</span>
        </p>
        <p id="sim-detail" class="mt-3 text-sm text-ink-400">
          24 membres actifs × 4 CHF
        </p>
        <p id="sim-floor-note" class="mt-2 hidden text-xs text-amber-300">
          Forfait minimum appliqué (39 CHF).
        </p>
        <div class="mt-6 border-t border-white/[0.06] pt-5">
          <p class="text-xs text-ink-500">
            Sans engagement · Résiliable au mois · Prix nets, sans TVA
          </p>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      const $members = document.getElementById('sim-members');
      const $active = document.getElementById('sim-active');
      const $membersVal = document.getElementById('sim-members-value');
      const $activeVal = document.getElementById('sim-active-value');
      const $price = document.getElementById('sim-price');
      const $detail = document.getElementById('sim-detail');
      const $floor = document.getElementById('sim-floor-note');
      if (!$members || !$active) return;
      const PRICE_PER_ACTIVE = 4;
      const FLOOR = 39;
      const update = () => {
        const total = parseInt($members.value, 10);
        const rate = parseInt($active.value, 10);
        const active = Math.max(1, Math.round((total * rate) / 100));
        const raw = active * PRICE_PER_ACTIVE;
        const final = Math.max(FLOOR, raw);
        $membersVal.textContent = total >= 500 ? '500+' : total;
        $activeVal.textContent = rate;
        $price.textContent = final;
        $detail.textContent = `${active} membre${active > 1 ? 's' : ''} actif${active > 1 ? 's' : ''} × ${PRICE_PER_ACTIVE} CHF`;
        if (raw < FLOOR) $floor.classList.remove('hidden');
        else $floor.classList.add('hidden');
      };
      $members.addEventListener('input', update);
      $active.addEventListener('input', update);
      update();
    })();
  </script>
</section>
